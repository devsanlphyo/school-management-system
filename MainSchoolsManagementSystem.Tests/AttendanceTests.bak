        public async Task Test_HeadmasterOverride_SimultaneousByDifferentUsers()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("HM School A");
            var hm1 = await CreateUserAsync("hm11a@school.com", "HM A", "Headmaster", school.Id);
            var hm2 = await CreateUserAsync("hm11b@school.com", "HM B", "Headmaster", school.Id);
            var teacher = await CreateUserAsync("t_or11@school.com", "Teacher Eleven", "Teacher", school.Id);

            // Simulate HM A setting Present
            using (var context = TestDbHelper.CreateDbContext())
            {
                var att = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, Status = AttendanceStatus.Present };
                context.Attendances.Add(att);
                await context.SaveChangesAsync();
            }

            // Simulate HM B setting Late concurrently
            using (var context = TestDbHelper.CreateDbContext())
            {
                var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
                record!.Status = AttendanceStatus.Late;
                context.Attendances.Update(record);
                await context.SaveChangesAsync();
            }

            using var contextFinal = TestDbHelper.CreateDbContext();
            var finalRecord = await contextFinal.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.Equals(AttendanceStatus.Late, finalRecord!.Status, "Database should reflect the latest update.");
        }

        public async Task Test_HeadmasterOverride_WhenTeacherIsCheckingIn()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("HM School A");
            var teacher = await CreateUserAsync("t_or12@school.com", "Teacher Twelve", "Teacher", school.Id);

            // Teacher check-in
            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, CheckedInAt = DateTime.UtcNow, Status = AttendanceStatus.Present };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            // Headmaster override happens right after
            attendance.Status = AttendanceStatus.Late;
            context.Attendances.Update(attendance);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.Equals(AttendanceStatus.Late, record!.Status, "Override should succeed even if teacher checked in.");
        }

