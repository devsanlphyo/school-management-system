    public static class Assert
    {
        public static void True(bool condition, string message)
        {
            if (!condition) throw new Exception($"Assert.True Failed: {message}");
        }
        public static void False(bool condition, string message)
        {
            if (condition) throw new Exception($"Assert.False Failed: {message}");
        }
        public static void Equals<T>(T expected, T actual, string message)
        {
            if (!EqualityComparer<T>.Default.Equals(expected, actual))
            {
                throw new Exception($"Assert.Equals Failed: {message}. Expected: {expected}, Actual: {actual}");
            }
        }
        public static void NotNull(object? obj, string message)
        {
            if (obj == null) throw new Exception($"Assert.NotNull Failed: {message}");
        }
        public static void Null(object? obj, string message)
        {
            if (obj != null) throw new Exception($"Assert.Null Failed: {message}");
        }
        public static void Fail(string message)
        {
            throw new Exception($"Assert.Fail: {message}");
        }
    }
}
