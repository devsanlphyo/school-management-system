        public async Task Test_CrossFeature_TeacherCheckIn_ThenHMView_ThenHMOverride_ThenTeacherDashboard()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Cross School");
            var hm = await CreateUserAsync("hm_cross@school.com", "Headmaster Cross", "Headmaster", school.Id);
            var teacher = await CreateUserAsync("t_cross@school.com", "Teacher Cross", "Teacher", school.Id);

            // 1. Teacher checks in (Late)
            using (var context = TestDbHelper.CreateDbContext())
            {
                var att = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, CheckedInAt = DateTime.Today.AddHours(9), Status = AttendanceStatus.Late };
                context.Attendances.Add(att);
                await context.SaveChangesAsync();
            }

            // 2. HM views and overrides to Present
            _authStateProvider.SetUser(hm.UserName!, "Headmaster", hm.Id, school.Id);
            var hmComponent = new MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance();
            InjectServices(hmComponent);

            var initMethod = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("OnInitializedAsync", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            await (Task)initMethod!.Invoke(hmComponent, null)!;

            var overrideMethod = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("SetAttendance", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            await (Task)overrideMethod!.Invoke(hmComponent, new object[] { teacher.Id, AttendanceStatus.Present })!;

            // 3. Verify in database
            using (var context = TestDbHelper.CreateDbContext())
            {
                var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
                Assert.Equals(AttendanceStatus.Present, record!.Status, "Status should now be Present.");
            }
        }

        public async Task Test_CrossFeature_HeadmasterOverride_ThenTeacherCheckIn_DoesNotOverwriteOverride()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Cross School");
            var teacher = await CreateUserAsync("t_cross2@school.com", "Teacher Cross 2", "Teacher", school.Id);

            // 1. HM overrides to Late (before teacher arrives)
            using (var context = TestDbHelper.CreateDbContext())
            {
                var att = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, Status = AttendanceStatus.Late, CheckedInAt = null };
                context.Attendances.Add(att);
                await context.SaveChangesAsync();
            }

            // 2. Teacher checks in. It should only update CheckedInAt, but keep the status as Late (from HM override).
            using (var context = TestDbHelper.CreateDbContext())
            {
                var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
                record!.CheckedInAt = DateTime.UtcNow;
                context.Attendances.Update(record);
                await context.SaveChangesAsync();
            }

            using (var context = TestDbHelper.CreateDbContext())
            {
                var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
                Assert.Equals(AttendanceStatus.Late, record!.Status, "Status should remain Late.");
                Assert.NotNull(record.CheckedInAt, "CheckedInAt should be set.");
            }
        }

        public async Task Test_CrossFeature_AdminChangesDeadline_ThenTeacherChecksIn_LatenessEvaluatedAgainstNewDeadline()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Cross School");
            var teacher = await CreateUserAsync("t_cross3@school.com", "Teacher Cross 3", "Teacher", school.Id);

            // 1. Change deadline from 08:30 to 09:00
            await SetDailyDeadlineAsync(new TimeSpan(9, 0, 0));

            // 2. Teacher checks in at 08:45 (would be late under old deadline, but present under new)
            var checkInTime = DateTime.Today.AddHours(8).AddMinutes(45);
            using (var context = TestDbHelper.CreateDbContext())
            {
                var deadline = (await context.SystemSettings.FirstOrDefaultAsync())?.DailyDeadline ?? new TimeSpan(8, 30, 0);
                var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;

                var att = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, CheckedInAt = checkInTime, Status = status };
                context.Attendances.Add(att);
                await context.SaveChangesAsync();
            }

            using (var context = TestDbHelper.CreateDbContext())
            {
                var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
                Assert.Equals(AttendanceStatus.Present, record!.Status, "Should be Present because of updated deadline.");
            }
        }

