        public async Task Test_HeadmasterView_TeacherWithMultipleRoles()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("HM School A");
            var hm = await CreateUserAsync("hm6@school.com", "Headmaster Six", "Headmaster", school.Id);
            
            // Create user with both Teacher and another role
            var teacher = await CreateUserAsync("t_multi@school.com", "Teacher Multi", "Teacher", school.Id);
            
            using var scope = _serviceProvider.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            var roleManager = scope.ServiceProvider.GetRequiredService<RoleManager<IdentityRole>>();
            if (!await roleManager.RoleExistsAsync("Officer"))
            {
                await roleManager.CreateAsync(new IdentityRole("Officer"));
            }
            await userManager.AddToRoleAsync(teacher, "Officer");

            _authStateProvider.SetUser(hm.UserName!, "Headmaster", hm.Id, school.Id);

            var component = new MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance();
            InjectServices(component);

            var method = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("OnInitializedAsync", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            await (Task)method!.Invoke(component, null)!;

            var field = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetField("teachersAttendance", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            var list = (System.Collections.IList)field!.GetValue(component)!;

            Assert.Equals(1, list.Count, "Teacher with multiple roles should still be listed.");
        }

