        #region FEATURE 2: LATENESS EVALUATION

        // 1. Feature Coverage
        public async Task Test_LatenessEvaluation_BeforeDeadline_IsPresent()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(8, 30, 0); // 08:30
            var checkInTime = DateTime.Today.AddHours(8).AddMinutes(15); // 08:15

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Present, status, "Should be Present before deadline.");
        }

        public async Task Test_LatenessEvaluation_AfterDeadline_IsLate()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(8, 30, 0); // 08:30
            var checkInTime = DateTime.Today.AddHours(8).AddMinutes(45); // 08:45

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Late, status, "Should be Late after deadline.");
        }

        public async Task Test_LatenessEvaluation_WithCustomDeadline_Before_IsPresent()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(9, 0, 0); // 09:00
            var checkInTime = DateTime.Today.AddHours(8).AddMinutes(50); // 08:50

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Present, status, "Should be Present before custom deadline.");
        }

        public async Task Test_LatenessEvaluation_WithCustomDeadline_After_IsLate()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(9, 0, 0); // 09:00
            var checkInTime = DateTime.Today.AddHours(9).AddMinutes(10); // 09:10

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Late, status, "Should be Late after custom deadline.");
        }

        public async Task Test_LatenessEvaluation_NoSystemSetting_UsesDefault0830()
        {
            await ResetStateAsync();
            // No settings in DB, use default 08:30
            var defaultDeadline = new TimeSpan(8, 30, 0);
            var checkInTime = DateTime.Today.AddHours(8).AddMinutes(20);

            var status = checkInTime.TimeOfDay <= defaultDeadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Present, status, "Should use default 08:30 deadline if no DB setting exists.");
        }

        // 2. Boundary & Corner Cases
        public async Task Test_LatenessEvaluation_ExactlyAtDeadline_IsPresent()
        {
