using System;
using System.Collections.Generic;
using System.Linq;
using System.Security.Claims;
using System.Threading.Tasks;
using Microsoft.AspNetCore.Components;
using Microsoft.AspNetCore.Components.Authorization;
using Microsoft.AspNetCore.Identity;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.DependencyInjection;
using MainSchoolsManagementSystem.Data;
using MainSchoolsManagementSystem.Components.Pages.Headmaster;

namespace MainSchoolsManagementSystem.Tests
{
    public class AttendanceTests
    {
        private readonly IServiceProvider _serviceProvider;
        private readonly TestAuthenticationStateProvider _authStateProvider;

        public AttendanceTests()
        {
            var services = new ServiceCollection();
            services.AddLogging();
            services.AddDbContext<ApplicationDbContext>(options =>
                options.UseSqlServer(TestDbHelper.ConnectionString));

            services.AddIdentity<ApplicationUser, IdentityRole>()
                .AddEntityFrameworkStores<ApplicationDbContext>()
                .AddDefaultTokenProviders();

            var testAuth = new TestAuthenticationStateProvider();
            services.AddSingleton<AuthenticationStateProvider>(testAuth);
            services.AddSingleton(testAuth);

            _serviceProvider = services.BuildServiceProvider();
            _authStateProvider = testAuth;
        }

        private async Task ResetStateAsync()
        {
            using var context = TestDbHelper.CreateDbContext();
            TestDbHelper.ClearTables(context);
            await context.SaveChangesAsync();
            _authStateProvider.ClearUser();
        }

        // Helper to inject services into Blazor components via reflection
        private void InjectServices(object component)
        {
            var type = component.GetType();
            var properties = type.GetProperties(System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.NonPublic);
            foreach (var prop in properties)
            {
                if (prop.GetCustomAttributes(typeof(InjectAttribute), true).Any())
                {
                    var service = _serviceProvider.GetService(prop.PropertyType);
                    if (service != null)
                    {
                        prop.SetValue(component, service);
                    }
                }
            }
        }

        private async Task<ApplicationUser> CreateUserAsync(string email, string fullName, string role, int? schoolId = null)
        {
            using var scope = _serviceProvider.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            var roleManager = scope.ServiceProvider.GetRequiredService<RoleManager<IdentityRole>>();

            if (!await roleManager.RoleExistsAsync(role))
            {
                await roleManager.CreateAsync(new IdentityRole(role));
            }

            var user = new ApplicationUser
            {
                UserName = email,
                Email = email,
                FullName = fullName,
                SchoolId = schoolId
            };

            var result = await userManager.CreateAsync(user, "Password123!");
            if (!result.Succeeded)
            {
                throw new Exception($"User creation failed: {string.Join(", ", result.Errors.Select(e => e.Description))}");
            }

            await userManager.AddToRoleAsync(user, role);
            return user;
        }

        private async Task<School> CreateSchoolAsync(string name)
        {
            using var context = TestDbHelper.CreateDbContext();
            var school = new School { Name = name };
            context.Schools.Add(school);
            await context.SaveChangesAsync();
            return school;
        }

        private async Task SetDailyDeadlineAsync(TimeSpan deadline, bool maintenance = false)
        {
            using var context = TestDbHelper.CreateDbContext();
            var setting = await context.SystemSettings.FirstOrDefaultAsync();
            if (setting == null)
            {
                setting = new SystemSetting { DailyDeadline = deadline, MaintenanceMode = maintenance };
                context.SystemSettings.Add(setting);
            }
            else
            {
                setting.DailyDeadline = deadline;
                setting.MaintenanceMode = maintenance;
                context.SystemSettings.Update(setting);
            }
            await context.SaveChangesAsync();
        }

        // Reflection helper to invoke teacher check-in
        private async Task InvokeTeacherCheckInAsync(object component, DateTime time)
        {
            var type = component.GetType();
            var method = type.GetMethod("CheckIn", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.NonPublic)
                         ?? type.GetMethod("CheckInAsync", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.NonPublic);

            if (method == null)
            {
                Assert.Fail("Teacher/Attendance.razor does not implement a CheckIn or CheckInAsync method.");
            }

            var parameters = method.GetParameters();
            if (parameters.Length == 1 && parameters[0].ParameterType == typeof(DateTime))
            {
                var result = method.Invoke(component, new object[] { time });
                if (result is Task task) await task;
            }
            else if (parameters.Length == 0)
            {
                var result = method.Invoke(component, null);
                if (result is Task task) await task;
            }
            else
            {
                Assert.Fail("Teacher/Attendance.razor CheckIn method has unsupported signature.");
            }
        }

        #region FEATURE 1: TEACHER CHECK-IN

        // 1. Feature Coverage
        public async Task Test_TeacherCheckIn_CreatesRecordInDatabase()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Test School");
            var teacher = await CreateUserAsync("teacher1@school.com", "Teacher One", "Teacher", school.Id);

            // Simulate teacher check-in
            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance
            {
                TeacherId = teacher.Id,
                Date = DateTime.Today,
                CheckedInAt = DateTime.UtcNow,
                Status = AttendanceStatus.Present
            };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.NotNull(record, "Attendance record should be created in the database.");
            Assert.Equals(AttendanceStatus.Present, record!.Status, "Status should be Present.");
        }

