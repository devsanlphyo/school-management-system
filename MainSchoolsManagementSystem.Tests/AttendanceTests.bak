        #region FEATURE 4: HEADMASTER ATTENDANCE VIEW

        // 1. Feature Coverage
        public async Task Test_HeadmasterView_DisplaysAllTeachersInSchool()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("HM School A");
            var otherSchool = await CreateSchoolAsync("HM School B");

            var hm = await CreateUserAsync("hm1@school.com", "Headmaster One", "Headmaster", school.Id);
            var teacher1 = await CreateUserAsync("t1@school.com", "Teacher One", "Teacher", school.Id);
            var teacher2 = await CreateUserAsync("t2@school.com", "Teacher Two", "Teacher", school.Id);
            var otherTeacher = await CreateUserAsync("t3@school.com", "Teacher Three", "Teacher", otherSchool.Id);

            _authStateProvider.SetUser(hm.UserName!, "Headmaster", hm.Id, school.Id);

            // Test the Headmaster Attendance Component
            var component = new MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance();
            InjectServices(component);

            // Call OnInitializedAsync via reflection
            var method = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("OnInitializedAsync", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            
            Assert.NotNull(method, "OnInitializedAsync should exist.");
            await (Task)method!.Invoke(component, null)!;

            // Get teachersAttendance field via reflection
            var field = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetField("teachersAttendance", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            
            Assert.NotNull(field, "teachersAttendance field should exist.");
            var list = (System.Collections.IList)field!.GetValue(component)!;

