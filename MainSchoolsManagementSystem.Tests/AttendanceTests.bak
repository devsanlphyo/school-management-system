        public async Task Test_TeacherCheckIn_RecordsCheckedInAtTimestamp()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Test School");
            var teacher = await CreateUserAsync("teacher4@school.com", "Teacher Four", "Teacher", school.Id);
            var now = DateTime.UtcNow;

            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance
            {
                TeacherId = teacher.Id,
                Date = DateTime.Today,
                CheckedInAt = now,
                Status = AttendanceStatus.Present
            };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync();
            Assert.NotNull(record!.CheckedInAt, "CheckedInAt should not be null.");
            Assert.True((record.CheckedInAt.Value - now).Duration() < TimeSpan.FromSeconds(1), "CheckedInAt should match the check-in time.");
        }

        public async Task Test_TeacherCheckIn_TwiceOnSameDay_UpdatesOrPrevents()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Test School");
            var teacher = await CreateUserAsync("teacher5@school.com", "Teacher Five", "Teacher", school.Id);

            using var context = TestDbHelper.CreateDbContext();
            var first = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, CheckedInAt = DateTime.UtcNow.AddHours(-1), Status = AttendanceStatus.Present };
            context.Attendances.Add(first);
            await context.SaveChangesAsync();

            // Simulate second check-in (should either update or do nothing, but not duplicate)
            var duplicate = await context.Attendances.AnyAsync(a => a.TeacherId == teacher.Id && a.Date == DateTime.Today);
            Assert.True(duplicate, "Should already have a record for today.");
        }

