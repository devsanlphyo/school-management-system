        public async Task Test_LatenessEvaluation_OneSecondAfterDeadline_IsLate()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(8, 30, 0);
            var checkInTime = DateTime.Today.AddHours(8).AddMinutes(30).AddSeconds(1);

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Late, status, "One second after deadline should be Late.");
        }

        public async Task Test_LatenessEvaluation_WithDeadlineAtMidnight_IsLate()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(0, 0, 0); // Midnight
            var checkInTime = DateTime.Today.AddMinutes(1); // 00:01

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Late, status, "Any check-in after midnight is Late if deadline is midnight.");
        }

        public async Task Test_LatenessEvaluation_WithDeadlineAtEndOfDay_IsPresent()
        {
            await ResetStateAsync();
            var deadline = new TimeSpan(23, 59, 59);
            var checkInTime = DateTime.Today.AddHours(23).AddMinutes(59);

            var status = checkInTime.TimeOfDay <= deadline ? AttendanceStatus.Present : AttendanceStatus.Late;
            Assert.Equals(AttendanceStatus.Present, status, "Check-in before 23:59:59 is Present.");
        }

        public async Task Test_LatenessEvaluation_NegativeTimeSpanDeadline_ThrowsOrHandles()
        {
            await ResetStateAsync();
            // Setting a negative deadline is invalid or should be handled
            var invalidDeadline = new TimeSpan(-1, 0, 0);
            Assert.True(invalidDeadline.Ticks < 0, "Timespan is negative.");
        }

        public async Task Test_LatenessEvaluation_MultipleSystemSettings_UsesActiveOrFirst()
        {
            await ResetStateAsync();
            using var context = TestDbHelper.CreateDbContext();
            context.SystemSettings.Add(new SystemSetting { DailyDeadline = new TimeSpan(8, 0, 0) });
            context.SystemSettings.Add(new SystemSetting { DailyDeadline = new TimeSpan(9, 0, 0) });
            await context.SaveChangesAsync();

            // The system should use the first or active setting
            var activeSetting = await context.SystemSettings.FirstOrDefaultAsync();
            Assert.NotNull(activeSetting, "Should retrieve a setting.");
            Assert.Equals(new TimeSpan(8, 0, 0), activeSetting!.DailyDeadline, "Should use the first setting.");
        }

