        public async Task Test_TeacherCheckIn_OnLeapDay()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Test School");
            var teacher = await CreateUserAsync("teacher8@school.com", "Teacher Eight", "Teacher", school.Id);
            var leapDay = new DateTime(2028, 2, 29); // 2028 is a leap year

            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance { TeacherId = teacher.Id, Date = leapDay, CheckedInAt = leapDay.AddHours(8), Status = AttendanceStatus.Present };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync();
            Assert.Equals(leapDay, record!.Date, "Should support check-in on February 29th.");
        }

        public async Task Test_TeacherCheckIn_WithNoSchoolAssigned_FailsOrHandles()
        {
            await ResetStateAsync();
            // Create a teacher with no school
            var teacher = await CreateUserAsync("teacher9@school.com", "Teacher Nine", "Teacher", null);

            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, CheckedInAt = DateTime.UtcNow, Status = AttendanceStatus.Present };
            context.Attendances.Add(attendance);
            
            // Should succeed at DB level if SchoolId is not required on Attendance (it is linked via Teacher)
            await context.SaveChangesAsync();
            var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.NotNull(record, "Attendance should be saved even if teacher has no school assigned.");
        }

