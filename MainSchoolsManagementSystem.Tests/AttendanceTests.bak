        public async Task Test_TeacherCheckIn_WhenAlreadyOverriddenByHeadmaster()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Test School");
            var teacher = await CreateUserAsync("teacher11@school.com", "Teacher Eleven", "Teacher", school.Id);

            // Headmaster overrides to Present
            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, Status = AttendanceStatus.Present, CheckedInAt = null };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            // Teacher checks in later. It should update CheckedInAt but keep Present status
            var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            record!.CheckedInAt = DateTime.UtcNow;
            context.Attendances.Update(record);
            await context.SaveChangesAsync();

            var updated = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.NotNull(updated!.CheckedInAt, "CheckedInAt should be updated.");
            Assert.Equals(AttendanceStatus.Present, updated.Status, "Status should remain Present as overridden.");
        }

        public async Task Test_TeacherCheckIn_WithDifferentTimeZones()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Test School");
            var teacher = await CreateUserAsync("teacher12@school.com", "Teacher Twelve", "Teacher", school.Id);
            var localCheckIn = DateTime.SpecifyKind(DateTime.Today.AddHours(8), DateTimeKind.Local);

            using var context = TestDbHelper.CreateDbContext();
            var attendance = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, CheckedInAt = localCheckIn.ToUniversalTime(), Status = AttendanceStatus.Present };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync();
            Assert.NotNull(record!.CheckedInAt, "Timestamp should be recorded.");
            Assert.Equals(localCheckIn.ToUniversalTime(), record.CheckedInAt.Value, "Timestamp should be converted to UTC in database.");
        }

