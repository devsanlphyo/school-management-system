                Status = AttendanceStatus.Present
            };
            context.Attendances.Add(attendance);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync();
            Assert.Equals(teacher.Id, record!.TeacherId, "TeacherId must match.");
        }

