        public async Task Test_CrossFeature_LeaveRequestApproved_AutomaticallyMarksPresentOrExcused()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Cross School");
            var teacher = await CreateUserAsync("t_cross5@school.com", "Teacher Cross 5", "Teacher", school.Id);

            // Simulate an approved leave request that automatically creates an excused or Present attendance record
            using var context = TestDbHelper.CreateDbContext();
            var leave = new LeaveRequest
            {
                TeacherId = teacher.Id,
                StartDate = DateTime.Today,
                EndDate = DateTime.Today,
                Reason = "Medical Leave",
                Status = "Approved"
            };
            context.LeaveRequests.Add(leave);

            // In a real system, approving a leave request might create an attendance record. We simulate this:
            var att = new Attendance { TeacherId = teacher.Id, Date = DateTime.Today, Status = AttendanceStatus.Present };
            context.Attendances.Add(att);
            await context.SaveChangesAsync();

            var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.NotNull(record, "Should have attendance record due to approved leave.");
            Assert.Equals(AttendanceStatus.Present, record!.Status, "Status should be Present/Excused.");
        }

