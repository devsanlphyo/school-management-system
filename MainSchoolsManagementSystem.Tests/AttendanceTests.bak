        #region TIER 4: REAL-WORLD APPLICATION SCENARIOS

        public async Task Test_Scenario_TypicalSchoolDay()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Main High School");
            var hm = await CreateUserAsync("hm_main@school.com", "Headmaster Main", "Headmaster", school.Id);
            
            var t1 = await CreateUserAsync("t1_main@school.com", "Teacher One", "Teacher", school.Id);
            var t2 = await CreateUserAsync("t2_main@school.com", "Teacher Two", "Teacher", school.Id);
            var t3 = await CreateUserAsync("t3_main@school.com", "Teacher Three", "Teacher", school.Id);

            // 1. Teacher 1 checks in early (08:10) -> Present
            using (var context = TestDbHelper.CreateDbContext())
            {
                context.Attendances.Add(new Attendance { TeacherId = t1.Id, Date = DateTime.Today, CheckedInAt = DateTime.Today.AddHours(8).AddMinutes(10), Status = AttendanceStatus.Present });
                await context.SaveChangesAsync();
            }

            // 2. Teacher 2 checks in late (08:40) -> Late
            using (var context = TestDbHelper.CreateDbContext())
            {
                context.Attendances.Add(new Attendance { TeacherId = t2.Id, Date = DateTime.Today, CheckedInAt = DateTime.Today.AddHours(8).AddMinutes(40), Status = AttendanceStatus.Late });
                await context.SaveChangesAsync();
            }

            // 3. Teacher 3 does not check in -> Absent

            // 4. HM reviews stats
            _authStateProvider.SetUser(hm.UserName!, "Headmaster", hm.Id, school.Id);
            var hmComponent = new MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance();
            InjectServices(hmComponent);

            var initMethod = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("OnInitializedAsync", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            await (Task)initMethod!.Invoke(hmComponent, null)!;

            var presentField = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetField("presentCount", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            var lateField = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetField("lateCount", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            var absentField = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetField("absentCount", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);

            Assert.Equals(1, (int)presentField!.GetValue(hmComponent)!, "1 Present");
            Assert.Equals(1, (int)lateField!.GetValue(hmComponent)!, "1 Late");
            Assert.Equals(1, (int)absentField!.GetValue(hmComponent)!, "1 Absent");

            // 5. HM overrides Teacher 3 to Present because they were on official duty
            var overrideMethod = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("SetAttendance", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            await (Task)overrideMethod!.Invoke(hmComponent, new object[] { t3.Id, AttendanceStatus.Present })!;

            Assert.Equals(2, (int)presentField!.GetValue(hmComponent)!, "Should now be 2 Present");
            Assert.Equals(0, (int)absentField!.GetValue(hmComponent)!, "Should now be 0 Absent");
        }

