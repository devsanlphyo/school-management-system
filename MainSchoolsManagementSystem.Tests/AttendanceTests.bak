        public async Task Test_Scenario_MonthTransition_HistoryTableAccuracy()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("Main High School");
            var teacher = await CreateUserAsync("t_trans@school.com", "Teacher Trans", "Teacher", school.Id);

            var lastDayOfPrevMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddDays(-1);
            var firstDayOfCurrentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

            using var context = TestDbHelper.CreateDbContext();
            context.Attendances.Add(new Attendance { TeacherId = teacher.Id, Date = lastDayOfPrevMonth, Status = AttendanceStatus.Present });
            context.Attendances.Add(new Attendance { TeacherId = teacher.Id, Date = firstDayOfCurrentMonth, Status = AttendanceStatus.Present });
            await context.SaveChangesAsync();

            // Verify both records exist in DB
            var count = await context.Attendances.CountAsync(a => a.TeacherId == teacher.Id);
            Assert.Equals(2, count, "Both transition records should be in the database.");
        }

