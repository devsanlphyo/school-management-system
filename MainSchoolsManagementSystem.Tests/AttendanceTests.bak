        #region FEATURE 5: HEADMASTER ATTENDANCE OVERRIDE

        // 1. Feature Coverage
        public async Task Test_HeadmasterOverride_ToPresent_UpdatesStatus()
        {
            await ResetStateAsync();
            var school = await CreateSchoolAsync("HM School A");
            var hm = await CreateUserAsync("hm_or1@school.com", "Headmaster One", "Headmaster", school.Id);
            var teacher = await CreateUserAsync("t_or1@school.com", "Teacher One", "Teacher", school.Id);

            _authStateProvider.SetUser(hm.UserName!, "Headmaster", hm.Id, school.Id);

            var component = new MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance();
            InjectServices(component);

            // Call OnInitializedAsync to load data
            var initMethod = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("OnInitializedAsync", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            await (Task)initMethod!.Invoke(component, null)!;

            // Trigger override to Present
            var overrideMethod = typeof(MainSchoolsManagementSystem.Components.Pages.Headmaster.Attendance)
                .GetMethod("SetAttendance", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            
            Assert.NotNull(overrideMethod, "SetAttendance method should exist.");
            await (Task)overrideMethod!.Invoke(component, new object[] { teacher.Id, AttendanceStatus.Present })!;

            // Verify in database
            using var context = TestDbHelper.CreateDbContext();
            var record = await context.Attendances.FirstOrDefaultAsync(a => a.TeacherId == teacher.Id);
            Assert.NotNull(record, "Override should create an attendance record.");
            Assert.Equals(AttendanceStatus.Present, record!.Status, "Override status should be Present.");
        }

