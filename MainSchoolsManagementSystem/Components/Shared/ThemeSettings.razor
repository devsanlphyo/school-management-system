@inject IJSRuntime JS

<div>
    <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1.25rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
        Appearance
    </h3>

    <!-- Theme Mode Toggle -->
    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <div style="font-weight: 700; font-size: 0.9rem; color: var(--text-primary);">Theme Mode</div>
        <p style="color: var(--text-muted); font-size: 0.78rem; margin-top: 0;">Choose how HelloTwo looks for you. Select a single theme, or sync with your system settings.</p>

        <div style="display: flex; gap: 0.75rem; margin-top: 0.5rem; flex-wrap: wrap;">
            @foreach (var option in themeOptions)
            {
                <button @onclick="() => SetTheme(option.Value)"
                        style="@GetOptionStyle(option.Value)"
                        title="@option.Label">
                    <span style="display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 10px; background: @option.IconBg; margin-bottom: 0.35rem;">
                        @((MarkupString)option.Icon)
                    </span>
                    <span style="font-size: 0.78rem; font-weight: 700;">@option.Label</span>
                </button>
            }
        </div>
    </div>
</div>

@code {
    private string currentTheme = "system";

    private record ThemeOption(string Value, string Label, string Icon, string IconBg);

    private readonly ThemeOption[] themeOptions = new[]
    {
        new ThemeOption("light", "Light",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='5'></circle><line x1='12' y1='1' x2='12' y2='3'></line><line x1='12' y1='21' x2='12' y2='23'></line><line x1='4.22' y1='4.22' x2='5.64' y2='5.64'></line><line x1='18.36' y1='18.36' x2='19.78' y2='19.78'></line><line x1='1' y1='12' x2='3' y2='12'></line><line x1='21' y1='12' x2='23' y2='12'></line><line x1='4.22' y1='19.78' x2='5.64' y2='18.36'></line><line x1='18.36' y1='5.64' x2='19.78' y2='4.22'></line></svg>",
            "rgba(251, 191, 36, 0.12)"),
        new ThemeOption("dark", "Dark",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z'></path></svg>",
            "rgba(129, 140, 248, 0.12)"),
        new ThemeOption("system", "System",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='3' width='20' height='14' rx='2' ry='2'></rect><line x1='8' y1='21' x2='16' y2='21'></line><line x1='12' y1='17' x2='12' y2='21'></line></svg>",
            "rgba(107, 114, 128, 0.12)")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            currentTheme = await JS.InvokeAsync<string>("themeManager.getTheme");
            StateHasChanged();
        }
    }

    private async Task SetTheme(string theme)
    {
        currentTheme = theme;
        await JS.InvokeVoidAsync("themeManager.setTheme", theme);
    }

    private string GetOptionStyle(string value)
    {
        var isActive = currentTheme == value;
        var basePadding = "padding: 1rem 1.25rem;";
        var baseLayout = "display: flex; flex-direction: column; align-items: center; gap: 0.25rem;";
        var baseMisc = "border-radius: var(--radius-md); cursor: pointer; transition: all 0.15s ease; flex: 1; min-width: 90px;";
        var fontFamily = "font-family: inherit;";

        if (isActive)
        {
            return $"{basePadding} {baseLayout} {baseMisc} {fontFamily} background: var(--primary-glow); border: 2px solid var(--primary); color: var(--primary);";
        }
        else
        {
            return $"{basePadding} {baseLayout} {baseMisc} {fontFamily} background: var(--bg-base); border: 2px solid var(--border-color); color: var(--text-secondary);";
        }
    }
}
