
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System
@using System.Linq
@using MainSchoolsManagementSystem.Data

<PageTitle>Attendance — HelloTwo</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.75rem; margin-bottom: 0.25rem;">My Attendance</h2>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Check in daily and view your attendance records.</p>
    </div>

    <!-- Daily Check-In Card -->
    <div class="glass-panel" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem;">
        <div>
            <h4 style="margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary);">Today's Status</h4>
            @if (todayAttendance == null)
            {
                <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem;">You have not checked in yet today.</p>
            }
            else
            {
                <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem;">
                    Checked in at @(todayAttendance.CheckedInAt?.ToLocalTime().ToString("hh:mm tt") ?? "—")
                </p>
            }
        </div>

        <div>
            @if (todayAttendance == null)
            {
                @if (isMaintenanceMode)
                {
                    <button class="btn-premium btn-secondary-custom" disabled style="opacity: 0.6; cursor: not-allowed;">
                        System Under Maintenance
                    </button>
                }
                else
                {
                    <button class="btn-premium" @onclick="() => CheckIn(DateTime.UtcNow)">
                        Check In
                    </button>
                }
            }
            else
            {
                switch (todayAttendance.Status)
                {
                    case AttendanceStatus.Present:
                        <span class="badge badge-present" style="font-size: 0.9rem; padding: 0.5rem 1rem;">Present</span>
                        break;
                    case AttendanceStatus.Late:
                        <span class="badge badge-late" style="font-size: 0.9rem; padding: 0.5rem 1rem;">Late</span>
                        break;
                    case AttendanceStatus.Absent:
                        <span class="badge badge-absent" style="font-size: 0.9rem; padding: 0.5rem 1rem;">Absent</span>
                        break;
                }
            }
        </div>
    </div>

    <!-- Monthly Stats Grid -->
    <div class="dashboard-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.25rem;">
        <div class="stat-card success" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.25rem;">
            <span class="stat-label" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">Present Days</span>
            <span class="stat-value" style="font-size: 2rem;">@presentCount</span>
        </div>
        <div class="stat-card warning" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.25rem;">
            <span class="stat-label" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">Late Days</span>
            <span class="stat-value" style="font-size: 2rem;">@lateCount</span>
        </div>
        <div class="stat-card danger" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.25rem;">
            <span class="stat-label" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">Absent Days</span>
            <span class="stat-value" style="font-size: 2rem;">@absentCount</span>
        </div>
    </div>

    <!-- Attendance History Table -->
    <div class="glass-panel" style="padding: 0;">
        <div style="padding: 1.25rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600;">Attendance History — @DateTime.Today.ToString("MMMM yyyy")</h3>
        </div>
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Day</th>
                        <th>Check-in Time</th>
                        <th style="text-align: right;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (attendanceHistory.Any())
                    {
                        foreach (var record in attendanceHistory)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-primary);">@record.Date.ToString("dd MMM yyyy")</div>
                                </td>
                                <td>
                                    <div style="color: var(--text-secondary);">@record.Date.ToString("dddd")</div>
                                </td>
                                <td>
                                    @(record.CheckedInAt?.ToLocalTime().ToString("hh:mm tt") ?? "—")
                                </td>
                                <td style="text-align: right;">
                                    @switch (record.Status)
                                    {
                                        case AttendanceStatus.Present:
                                            <span class="badge badge-present">Present</span>
                                            break;
                                        case AttendanceStatus.Late:
                                            <span class="badge badge-late">Late</span>
                                            break;
                                        case AttendanceStatus.Absent:
                                            <span class="badge badge-absent">Absent</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No attendance records found for this month.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private string? teacherId;
    private ApplicationUser? currentTeacher;
    private MainSchoolsManagementSystem.Data.Attendance? todayAttendance;
    private List<MainSchoolsManagementSystem.Data.Attendance> attendanceHistory = new();

    private int presentCount = 0;
    private int lateCount = 0;
    private int absentCount = 0;

    private bool isMaintenanceMode = false;
    private TimeSpan dailyDeadline = new TimeSpan(8, 30, 0);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var appUser = await UserManager.GetUserAsync(user);
            if (appUser != null)
            {
                teacherId = appUser.Id;
                currentTeacher = appUser;
                await LoadDataAsync();
            }
        }
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(teacherId)) return;

        // Fetch settings
        var setting = await DbContext.SystemSettings.AsNoTracking().FirstOrDefaultAsync();
        if (setting != null)
        {
            dailyDeadline = setting.DailyDeadline;
            isMaintenanceMode = setting.MaintenanceMode;
        }

        var today = DateTime.Today;

        // Load today's attendance record
        todayAttendance = await DbContext.Attendances
            .AsNoTracking()
            .FirstOrDefaultAsync(a => a.UserId == teacherId && a.Date == today);

        // Load all attendance records for this month
        var firstDayOfMonth = new DateTime(today.Year, today.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);

        var monthRecords = await DbContext.Attendances
            .AsNoTracking()
            .Where(a => a.UserId == teacherId && a.Date >= firstDayOfMonth && a.Date <= lastDayOfMonth)
            .ToListAsync();

        // Build history: weekdays from 1st of month up to today
        var historyList = new List<MainSchoolsManagementSystem.Data.Attendance>();
        presentCount = 0;
        lateCount = 0;
        absentCount = 0;

        for (var date = today; date >= firstDayOfMonth; date = date.AddDays(-1))
        {
            // Skip weekends
            if (date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday)
            {
                continue;
            }

            var record = monthRecords.FirstOrDefault(r => r.Date == date);
            if (record != null)
            {
                historyList.Add(record);
                if (record.Status == AttendanceStatus.Present) presentCount++;
                else if (record.Status == AttendanceStatus.Late) lateCount++;
                else if (record.Status == AttendanceStatus.Absent) absentCount++;
            }
            else
            {
                // No record on a past weekday is counted as Absent
                var dummyRecord = new MainSchoolsManagementSystem.Data.Attendance
                {
                    UserId = teacherId,
                    Date = date,
                    CheckedInAt = null,
                    Status = AttendanceStatus.Absent
                };
                
                historyList.Add(dummyRecord);
                absentCount++;
            }
        }

        // Sort history by date descending
        attendanceHistory = historyList.OrderByDescending(h => h.Date).ToList();
    }

    private async Task CheckIn()
    {
        await CheckIn(DateTime.UtcNow);
    }

    private async Task CheckIn(DateTime checkInTimeUtc)
    {
        if (isMaintenanceMode || string.IsNullOrEmpty(teacherId)) return;

        var localTime = checkInTimeUtc.ToLocalTime();
        var date = localTime.Date;

        // Fetch settings again to ensure up-to-date deadline
        var setting = await DbContext.SystemSettings.FirstOrDefaultAsync();
        if (setting != null)
        {
            dailyDeadline = setting.DailyDeadline;
            isMaintenanceMode = setting.MaintenanceMode;
        }

        if (isMaintenanceMode) return;

        // Check if today's record already exists
        var existing = await DbContext.Attendances
            .FirstOrDefaultAsync(a => a.UserId == teacherId && a.Date == date);

        if (existing == null)
        {
            var status = AttendanceLogic.CalculateStatus(checkInTimeUtc, dailyDeadline);
            var attendance = new MainSchoolsManagementSystem.Data.Attendance
            {
                UserId = teacherId,
                Date = date,
                CheckedInAt = checkInTimeUtc,
                Status = status
            };
            DbContext.Attendances.Add(attendance);
        }
        else
        {
            // If already overridden by Headmaster, only update CheckedInAt timestamp and do not touch the Status
            existing.CheckedInAt = checkInTimeUtc;
            DbContext.Attendances.Update(existing);
        }

        await DbContext.SaveChangesAsync();
        await LoadDataAsync();
        try
        {
            StateHasChanged();
        }
        catch (InvalidOperationException)
        {
            // Suppress exception during unit testing
        }
    }
}
