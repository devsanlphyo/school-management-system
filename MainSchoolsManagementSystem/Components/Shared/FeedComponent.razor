@using MainSchoolsManagementSystem.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject NavigationManager NavigationManager

<div class="feed-container">
  <!-- Create Post Prompt -->
  <div class="glass-panel" style="margin-bottom: 1.5rem;">
    <div class="create-prompt-row">
      <div class="avatar">@AvatarInitials</div>
      <div class="fake-input" @onclick="NavigateToCreate">What's on your mind?</div>
    </div>
    <div class="create-actions">
      <button class="action-btn" @onclick="NavigateToCreate">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
        Photo/Video
      </button>
      <button class="action-btn" @onclick="NavigateToCreate">
        <svg viewBox="0 0 24 24"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
        Attach File
      </button>
    </div>
  </div>

  <!-- Feed Posts -->
  @if (posts == null)
  {
      <p>Loading feed...</p>
  }
  else if (!posts.Any())
  {
      <div class="glass-panel text-center" style="padding: 4rem 2rem;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); margin-bottom: 1rem; opacity: 0.5;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          <p class="text-muted">No posts yet. Be the first to share something!</p>
      </div>
  }
  else
  {
      @foreach (var post in posts)
      {
          <div class="glass-panel post-card" style="margin-bottom: 1.5rem;">
            <div class="post-header">
              <div class="post-author-row">
                <div class="avatar">@GetInitials(post.Author?.FullName ?? post.Author?.Email ?? "U")</div>
                <div class="post-author-info">
                  <h4 style="margin-bottom:0;">@(post.Author?.FullName ?? post.Author?.Email ?? "User")
                      @if (userRoles.TryGetValue(post.AuthorId, out var role))
                      {
                          <span class="role-badge">@role</span>
                      }
                  </h4>
                  <div class="post-time">@GetRelativeTime(post.CreatedAt)</div>
                </div>
              </div>
              @if (post.AuthorId == currentUserId)
              {
                  <button class="btn btn-sm btn-outline-danger" style="display: flex; align-items: center; gap: 4px;" title="Delete Post" @onclick="() => DeletePost(post)">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                      Delete
                  </button>
              }
            </div>
            <div class="post-content">@post.Content</div>
            
            @if (post.MediaItems != null && post.MediaItems.Any())
            {
                var sortedMedia = post.MediaItems.OrderBy(m => m.SortOrder).ToList();
                int mediaCount = sortedMedia.Count;
                string gridClass = mediaCount >= 4 ? "count-4" : $"count-{mediaCount}";
                
                <div class="media-grid @gridClass">
                    @for (int i = 0; i < Math.Min(4, mediaCount); i++)
                    {
                        var media = sortedMedia[i];
                        bool isLastAndMore = i == 3 && mediaCount > 4;
                        string mediaUrl = $"/api/feed/media/{media.StoredFileName}/download";
                        
                        <div class="media-item" style="background-image: url('@mediaUrl');">
                            @if (isLastAndMore)
                            {
                                <div class="more-overlay">+@(mediaCount - 4)</div>
                            }
                            else
                            {
                                <div class="media-overlay">
                                    <a href="@mediaUrl" download="@media.FileName" class="download-btn" title="Download">
                                        <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <div class="interaction-stats">
              <span>❤️ @post.Reactions.Count</span>
              <span>@post.Comments.Count Comments</span>
            </div>
            
            <div class="interaction-bar">
              @{ bool hasLoved = post.Reactions.Any(r => r.UserId == currentUserId); }
              <button class="interact-btn @(hasLoved ? "loved" : "")" @onclick="() => ToggleLove(post)">
                <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                Love
              </button>
              <button class="interact-btn" @onclick="() => ToggleComments(post.Id)">
                <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                Comment
              </button>
            </div>
            
            <div class="comments-section @(openCommentSections.Contains(post.Id) ? "show" : "")">
                @foreach(var comment in post.Comments.OrderBy(c => c.CreatedAt))
                {
                    <div class="comment-item">
                        <div class="avatar" style="width: 32px; height: 32px; font-size: 0.8rem;">@GetInitials(comment.Author?.FullName ?? comment.Author?.Email ?? "U")</div>
                        <div class="comment-bubble">
                            <div style="display: flex; justify-content: space-between;">
                                <h5 style="margin-top:0; margin-bottom: 0.25rem;">@(comment.Author?.FullName ?? comment.Author?.Email ?? "User")</h5>
                                @if (comment.AuthorId == currentUserId)
                                {
                                    <button class="btn btn-sm text-danger" style="background: none; border: none; padding: 0; display: flex; align-items: center;" title="Delete Comment" @onclick="() => DeleteComment(comment)">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                    </button>
                                }
                            </div>
                            @comment.Content
                        </div>
                    </div>
                }
                
                <div class="comment-input-row">
                    <div class="avatar" style="width: 32px; height: 32px; font-size: 0.8rem;">@AvatarInitials</div>
                    <input type="text" class="comment-input" placeholder="Write a comment..." 
                           @bind="newCommentText[post.Id]" @onkeyup="@(e => HandleCommentKeyUp(e, post))" />
                </div>
            </div>
          </div>
      }
  }
</div>

@code {
    [Parameter] public string CurrentRole { get; set; } = "";
    
    private string AvatarInitials = "U";
    private List<FeedPost>? posts;
    private string? currentUserId;
    private HashSet<int> openCommentSections = new HashSet<int>();
    private Dictionary<int, string> newCommentText = new Dictionary<int, string>();
    private Dictionary<string, string> userRoles = new Dictionary<string, string>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var name = user.Identity.Name ?? "U";
            AvatarInitials = GetInitials(name);
            await LoadPostsAsync();
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        return name.Substring(0, 1).ToUpper();
    }

    private string GetRelativeTime(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} minutes ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hours ago";
        return $"{(int)span.TotalDays} days ago";
    }

    private async Task LoadPostsAsync()
    {
        using var db = await DbContextFactory.CreateDbContextAsync();
        posts = await db.FeedPosts
            .Include(p => p.Author)
            .Include(p => p.MediaItems)
            .Include(p => p.Reactions)
            .Include(p => p.Comments)
            .ThenInclude(c => c.Author)
            .OrderByDescending(p => p.CreatedAt)
            .ToListAsync();
            
        foreach(var p in posts)
        {
            if (!newCommentText.ContainsKey(p.Id)) newCommentText[p.Id] = "";
        }

        var userIds = posts.Select(p => p.AuthorId).Concat(posts.SelectMany(p => p.Comments.Select(c => c.AuthorId))).Distinct().ToList();
        if (userIds.Any())
        {
            var rolesQuery = await db.UserRoles
                .Where(ur => userIds.Contains(ur.UserId))
                .Join(db.Roles, ur => ur.RoleId, r => r.Id, (ur, r) => new { ur.UserId, r.Name })
                .ToListAsync();
                
            userRoles = rolesQuery.GroupBy(x => x.UserId)
                                  .ToDictionary(g => g.Key, g => g.First().Name!);
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/feed/create");
    }

    private void ToggleComments(int postId)
    {
        if (openCommentSections.Contains(postId)) openCommentSections.Remove(postId);
        else openCommentSections.Add(postId);
    }

    private async Task ToggleLove(FeedPost post)
    {
        if (currentUserId == null) return;
        using var db = await DbContextFactory.CreateDbContextAsync();
        
        var existing = await db.FeedPostReactions.FirstOrDefaultAsync(r => r.FeedPostId == post.Id && r.UserId == currentUserId);
        if (existing != null)
        {
            db.FeedPostReactions.Remove(existing);
        }
        else
        {
            db.FeedPostReactions.Add(new FeedPostReaction { FeedPostId = post.Id, UserId = currentUserId });
        }
        await db.SaveChangesAsync();
        await LoadPostsAsync();
    }

    private async Task HandleCommentKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, FeedPost post)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newCommentText[post.Id]))
        {
            if (currentUserId == null) return;
            using var db = await DbContextFactory.CreateDbContextAsync();
            db.FeedPostComments.Add(new FeedPostComment { FeedPostId = post.Id, AuthorId = currentUserId, Content = newCommentText[post.Id] });
            await db.SaveChangesAsync();
            newCommentText[post.Id] = "";
            await LoadPostsAsync();
        }
    }

    private async Task DeletePost(FeedPost post)
    {
        using var db = await DbContextFactory.CreateDbContextAsync();
        var toDelete = await db.FeedPosts.FindAsync(post.Id);
        if (toDelete != null)
        {
            db.FeedPosts.Remove(toDelete);
            await db.SaveChangesAsync();
            await LoadPostsAsync();
        }
    }

    private async Task DeleteComment(FeedPostComment comment)
    {
        using var db = await DbContextFactory.CreateDbContextAsync();
        var toDelete = await db.FeedPostComments.FindAsync(comment.Id);
        if (toDelete != null)
        {
            db.FeedPostComments.Remove(toDelete);
            await db.SaveChangesAsync();
            await LoadPostsAsync();
        }
    }
}
