@using Microsoft.AspNetCore.Components

<header class="admin-header">
    <div style="display: flex; align-items: center; gap: 1rem;">
        <button class="mobile-nav-toggle" @onclick="OnToggleSidebar">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        @if (!string.IsNullOrEmpty(Title))
        {
            <div class="header-school">
                @if (ShowSchoolIcon)
                {
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>
                }
                @Title
            </div>
        }
    </div>
    <div class="header-profile" style="display: flex; align-items: center; gap: 0.5rem;">
        <div class="avatar-circle" style="width: 36px; height: 36px; border-radius: 50%; background: #eef2ff; color: var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; border: 1px solid rgba(79, 70, 229, 0.2);">
            @(string.IsNullOrWhiteSpace(UserDisplayName) ? "U" : UserDisplayName[0].ToString().ToUpper())
        </div>
    </div>
</header>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool ShowSchoolIcon { get; set; } = false;
    [Parameter] public string? UserDisplayName { get; set; }
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
}
