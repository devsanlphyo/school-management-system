@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@inject NavigationManager NavigationManager
@using System.IO

<div class="sidebar-header" style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;" @onclick="NavigateHome">
    @if (!string.IsNullOrEmpty(brandLogoPath))
    {
        <img src="@brandLogoPath" alt="Logo" style="max-height: 40px; max-width: 100%; object-fit: contain; border-radius: 6px; transition: transform 0.2s;" />
    }
    else
    {
        <span class="brand-title">HelloTwo @Role</span>
    }
</div>

@code {
    [Parameter] public string Role { get; set; } = "";
    private string? brandLogoPath;

    protected override void OnInitialized()
    {
        var logoFolder = Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "brand");
        var logoFile = Path.Combine(logoFolder, "logo.png");
        if (File.Exists(logoFile))
        {
            var lastWrite = File.GetLastWriteTimeUtc(logoFile).Ticks;
            brandLogoPath = $"/uploads/brand/logo.png?v={lastWrite}";
        }
    }

    private void NavigateHome()
    {
        NavigationManager.NavigateTo($"/{Role.ToLower()}/feed");
    }
}
