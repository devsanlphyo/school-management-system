@using MainSchoolsManagementSystem.Components.Account.Shared
<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                <AuthorizeView Context="authContext">
                    <Authorized>
                        <div class="login-container">
                            <div class="login-card" style="text-align: center; max-width: 450px;">
                                <h3 style="color: var(--danger); margin-bottom: 1rem;">Access Denied</h3>
                                <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;">
                                    You do not have permission to access this page.
                                </p>
                                <a href="home" class="btn-premium">Go to Home</a>
                            </div>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeView>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
