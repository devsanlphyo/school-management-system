@page "/home"
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Home</PageTitle>

<div class="login-container">
    <div class="login-card" style="text-align: center;">
        <h3 style="margin-bottom: 1rem;">Redirecting...</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Please wait while we route you to your dashboard.</p>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            if (user.IsInRole("Admin"))
            {
                NavigationManager.NavigateTo("admin/schools");
            }
            else if (user.IsInRole("Headmaster") || user.IsInRole("Officer"))
            {
                NavigationManager.NavigateTo("headmaster/dashboard");
            }
            else if (user.IsInRole("Teacher"))
            {
                NavigationManager.NavigateTo("teacher/dashboard");
            }
            else
            {
                // Default fallback
                NavigationManager.NavigateTo("teacher/dashboard");
            }
        }
        else
        {
            NavigationManager.NavigateTo("Account/Login");
        }
    }
}
