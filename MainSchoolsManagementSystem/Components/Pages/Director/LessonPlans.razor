@page "/director/lessonplans"
@layout MainSchoolsManagementSystem.Components.Layout.DirectorLayout
@attribute [Authorize(Roles = "Director")]
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data
@using System.IO

<PageTitle>Lesson Plans Review - Director</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.75rem; margin-bottom: 0.25rem;">Lesson Plans Review</h2>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Review submissions, check compliance, and provide feedback.</p>
    </div>

    <!-- Tabbed Navigation -->
    <div class="tab-navigation">
        <button class="tab-link @(activeTab == "pending" ? "active" : "")" @onclick='() => SetActiveTab("pending")'>
            Pending Review (@pendingPlans.Count)
        </button>
        <button class="tab-link @(activeTab == "reviewed" ? "active" : "")" @onclick='() => SetActiveTab("reviewed")'>
            Reviewed (@reviewedPlans.Count)
        </button>
    </div>

    <!-- Submissions List -->
    <div class="glass-panel" style="padding: 0;">
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Teacher</th>
                        <th>Uploaded At</th>
                        <th>Compliance</th>
                        <th>Status</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (GetActivePlans().Any())
                    {
                        foreach (var plan in GetActivePlans())
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-primary);">@plan.Teacher?.FullName</div>
                                </td>
                                <td>
                                    @plan.UploadedAt.ToLocalTime().ToString("g")
                                </td>
                                <td>
                                    @if (plan.IsLate)
                                    {
                                        <span class="badge badge-late" style="cursor: help;" title="Submitted after daily deadline">
                                            Late Submission
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-present">On Time</span>
                                    }
                                </td>
                                <td>
                                    @if (plan.Status == LessonPlanStatus.Pending)
                                    {
                                        <span class="badge badge-pending">Pending Review</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-present">Reviewed</span>
                                    }
                                </td>
                                <td style="text-align: right;">
                                    <button class="btn-premium" style="padding: 0.4rem 0.80rem; font-size: 0.8rem;" 
                                            @onclick="() => OpenReviewModal(plan)">
                                        View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No lesson plans found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Review & Feedback Modal -->
@if (showReviewModal && selectedPlan != null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 550px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.25rem;">Lesson Plan Details</h3>
                <button style="background: transparent; border: none; color: var(--text-secondary); font-size: 1.5rem; cursor: pointer;" @onclick="CloseReviewModal">×</button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1.25rem;">
                <!-- Teacher Details -->
                <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                    <div>
                        <span style="color: var(--text-secondary);">Teacher:</span>
                        <strong style="display: block; color: var(--text-primary);">@selectedPlan.Teacher?.FullName</strong>
                    </div>
                    <div style="text-align: right;">
                        <span style="color: var(--text-secondary);">Submitted:</span>
                        <strong style="display: block; color: var(--text-primary);">@selectedPlan.UploadedAt.ToLocalTime().ToString("g")</strong>
                    </div>
                </div>

                <!-- Lesson Plan File -->
                <div>
                    <span style="color: var(--text-secondary); font-size: 0.9rem;">Lesson Plan File:</span>
                    @if (lessonPlanUrls.TryGetValue(selectedPlan.Id, out var url))
                    {
                        <div style="margin-top: 0.25rem;">
                            <a href="@url" target="_blank" class="btn-premium btn-secondary-custom" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.8rem; font-size: 0.85rem; text-decoration: none;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                View / Download Lesson Plan
                            </a>
                        </div>
                    }
                    else
                    {
                        <strong style="display: block; color: var(--danger); font-size: 0.9rem;">No file uploaded</strong>
                    }
                </div>

                <!-- Lateness / Justification -->
                @if (selectedPlan.IsLate)
                {
                    <div style="background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: var(--radius-md); padding: 1rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--warning); font-weight: 700; font-size: 0.85rem; margin-bottom: 0.5rem; text-transform: uppercase;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            Lateness Justification
                        </div>
                        <p style="font-size: 0.9rem; line-height: 1.5; color: var(--text-primary); margin-bottom: 0.75rem;">
                            @(string.IsNullOrEmpty(selectedPlan.JustificationText) ? "No justification provided." : selectedPlan.JustificationText)
                        </p>
                        @if (selectedPlan.HasJustificationAttachment && justificationUrls.TryGetValue(selectedPlan.Id, out var jUrl))
                        {
                            <a href="@jUrl" target="_blank" class="btn-premium btn-secondary-custom" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.8rem; font-size: 0.85rem; text-decoration: none;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                View / Download Attachment
                            </a>
                        }
                    </div>
                }

                <!-- Feedback Area -->
                <div class="form-group">
                    <label class="form-label">Review Feedback (From Headmaster)</label>
                    @if (selectedPlan.Status == LessonPlanStatus.Pending)
                    {
                        <div style="background: rgba(255,255,255,0.02); border: 1px dashed var(--border-color); padding: 1rem; border-radius: var(--radius-md); font-size: 0.9rem; color: var(--text-muted); text-align: center;">
                            Pending review by the Headmaster.
                        </div>
                    }
                    else
                    {
                        <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 1rem; border-radius: var(--radius-md); font-size: 0.9rem; line-height: 1.5; color: var(--text-primary);">
                            @(string.IsNullOrEmpty(selectedPlan.Feedback) ? "No feedback provided." : selectedPlan.Feedback)
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseReviewModal">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private string activeTab = "pending";

    private List<LessonPlan> pendingPlans = new();
    private List<LessonPlan> reviewedPlans = new();
    private Dictionary<int, string> lessonPlanUrls = new();
    private Dictionary<int, string> justificationUrls = new();

    private bool showReviewModal = false;
    private LessonPlan? selectedPlan;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            await LoadLessonPlans();
        }
    }

    private async Task LoadLessonPlans()
    {
        var allPlans = await DbContext.LessonPlans
            .Include(lp => lp.Teacher)
            .OrderByDescending(lp => lp.UploadedAt)
            .ToListAsync();

        pendingPlans = allPlans.Where(p => p.Status == LessonPlanStatus.Pending).ToList();
        reviewedPlans = allPlans.Where(p => p.Status == LessonPlanStatus.Reviewed).ToList();
        LoadFileUrls();
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private List<LessonPlan> GetActivePlans()
    {
        return activeTab switch
        {
            "pending" => pendingPlans,
            "reviewed" => reviewedPlans,
            _ => pendingPlans
        };
    }

    private void OpenReviewModal(LessonPlan plan)
    {
        selectedPlan = plan;
        showReviewModal = true;
    }

    private void CloseReviewModal()
    {
        showReviewModal = false;
        selectedPlan = null;
    }

    private void LoadFileUrls()
    {
        lessonPlanUrls.Clear();
        justificationUrls.Clear();
        var uploadsPath = Path.Combine(Env.WebRootPath, "uploads");
        if (Directory.Exists(uploadsPath))
        {
            var files = Directory.GetFiles(uploadsPath);
            foreach (var file in files)
            {
                var fileName = Path.GetFileName(file);
                if (fileName.StartsWith("lessonplan_"))
                {
                    var idStr = Path.GetFileNameWithoutExtension(fileName).Substring("lessonplan_".Length);
                    if (int.TryParse(idStr, out int id)) lessonPlanUrls[id] = $"/uploads/{fileName}";
                }
                else if (fileName.StartsWith("justification_"))
                {
                    var idStr = Path.GetFileNameWithoutExtension(fileName).Substring("justification_".Length);
                    if (int.TryParse(idStr, out int id)) justificationUrls[id] = $"/uploads/{fileName}";
                }
            }
        }
    }
}
