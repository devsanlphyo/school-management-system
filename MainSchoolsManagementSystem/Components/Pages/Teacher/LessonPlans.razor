@page "/teacher/lessonplans"
@layout MainSchoolsManagementSystem.Components.Layout.TeacherLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Teacher")]
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data
@using System.IO

<PageTitle>Lesson Plans - Teacher</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.75rem; margin-bottom: 0.25rem;">My Lesson Plans</h2>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Submit your daily lesson plans and view review feedback.</p>
    </div>

    <!-- Status & Submission Card -->
    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem;">
        <!-- Today's Status -->
        <div class="glass-panel" style="flex: 1 1 300px; padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between;">
            <div>
                <h3 style="font-size: 1.15rem; margin-bottom: 0.75rem; color: var(--text-primary);">Today's Submissions</h3>
                @if (todayPlans.Any())
                {
                    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                        <span class="badge badge-present">@todayPlans.Count Submitted</span>
                    </div>
                    foreach (var plan in todayPlans)
                    {
                        <div style="margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">
                            <p style="font-size: 0.9rem; color: var(--text-secondary); font-weight: 600;">
                                @(plan.Subject?.Name ?? "General") - @(plan.Class?.Name ?? "General")
                            </p>
                            <p style="font-size: 0.85rem; color: var(--text-secondary);">
                                Submitted at: <strong>@plan.UploadedAt.ToLocalTime().ToString("t")</strong>
                                @if (plan.IsLate)
                                {
                                    <span class="badge badge-late" style="margin-left: 0.5rem;">Late</span>
                                }
                            </p>
                        </div>
                    }
                }
                else
                {
                    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                        <span class="badge badge-absent">Pending Submission</span>
                    </div>
                    <p style="font-size: 0.9rem; color: var(--text-secondary);">
                        Please upload your lesson plans for today before the deadline: <strong>@dailyDeadline.ToString(@"hh\:mm")</strong>
                    </p>
                }
            </div>
            
            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-color); font-size: 0.85rem; color: var(--text-muted);">
                Daily Deadline: @dailyDeadline.ToString(@"hh\:mm")
            </div>
        </div>

        <!-- Confirm Modal -->
        @if (showConfirmModal)
        {
            <div class="modal-backdrop-custom">
                <div class="modal-content-custom" style="max-width: 500px;">
                    <div class="modal-header-custom">
                        <h3 style="font-size: 1.15rem; font-weight: 800;">Review Submission</h3>
                        <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="() => showConfirmModal = false">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        </button>
                    </div>
                    <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1rem;">
                        <p style="margin: 0; font-size: 0.95rem;">You are about to upload <strong>@selectedLessonPlanFiles.Count</strong> images.</p>
                        
                        <div style="background: rgba(0,0,0,0.05); padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                            <strong>Class/Subject:</strong> @GetSelectedAssignmentName()
                        </div>

                        @if (isSubmissionLate)
                        {
                            <div style="background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: var(--radius-md); padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;">
                                <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--warning); font-weight: 700; font-size: 0.85rem; text-transform: uppercase;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    Late Submission
                                </div>
                                <p style="font-size: 0.85rem; margin: 0; color: var(--text-secondary);">
                                    @GetLatenessString(DateTime.Now.TimeOfDay - dailyDeadline)
                                </p>
                            </div>
                        }

                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            @foreach (var file in selectedLessonPlanFiles)
                            {
                                if (imagePreviews.TryGetValue(file, out var url))
                                {
                                    <img src="@url" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-color);" />
                                }
                            }
                        </div>
                    </div>
                    <div class="modal-footer-custom">
                        <button class="btn-premium btn-secondary-custom" @onclick="() => showConfirmModal = false">Cancel</button>
                        <button class="btn-premium" style="display: flex; align-items: center; gap: 0.5rem;" disabled="@isUploading" @onclick="HandleSubmit">
                            @if (isUploading)
                            {
                                <span>Uploading...</span>
                            }
                            else
                            {
                                <span>Confirm & Upload</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Submission Form -->
        <div class="glass-panel" style="flex: 2 1 500px; padding: 1.5rem;">
            <h3 style="font-size: 1.15rem; margin-bottom: 1rem; color: var(--text-primary);">Upload Lesson Plan</h3>
            
            <EditForm Model="this" OnValidSubmit="HandleSubmit" Style="display: flex; flex-direction: column; gap: 1rem;">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div style="background: var(--danger-bg); border: 1px solid var(--danger-border); color: var(--danger); padding: 0.75rem; border-radius: var(--radius-sm); font-size: 0.9rem;">
                        @errorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div style="background: rgba(16, 185, 129, 0.05); border: 1px solid var(--success-border); color: var(--success); padding: 0.75rem; border-radius: var(--radius-sm); font-size: 0.9rem;">
                        @successMessage
                    </div>
                }

                <div class="form-group">
                    <label class="form-label" style="font-weight: 600;">Subject & Class</label>
                    <select class="form-control-custom" style="padding: 0.5rem;" @bind="selectedAssignmentId">
                        <option value="">-- Select Subject/Class --</option>
                        @foreach (var ta in teacherAssignments)
                        {
                            <option value="@ta.Id">@(ta.Subject?.Name ?? "General") - @(ta.Class?.Name ?? "General")</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" style="font-weight: 600;">Lesson Plan Images</label>
                    <InputFile accept="image/*" multiple OnChange="OnLessonPlanSelected" class="form-control-custom" style="padding: 0.5rem;" />
                    @if (selectedLessonPlanFiles.Count > 0)
                    {
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
                            @foreach (var file in selectedLessonPlanFiles)
                            {
                                if (imagePreviews.TryGetValue(file, out var url))
                                {
                                    <div style="position: relative;">
                                        <img src="@url" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-color);" />
                                    </div>
                                }
                            }
                        </div>
                        <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;">
                            Selected @selectedLessonPlanFiles.Count image(s). You can select more to add them.
                        </div>
                        <button type="button" class="btn-premium btn-secondary-custom" style="padding: 0.25rem 0.5rem; font-size: 0.8rem; margin-top: 0.5rem;" @onclick="ClearFiles">Clear Files</button>
                    }
                </div>

                @if (isSubmissionLate)
                {
                    <div style="background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: var(--radius-md); padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--warning); font-weight: 700; font-size: 0.85rem; text-transform: uppercase;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            Late Submission Justification Required
                        </div>
                        <p style="font-size: 0.85rem; color: var(--text-secondary);">
                            You are submitting past the deadline (@dailyDeadline.ToString(@"hh\:mm")). Please provide a justification.
                        </p>
                        <div class="form-group" style="margin: 0;">
                            <textarea class="form-control-custom" style="min-height: 80px; resize: vertical;" 
                                      placeholder="Enter lateness justification..." 
                                      @bind="justificationText"></textarea>
                        </div>
                    </div>
                }

                <div style="display: flex; justify-content: flex-end; margin-top: 0.5rem;">
                    <button type="button" class="btn-premium" style="display: flex; align-items: center; gap: 0.5rem;" @onclick="OpenConfirmModal">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                        <span>Review Submission</span>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- History List -->
    <div class="glass-panel" style="padding: 0;">
        <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h3 style="font-size: 1.15rem; color: var(--text-primary); margin: 0;">Submission History</h3>
                <span style="font-size: 0.85rem; color: var(--text-muted);">Total Submissions: @pastPlans.Count</span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <label style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 600;">Filter by Date:</label>
                <input type="date" @bind="filterDate" class="form-control-custom" style="padding: 0.3rem 0.5rem; font-size: 0.85rem; width: auto;" />
                @if (filterDate.HasValue)
                {
                    <button class="btn-premium btn-secondary-custom" style="padding: 0.3rem 0.5rem; font-size: 0.8rem;" @onclick="() => filterDate = null">Clear</button>
                }
            </div>
        </div>
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Date Submitted</th>
                        <th>Class & Subject</th>
                        <th>Compliance</th>
                        <th>Lesson Plan Files</th>
                        <th>Review Status</th>
                        <th>Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredPastPlans.Any())
                    {
                        foreach (var plan in FilteredPastPlans)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-primary);">
                                        @plan.UploadedAt.ToLocalTime().ToString("g")
                                    </div>
                                </td>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-primary);">
                                        @(plan.Class?.Name ?? "General")
                                    </div>
                                    <div style="font-size: 0.85rem; color: var(--text-secondary);">
                                        @(plan.Subject?.Name ?? "General")
                                    </div>
                                </td>
                                <td>
                                    @if (plan.IsLate)
                                    {
                                        <span class="badge badge-late" style="cursor: help;" title="Submitted past the deadline">
                                            Late (@GetLatenessString(plan.UploadedAt.TimeOfDay - dailyDeadline))
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-present">On Time</span>
                                    }
                                </td>
                                <td>
                                    @if (lessonPlanUrls.TryGetValue(plan.Id, out var urls) && urls.Any())
                                    {
                                        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                                            @for (int i = 0; i < urls.Count; i++)
                                            {
                                                <a href="@urls[i]" target="_blank" class="btn-premium btn-secondary-custom" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                                    File @(i + 1)
                                                </a>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color: var(--text-muted); font-size: 0.85rem;">No files</span>
                                    }
                                </td>
                                <td>
                                    @if (plan.Status == LessonPlanStatus.Pending)
                                    {
                                        <span class="badge badge-pending">Pending Review</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-approved">Reviewed</span>
                                    }
                                </td>
                                <td>
                                    <div style="font-size: 0.9rem; color: var(--text-secondary); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@plan.Feedback">
                                        @(string.IsNullOrEmpty(plan.Feedback) ? "-" : plan.Feedback)
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No lesson plans found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private string? userId;
    private TimeSpan dailyDeadline = new TimeSpan(8, 30, 0);
    private List<LessonPlan> todayPlans = new();
    private List<LessonPlan> pastPlans = new();
    private Dictionary<int, List<string>> lessonPlanUrls = new();
    
    private List<TeacherAssignment> teacherAssignments = new();
    private string selectedAssignmentId = "";

    private DateTime? filterDate;
    private IEnumerable<LessonPlan> FilteredPastPlans => filterDate.HasValue 
        ? pastPlans.Where(p => p.UploadedAt.Date == filterDate.Value.Date) 
        : pastPlans;

    private List<IBrowserFile> selectedLessonPlanFiles = new();
    private Dictionary<IBrowserFile, string> imagePreviews = new();
    private string justificationText = "";
    
    private bool isSubmissionLate = false;
    private bool isUploading = false;
    private bool showConfirmModal = false;
    private string errorMessage = "";
    private string successMessage = "";

    private string GetLatenessString(TimeSpan diff)
    {
        if (diff.TotalMinutes < 0) return "On time";
        return $"{diff.Hours}h {diff.Minutes}m";
    }

    private string GetSelectedAssignmentName()
    {
        if (int.TryParse(selectedAssignmentId, out int id))
        {
            var ta = teacherAssignments.FirstOrDefault(t => t.Id == id);
            if (ta != null) return $"{ta.Subject?.Name ?? "General"} - {ta.Class?.Name ?? "General"}";
        }
        return "Unknown";
    }

    private void ClearFiles()
    {
        selectedLessonPlanFiles.Clear();
        imagePreviews.Clear();
    }
    
    private void OpenConfirmModal()
    {
        errorMessage = "";
        if (selectedLessonPlanFiles.Count == 0)
        {
            errorMessage = "Please select at least one lesson plan image to upload.";
            return;
        }

        if (string.IsNullOrEmpty(selectedAssignmentId) || !int.TryParse(selectedAssignmentId, out _))
        {
            errorMessage = "Please select a Subject and Class for this lesson plan.";
            return;
        }
        
        isSubmissionLate = DateTime.Now.TimeOfDay > dailyDeadline;
        if (isSubmissionLate && string.IsNullOrWhiteSpace(justificationText))
        {
            errorMessage = "Justification text is required for late submissions.";
            return;
        }

        showConfirmModal = true;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var appUser = await UserManager.GetUserAsync(user);
            if (appUser != null)
            {
                userId = appUser.Id;
                await LoadData();
            }
        }
    }

    private async Task LoadData()
    {
        if (string.IsNullOrEmpty(userId)) return;

        // Load assignments
        teacherAssignments = await DbContext.TeacherAssignments
            .Include(ta => ta.Class)
            .Include(ta => ta.Subject)
            .Where(ta => ta.TeacherId == userId)
            .ToListAsync();

        // Load setting
        var setting = await DbContext.SystemSettings.FirstOrDefaultAsync();
        if (setting != null)
        {
            dailyDeadline = setting.DailyDeadline;
        }

        // Check if current time is past deadline
        isSubmissionLate = DateTime.Now.TimeOfDay > dailyDeadline;

        // Load today's plans
        var today = DateTime.Today;
        todayPlans = await DbContext.LessonPlans
            .Include(lp => lp.Class)
            .Include(lp => lp.Subject)
            .Where(lp => lp.TeacherId == userId && lp.UploadedAt >= today && lp.UploadedAt < today.AddDays(1))
            .ToListAsync();

        // Load all past plans
        pastPlans = await DbContext.LessonPlans
            .Include(lp => lp.Class)
            .Include(lp => lp.Subject)
            .Where(lp => lp.TeacherId == userId)
            .OrderByDescending(lp => lp.UploadedAt)
            .ToListAsync();
            
        LoadFileUrls();
    }

    private async Task OnLessonPlanSelected(InputFileChangeEventArgs e)
    {
        var newFiles = e.GetMultipleFiles(maximumFileCount: 10);
        foreach (var file in newFiles)
        {
            if (file.ContentType.StartsWith("image/"))
            {
                selectedLessonPlanFiles.Add(file);
                
                try
                {
                    using var ms = new MemoryStream();
                    await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
                    var base64 = Convert.ToBase64String(ms.ToArray());
                    imagePreviews[file] = $"data:{file.ContentType};base64,{base64}";
                }
                catch (Exception)
                {
                    // Ignore preview fail
                }
            }
        }
        
        errorMessage = "";
        successMessage = "";
    }

    private void LoadFileUrls()
    {
        lessonPlanUrls.Clear();
        var uploadsPath = Path.Combine(Env.WebRootPath, "uploads");
        if (Directory.Exists(uploadsPath))
        {
            var files = Directory.GetFiles(uploadsPath);
            foreach (var file in files)
            {
                var fileName = Path.GetFileName(file);
                if (fileName.StartsWith("lessonplan_"))
                {
                    // lessonplan_{id}_{index}.ext or lessonplan_{id}.ext
                    var parts = Path.GetFileNameWithoutExtension(fileName).Split('_');
                    if (parts.Length >= 2 && int.TryParse(parts[1], out int id))
                    {
                        if (!lessonPlanUrls.ContainsKey(id)) lessonPlanUrls[id] = new List<string>();
                        lessonPlanUrls[id].Add($"/uploads/{fileName}");
                    }
                }
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (isUploading) return;
        isUploading = true;
        errorMessage = "";
        successMessage = "";

        try
        {
            showConfirmModal = false;

            if (string.IsNullOrEmpty(selectedAssignmentId) || !int.TryParse(selectedAssignmentId, out int assignmentId))
            {
                errorMessage = "Please select a Subject and Class for this lesson plan.";
                return;
            }

            var assignment = teacherAssignments.FirstOrDefault(ta => ta.Id == assignmentId);
            if (assignment == null)
            {
                errorMessage = "Invalid assignment selected.";
                return;
            }

            // Re-evaluate lateness
            isSubmissionLate = DateTime.Now.TimeOfDay > dailyDeadline;

            if (isSubmissionLate && string.IsNullOrWhiteSpace(justificationText))
            {
                errorMessage = "Justification text is required for late submissions.";
                return;
            }

            var uploadsPath = Path.Combine(Env.WebRootPath, "uploads");
            if (!Directory.Exists(uploadsPath))
            {
                Directory.CreateDirectory(uploadsPath);
            }

            // Create db record
            var lp = new LessonPlan
            {
                TeacherId = userId!,
                ClassId = assignment.ClassId,
                SubjectId = assignment.SubjectId,
                UploadedAt = DateTime.Now,
                IsLate = isSubmissionLate,
                JustificationText = isSubmissionLate ? justificationText : null,
                Status = LessonPlanStatus.Pending,
                HasJustificationAttachment = false
            };

            DbContext.LessonPlans.Add(lp);
            await DbContext.SaveChangesAsync();

            // Save lesson plan files
            int counter = 1;
            foreach (var file in selectedLessonPlanFiles)
            {
                var lpExt = Path.GetExtension(file.Name);
                var lpPath = Path.Combine(uploadsPath, $"lessonplan_{lp.Id}_{counter}{lpExt}");
                using (var fs = new FileStream(lpPath, FileMode.Create))
                {
                    await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);
                }
                counter++;
            }

            // Reset Form
            ClearFiles();
            justificationText = "";
            selectedAssignmentId = "";
            
            successMessage = "Lesson plan uploaded successfully!";
            
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred during submission: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }
}
