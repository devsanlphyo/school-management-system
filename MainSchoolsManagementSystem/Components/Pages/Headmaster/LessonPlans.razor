@page "/headmaster/lesson-plans"
@layout HeadmasterLayout
@attribute [Authorize(Roles = "Admin,Headmaster,Officer")]
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data
@using System.IO

<PageTitle>Lesson Plans Review</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h2 style="font-size: 1.75rem; margin-bottom: 0.25rem;">Lesson Plans Review</h2>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">Review submissions, check compliance, and provide feedback.</p>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-secondary); padding: 0.5rem 1rem; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
            <label style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 600;">Filter by Date:</label>
            <input type="date" @bind="filterDate" class="form-control-custom" style="padding: 0.3rem 0.5rem; font-size: 0.85rem; width: auto;" />
            @if (filterDate.HasValue)
            {
                <button class="btn-premium btn-secondary-custom" style="padding: 0.3rem 0.5rem; font-size: 0.8rem;" @onclick="ClearFilterDate">Clear</button>
            }
        </div>
    </div>

    <!-- Tabbed Navigation -->
    <div class="tab-navigation">
        <button class="tab-link @(activeTab == "pending" ? "active" : "")" @onclick='() => SetActiveTab("pending")'>
            Pending Review (@pendingPlans.Count)
        </button>
        <button class="tab-link @(activeTab == "reviewed" ? "active" : "")" @onclick='() => SetActiveTab("reviewed")'>
            Reviewed (@reviewedPlans.Count)
        </button>
    </div>

    <!-- Submissions List -->
    <div class="glass-panel" style="padding: 0;">
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Teacher</th>
                        <th>Uploaded At</th>
                        <th>Compliance</th>
                        <th>Status</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (GetActivePlans().Any())
                    {
                        foreach (var plan in GetActivePlans())
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-primary);">@plan.Teacher?.FullName</div>
                                </td>
                                <td>
                                    @plan.UploadedAt.ToLocalTime().ToString("g")
                                </td>
                                <td>
                                    @if (plan.IsLate)
                                    {
                                        <span class="badge badge-late" style="cursor: help;" title="Submitted after daily deadline">
                                            Late (@GetLatenessString(plan.UploadedAt.TimeOfDay - dailyDeadline))
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-present">On Time</span>
                                    }
                                </td>
                                <td>
                                    @if (plan.Status == LessonPlanStatus.Pending)
                                    {
                                        <span class="badge badge-pending">Pending Review</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-present">Reviewed</span>
                                    }
                                </td>
                                <td style="text-align: right;">
                                    <button class="btn-premium" style="padding: 0.4rem 0.80rem; font-size: 0.8rem;" 
                                            @onclick="() => OpenReviewModal(plan)">
                                        @(plan.Status == LessonPlanStatus.Pending ? "Review & Feedback" : "View Feedback")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No lesson plans found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Review & Feedback Modal -->
@if (showReviewModal && selectedPlan != null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 550px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.25rem;">Review Lesson Plan</h3>
                <button style="background: transparent; border: none; color: var(--text-secondary); font-size: 1.5rem; cursor: pointer;" @onclick="CloseReviewModal">×</button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1.25rem;">
                <!-- Teacher Details -->
                <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                    <div>
                        <span style="color: var(--text-secondary);">Teacher:</span>
                        <strong style="display: block; color: var(--text-primary);">@selectedPlan.Teacher?.FullName</strong>
                    </div>
                    <div style="text-align: right;">
                        <span style="color: var(--text-secondary);">Submitted:</span>
                        <strong style="display: block; color: var(--text-primary);">@selectedPlan.UploadedAt.ToLocalTime().ToString("g")</strong>
                    </div>
                </div>

                <!-- Lesson Plan File -->
                <div>
                    <span style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem; display: block;">Lesson Plan Images:</span>
                    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                        @if (lessonPlanUrls.TryGetValue(selectedPlan.Id, out var urls) && urls.Any())
                        {
                            foreach (var url in urls)
                            {
                                <a href="@url" target="_blank" style="display: block; border: 1px solid var(--border-color); border-radius: var(--radius-md); overflow: hidden;">
                                    <img src="@url" style="width: 150px; height: 150px; object-fit: cover; display: block;" alt="Lesson Plan Image" />
                                </a>
                            }
                        }
                        else
                        {
                            <span style="color: var(--text-muted); font-size: 0.9rem;">No images uploaded.</span>
                        }
                    </div>
                </div>

                <!-- Lateness / Justification -->
                @if (selectedPlan.IsLate)
                {
                    <div style="background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: var(--radius-md); padding: 1rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--warning); font-weight: 700; font-size: 0.85rem; margin-bottom: 0.5rem; text-transform: uppercase;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            Lateness Justification (@GetLatenessString(selectedPlan.UploadedAt.TimeOfDay - dailyDeadline))
                        </div>
                        <p style="font-size: 0.9rem; line-height: 1.5; color: var(--text-primary); margin-bottom: 0.75rem;">
                            @(string.IsNullOrEmpty(selectedPlan.JustificationText) ? "No justification provided." : selectedPlan.JustificationText)
                        </p>
                    </div>
                }

                <!-- Feedback Area -->
                <div class="form-group">
                    <label class="form-label">Review Feedback</label>
                    @if (selectedPlan.Status == LessonPlanStatus.Pending)
                    {
                        <textarea class="form-control-custom" style="min-height: 120px; resize: vertical;" 
                                  placeholder="Write constructive feedback for the teacher..." 
                                  @bind="feedbackText"></textarea>
                    }
                    else
                    {
                        <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 1rem; border-radius: var(--radius-md); font-size: 0.9rem; line-height: 1.5; color: var(--text-primary);">
                            @selectedPlan.Feedback
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer-custom" style="display: flex; justify-content: space-between;">
                <div>
                    <button class="btn-premium" style="background: var(--danger); border-color: var(--danger);" @onclick="DeleteSubmission" title="Delete duplicate or erroneous submission">Delete</button>
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="btn-premium btn-secondary-custom" @onclick="CloseReviewModal">Close</button>
                    @if (selectedPlan.Status == LessonPlanStatus.Pending)
                    {
                        <button class="btn-premium" @onclick="SubmitReview">Submit Review & Approve</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int? schoolId;
    private string activeTab = "pending";

    private List<LessonPlan> pendingPlans = new();
    private List<LessonPlan> reviewedPlans = new();
    private Dictionary<int, List<string>> lessonPlanUrls = new();

    private TimeSpan dailyDeadline = new TimeSpan(8, 30, 0);

    private bool showReviewModal = false;
    private LessonPlan? selectedPlan;
    private string feedbackText = "";
    
    private DateTime? filterDate;

    private async Task ClearFilterDate()
    {
        filterDate = null;
        await LoadLessonPlans();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var setting = await DbContext.SystemSettings.FirstOrDefaultAsync();
            if (setting != null)
            {
                dailyDeadline = setting.DailyDeadline;
            }

            var appUser = await UserManager.GetUserAsync(user);
            if (appUser != null && appUser.SchoolId.HasValue)
            {
                schoolId = appUser.SchoolId.Value;
                await LoadLessonPlans();
            }
        }
    }

    private async Task LoadLessonPlans()
    {
        if (!schoolId.HasValue) return;

        var allPlans = await DbContext.LessonPlans
            .Include(lp => lp.Teacher)
            .Where(lp => lp.Teacher != null && lp.Teacher.SchoolId == schoolId.Value)
            .OrderByDescending(lp => lp.UploadedAt)
            .ToListAsync();

        pendingPlans = allPlans.Where(p => p.Status == LessonPlanStatus.Pending).ToList();
        reviewedPlans = allPlans.Where(p => p.Status == LessonPlanStatus.Reviewed).ToList();
        LoadFileUrls();
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private IEnumerable<LessonPlan> GetActivePlans()
    {
        var plans = activeTab switch
        {
            "pending" => pendingPlans,
            "reviewed" => reviewedPlans,
            _ => pendingPlans
        };
        
        if (filterDate.HasValue)
        {
            return plans.Where(p => p.UploadedAt.Date == filterDate.Value.Date);
        }
        return plans;
    }

    private void OpenReviewModal(LessonPlan plan)
    {
        selectedPlan = plan;
        feedbackText = plan.Feedback ?? "";
        showReviewModal = true;
    }

    private void CloseReviewModal()
    {
        showReviewModal = false;
        selectedPlan = null;
        feedbackText = "";
    }

    private async Task SubmitReview()
    {
        if (selectedPlan != null)
        {
            selectedPlan.Feedback = feedbackText;
            selectedPlan.Status = LessonPlanStatus.Reviewed;

            DbContext.LessonPlans.Update(selectedPlan);
            await DbContext.SaveChangesAsync();
            await LoadLessonPlans();
            CloseReviewModal();
            StateHasChanged();
        }
    }

    private async Task DeleteSubmission()
    {
        if (selectedPlan != null)
        {
            DbContext.LessonPlans.Remove(selectedPlan);
            await DbContext.SaveChangesAsync();
            
            var uploadsPath = Path.Combine(Env.WebRootPath, "uploads");
            var matchingFiles = Directory.GetFiles(uploadsPath, $"*_{selectedPlan.Id}.*");
            foreach(var f in matchingFiles) 
            {
               if(Path.GetFileName(f).StartsWith($"lessonplan_{selectedPlan.Id}.") || Path.GetFileName(f).StartsWith($"justification_{selectedPlan.Id}.")) 
               {
                   System.IO.File.Delete(f);
               }
            }

            await LoadLessonPlans();
            CloseReviewModal();
            StateHasChanged();
        }
    }

    private void LoadFileUrls()
    {
        lessonPlanUrls.Clear();
        var uploadsPath = Path.Combine(Env.WebRootPath, "uploads");
        if (Directory.Exists(uploadsPath))
        {
            var files = Directory.GetFiles(uploadsPath);
            foreach (var file in files)
            {
                var fileName = Path.GetFileName(file);
                if (fileName.StartsWith("lessonplan_"))
                {
                    var parts = Path.GetFileNameWithoutExtension(fileName).Split('_');
                    if (parts.Length >= 2 && int.TryParse(parts[1], out int id))
                    {
                        if (!lessonPlanUrls.ContainsKey(id)) lessonPlanUrls[id] = new List<string>();
                        lessonPlanUrls[id].Add($"/uploads/{fileName}");
                    }
                }
            }
        }
    }

    private string GetLatenessString(TimeSpan diff)
    {
        if (diff.TotalMinutes < 0) return "On time";
        return $"{diff.Hours}h {diff.Minutes}m";
    }
}
