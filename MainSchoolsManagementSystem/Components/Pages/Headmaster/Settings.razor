@page "/headmaster/settings"
@layout HeadmasterLayout
@attribute [Authorize(Roles = "Admin,Headmaster,Officer")]
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data
@using System

<PageTitle>Admin Settings</PageTitle>

<div class="d-flex flex-column gap-4" style="max-width: 600px;">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.75rem; margin-bottom: 0.25rem;">Settings</h2>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Configure school policies, deadlines, and parameters.</p>
    </div>

    <!-- Alert Success -->
    @if (showSuccessAlert)
    {
        <div style="background: var(--success-bg); border: 1px solid var(--success-border); color: var(--success); padding: 1rem; border-radius: var(--radius-md); display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Settings saved successfully!
        </div>
    }

    <!-- Lesson Plan Policies -->
    <div class="glass-panel d-flex flex-column gap-4">
        <div style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
            <h3 style="font-size: 1.15rem; font-weight: 700;">Lesson Plan Policies</h3>
            <p style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 0.15rem;">Set submission deadlines and compliance triggers.</p>
        </div>

        <div class="form-group">
            <label class="form-label">Daily Submission Deadline</label>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <input type="time" class="form-control-custom" style="width: 150px;" value="@deadlineString" @onchange="OnDeadlineChanged" />
                <span style="font-size: 0.85rem; color: var(--text-secondary);">
                    Any lesson plan uploaded after this time will be flagged as <strong>Late</strong>.
                </span>
            </div>
        </div>

        <div style="border-top: 1px solid var(--border-color); padding-top: 1.25rem; display: flex; justify-content: flex-end;">
            <button class="btn-premium" @onclick="SaveSettings">
                Save Settings
            </button>
        </div>
    </div>
</div>

@code {
    private SystemSetting? settings;
    private string deadlineString = "08:30";
    private bool showSuccessAlert = false;

    protected override async Task OnInitializedAsync()
    {
        settings = await DbContext.SystemSettings.FirstOrDefaultAsync();
        if (settings == null)
        {
            settings = new SystemSetting { DailyDeadline = new TimeSpan(8, 30, 0) };
            DbContext.SystemSettings.Add(settings);
            await DbContext.SaveChangesAsync();
        }

        // Format TimeSpan to hh:mm string for input type="time"
        deadlineString = $"{settings.DailyDeadline.Hours:D2}:{settings.DailyDeadline.Minutes:D2}";
    }

    private void OnDeadlineChanged(ChangeEventArgs e)
    {
        deadlineString = e.Value?.ToString() ?? "08:30";
    }

    private async Task SaveSettings()
    {
        if (settings != null && TimeSpan.TryParse(deadlineString, out var parsedTime))
        {
            settings.DailyDeadline = parsedTime;
            DbContext.SystemSettings.Update(settings);
            await DbContext.SaveChangesAsync();

            showSuccessAlert = true;
            StateHasChanged();

            // Hide alert after 3 seconds
            await Task.Delay(3000);
            showSuccessAlert = false;
            StateHasChanged();
        }
    }
}
