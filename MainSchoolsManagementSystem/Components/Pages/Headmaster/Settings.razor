@page "/headmaster/settings"
@layout HeadmasterLayout
@attribute [Authorize(Roles = "Admin,Headmaster,Officer")]

<PageTitle>Settings — Headmaster Portal</PageTitle>

<div class="d-flex flex-column" style="max-width: 600px; gap: 2rem;">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">Settings</h2>
        <p style="color: var(--text-muted); font-size: 0.92rem;">Configure your preferences and notifications.</p>
    </div>

    <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.75rem; padding: 3rem; text-align: center; color: var(--text-muted);">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto; opacity: 0.3;"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
        <div style="margin-top: 1rem; font-size: 1.1rem; font-weight: 600; color: var(--text-primary);">Settings Coming Soon</div>
        <p style="font-size: 0.9rem;">Notification and display preferences will be available here in a future update.</p>
    </div>
</div>
