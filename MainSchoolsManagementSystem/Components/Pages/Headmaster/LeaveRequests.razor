@page "/headmaster/leave-requests"
@layout HeadmasterLayout
@attribute [Authorize(Roles = "Admin,Headmaster,Officer")]
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data

<PageTitle>Leave Requests</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h2 style="font-size: 1.75rem; margin-bottom: 0.25rem;">Leave Requests</h2>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">Review, approve, and reject teacher leave submissions.</p>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-secondary); padding: 0.5rem 1rem; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
            <label style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 600;">Filter by Date:</label>
            <input type="date" @bind="filterDate" class="form-control-custom" style="padding: 0.3rem 0.5rem; font-size: 0.85rem; width: auto;" />
            @if (filterDate.HasValue)
            {
                <button class="btn-premium btn-secondary-custom" style="padding: 0.3rem 0.5rem; font-size: 0.8rem;" @onclick="() => filterDate = null">Clear</button>
            }
        </div>
    </div>

    <!-- Tabbed Navigation -->
    <div class="tab-navigation">
        <button class="tab-link @(activeTab == "pending" ? "active" : "")" @onclick='() => SetActiveTab("pending")'>
            Pending (@pendingRequests.Count)
        </button>
        <button class="tab-link @(activeTab == "approved" ? "active" : "")" @onclick='() => SetActiveTab("approved")'>
            Approved (@approvedRequests.Count)
        </button>
        <button class="tab-link @(activeTab == "rejected" ? "active" : "")" @onclick='() => SetActiveTab("rejected")'>
            Rejected (@rejectedRequests.Count)
        </button>
    </div>

    <!-- Requests List -->
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        @if (GetActiveRequests().Any())
        {
            foreach (var request in GetActiveRequests())
            {
                <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem;">
                        <div>
                            <div style="font-size: 1.1rem; font-weight: 700; color: var(--text-primary);">
                                @request.User?.FullName
                            </div>
                            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;">
                                Submitted on: @request.SubmittedAt.ToLocalTime().ToString("g")
                            </div>
                        </div>
                        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem;">
                            <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">Leave Dates:</span>
                            <span style="font-size: 0.95rem; font-weight: 700; color: var(--primary);">
                                @request.StartDate.ToString("MMM dd") - @request.EndDate.ToString("MMM dd, yyyy")
                            </span>
                        </div>
                    </div>

                    <div style="background: rgba(0,0,0,0.15); border: 1px solid var(--border-color); padding: 1rem; border-radius: var(--radius-md); font-size: 0.9rem; line-height: 1.5; color: var(--text-primary);">
                        <strong style="display: block; font-size: 0.8rem; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 0.5rem; letter-spacing: 0.05em;">Reason</strong>
                        @request.Reason
                    </div>

                    @if (request.Status == LeaveStatus.Pending)
                    {
                        <div style="display: flex; justify-content: flex-end; gap: 0.75rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                            <button class="btn-premium btn-secondary-custom" style="border-color: var(--danger-border); color: #f87171;" 
                                    @onclick="() => UpdateRequestStatus(request.Id, LeaveStatus.Rejected)">
                                Reject Request
                            </button>
                            <button class="btn-premium" style="background: var(--success);" 
                                    @onclick="() => UpdateRequestStatus(request.Id, LeaveStatus.Approved)">
                                Approve Request
                            </button>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; justify-content: flex-end; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
                            @if (request.Status == LeaveStatus.Approved)
                            {
                                <span class="badge badge-present" style="padding: 0.4rem 1rem;">Approved</span>
                            }
                            else
                            {
                                <span class="badge badge-absent" style="padding: 0.4rem 1rem;">Rejected</span>
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="glass-panel" style="text-align: center; padding: 4rem; color: var(--text-muted);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.5;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="15" x2="15" y2="15"></line><line x1="9" y1="19" x2="15" y2="19"></line><line x1="9" y1="11" x2="10" y2="11"></line></svg>
                <p>No leave requests found in this tab.</p>
            </div>
        }
    </div>
</div>

@code {
    private int? schoolId;
    private string activeTab = "pending";
    private DateTime? filterDate;

    private List<LeaveRequest> pendingRequests = new();
    private List<LeaveRequest> approvedRequests = new();
    private List<LeaveRequest> rejectedRequests = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var appUser = await UserManager.GetUserAsync(user);
            if (appUser != null && appUser.SchoolId.HasValue)
            {
                schoolId = appUser.SchoolId.Value;
                await LoadLeaveRequests();
            }
        }
    }

    private async Task LoadLeaveRequests()
    {
        if (!schoolId.HasValue) return;

        var allRequests = await DbContext.LeaveRequests
            .Include(lr => lr.User)
            .Where(lr => lr.User != null && lr.User.SchoolId == schoolId.Value)
            .OrderByDescending(lr => lr.SubmittedAt)
            .ToListAsync();

        pendingRequests = allRequests.Where(r => r.Status == LeaveStatus.Pending).ToList();
        approvedRequests = allRequests.Where(r => r.Status == LeaveStatus.Approved).ToList();
        rejectedRequests = allRequests.Where(r => r.Status == LeaveStatus.Rejected).ToList();
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private IEnumerable<LeaveRequest> GetActiveRequests()
    {
        var requests = activeTab switch
        {
            "pending" => pendingRequests,
            "approved" => approvedRequests,
            "rejected" => rejectedRequests,
            _ => pendingRequests
        };
        
        return filterDate.HasValue 
            ? requests.Where(r => filterDate.Value.Date >= r.StartDate.Date && filterDate.Value.Date <= r.EndDate.Date)
            : requests;
    }

    private async Task UpdateRequestStatus(int requestId, LeaveStatus status)
    {
        var request = await DbContext.LeaveRequests.FindAsync(requestId);
        if (request != null)
        {
            request.Status = status;
            DbContext.LeaveRequests.Update(request);
            await DbContext.SaveChangesAsync();
            await LoadLeaveRequests();
            StateHasChanged();
        }
    }
}
