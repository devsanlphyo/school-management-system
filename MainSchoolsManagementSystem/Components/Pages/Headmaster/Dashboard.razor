@page "/headmaster/dashboard"
@layout HeadmasterLayout
@attribute [Authorize(Roles = "Admin,Headmaster,Officer")]
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Data.ApplicationDbContext DbContext
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data

<PageTitle>Admin Dashboard</PageTitle>

<div class="d-flex flex-column" style="gap: 2.5rem;">
    <!-- Welcome Header with Breathing Space -->
    <div style="margin-bottom: 0.5rem;">
        <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">Dashboard Overview</h2>
        <p style="color: var(--text-muted); font-size: 0.92rem;">Real-time analytics and management actions for today.</p>
    </div>

    <!-- Stats Cards (Breathing Space & Clean Iconography) -->
    <div class="dashboard-grid" style="gap: 1.5rem;">
        <div class="stat-card">
            <div style="color: var(--primary); margin-bottom: 0.75rem;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <span class="stat-value">@totalTeachers</span>
            <span class="stat-label" style="margin-top: 0.25rem;">Total Teachers</span>
        </div>

        <div class="stat-card">
            <div style="color: var(--success); margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <span class="stat-value">@attendancePercentage%</span>
            <span class="stat-label" style="margin-top: 0.25rem; margin-bottom: 0.5rem;">Today's Attendance</span>
            <div class="prog-bar">
                <div class="prog-fill" style="width: @(attendancePercentage)%;"></div>
            </div>
        </div>

        <div class="stat-card">
            <div style="color: var(--warning); margin-bottom: 0.75rem;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </div>
            <span class="stat-value">@pendingLeavesCount</span>
            <span class="stat-label" style="margin-top: 0.25rem;">Pending Leaves</span>
        </div>

        <div class="stat-card">
            <div style="color: var(--danger); margin-bottom: 0.75rem;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </div>
            <span class="stat-value">@pendingLessonPlansCount</span>
            <span class="stat-label" style="margin-top: 0.25rem;">Pending Lesson Plans</span>
        </div>
    </div>

    <!-- Action Center (Clean Cards with Icons) -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
        
        <!-- Pending Leave Requests Card -->
        <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.5rem; padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
                <div>
                    <h3 style="font-size: 1.05rem; font-weight: 800; color: var(--text-primary);">Leave Requests</h3>
                    <span style="font-size: 0.72rem; color: var(--text-muted);">Require your approval</span>
                </div>
                <a href="headmaster/leave-requests" class="btn-premium btn-secondary-custom" style="padding: 0.4rem; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;" title="View All">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </a>
            </div>
            <div style="display: flex; flex-direction: column; gap: 1rem; max-height: 280px; overflow-y: auto; padding-right: 0.25rem;">
                @if (pendingLeaves.Any())
                {
                    foreach (var leave in pendingLeaves)
                    {
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.02);">
                            <div>
                                <div style="font-weight: 600; font-size: 0.85rem; color: var(--text-primary);">@leave.Teacher?.FullName</div>
                                <div style="color: var(--text-muted); font-size: 0.75rem; margin-top: 0.15rem;">
                                    Target Date: @leave.TargetDate.ToShortDateString()
                                </div>
                            </div>
                            <span class="badge badge-amber" title="Pending approval" style="padding: 0.25rem 0.5rem; display: flex; align-items: center; gap: 0.25rem;">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                Pending
                            </span>
                        </div>
                    }
                }
                else
                {
                    <div style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 3rem 0;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 0.5rem; opacity: 0.5;"><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg>
                        <p>All leave requests cleared</p>
                    </div>
                }
            </div>
        </div>

        <!-- Pending Lesson Plans Card -->
        <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.5rem; padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
                <div>
                    <h3 style="font-size: 1.05rem; font-weight: 800; color: var(--text-primary);">Lesson Plans</h3>
                    <span style="font-size: 0.72rem; color: var(--text-muted);">Awaiting review</span>
                </div>
                <a href="headmaster/lesson-plans" class="btn-premium btn-secondary-custom" style="padding: 0.4rem; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;" title="View All">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </a>
            </div>
            <div style="display: flex; flex-direction: column; gap: 1rem; max-height: 280px; overflow-y: auto; padding-right: 0.25rem;">
                @if (pendingLessonPlans.Any())
                {
                    foreach (var plan in pendingLessonPlans)
                    {
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.02);">
                            <div>
                                <div style="font-weight: 600; font-size: 0.85rem; color: var(--text-primary);">@plan.Teacher?.FullName</div>
                                <div style="color: var(--text-muted); font-size: 0.75rem; margin-top: 0.15rem;">
                                    Uploaded: @plan.UploadedAt.ToShortDateString()
                                </div>
                            </div>
                            @if (plan.IsLate)
                            {
                                <span class="badge badge-rose" title="Late Submission" style="padding: 0.25rem 0.5rem; display: flex; align-items: center; gap: 0.25rem;">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    Late
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-green" title="On Time" style="padding: 0.25rem 0.5rem; display: flex; align-items: center; gap: 0.25rem;">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    On Time
                                </span>
                            }
                        </div>
                    }
                }
                else
                {
                    <div style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 3rem 0;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 0.5rem; opacity: 0.5;"><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg>
                        <p>All lesson plans reviewed</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int totalTeachers = 0;
    private int attendancePercentage = 0;
    private int pendingLeavesCount = 0;
    private int pendingLessonPlansCount = 0;
    
    private List<LeaveRequest> pendingLeaves = new();
    private List<LessonPlan> pendingLessonPlans = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var appUser = await UserManager.GetUserAsync(user);
            if (appUser != null && appUser.SchoolId.HasValue)
            {
                int schoolId = appUser.SchoolId.Value;

                // 1. Total Teachers
                var allTeachers = await UserManager.GetUsersInRoleAsync("Teacher");
                var schoolTeachers = allTeachers.Where(u => u.SchoolId == schoolId).ToList();
                totalTeachers = schoolTeachers.Count;

                // 2. Today's Attendance Rate
                var today = DateTime.Today;
                var todayAttendances = await DbContext.Attendances
                    .Include(a => a.Teacher)
                    .Where(a => a.Teacher.SchoolId == schoolId && a.Date == today)
                    .ToListAsync();

                if (totalTeachers > 0)
                {
                    int presentCount = todayAttendances.Count(a => a.Status == AttendanceStatus.Present || a.Status == AttendanceStatus.Late);
                    attendancePercentage = (int)Math.Round((double)presentCount / totalTeachers * 100);
                }

                // 3. Pending Leaves
                pendingLeaves = await DbContext.LeaveRequests
                    .Include(lr => lr.Teacher)
                    .Where(lr => lr.Teacher.SchoolId == schoolId && lr.Status == LeaveStatus.Pending)
                    .OrderByDescending(lr => lr.SubmittedAt)
                    .ToListAsync();
                pendingLeavesCount = pendingLeaves.Count;

                // 4. Pending Lesson Plans
                pendingLessonPlans = await DbContext.LessonPlans
                    .Include(lp => lp.Teacher)
                    .Where(lp => lp.Teacher.SchoolId == schoolId && lp.Status == LessonPlanStatus.Pending)
                    .OrderByDescending(lp => lp.UploadedAt)
                    .ToListAsync();
                pendingLessonPlansCount = pendingLessonPlans.Count;
            }
        }
    }
}
