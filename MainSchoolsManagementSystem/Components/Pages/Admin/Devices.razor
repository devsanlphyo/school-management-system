@page "/admin/devices"
@layout MainSchoolsManagementSystem.Components.Layout.AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using MainSchoolsManagementSystem.Data
@using MainSchoolsManagementSystem.Features.TrustedDevices.Services
@inject ITrustedDeviceService TrustedDeviceService
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager

<PageTitle>Device Authorizations — Admin</PageTitle>

<div class="d-flex flex-column" style="gap: 2rem;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 0.5rem;">
        <div>
            <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">Device Authorizations</h2>
            <p style="color: var(--text-muted); font-size: 0.92rem;">Manage device access for all users in the system.</p>
        </div>
    </div>

    <!-- Devices List -->
    <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.5rem;">
        @if (devices == null)
        {
            <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
                <div class="spinner-border text-primary" role="status" style="width: 2rem; height: 2rem; margin-bottom: 0.5rem;"></div>
                <p>Loading authorized devices...</p>
            </div>
        }
        else if (!devices.Any())
        {
            <div style="padding: 3rem 1.5rem; text-align: center; color: var(--text-muted);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.5;"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                <p style="font-weight: 600; font-size: 0.95rem;">No devices registered yet</p>
                <p style="font-size: 0.8rem; opacity: 0.8; margin-top: 0.25rem;">Authorized user logins will appear here.</p>
            </div>
        }
        else
        {
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.85rem; flex-wrap: wrap; gap: 0.75rem;">
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--text-primary); margin: 0;">Authorized System Devices</h3>
                    <span style="font-size: 0.72rem; color: var(--text-muted);">Trusted devices with access privileges</span>
                </div>
                <span class="badge badge-indigo" style="font-weight: 700; font-size: 0.78rem; padding: 0.35rem 0.85rem; border-radius: 30px;">
                    @devices.Count Active Devices
                </span>
            </div>

            <div class="table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Device Details</th>
                            <th>Last Used</th>
                            <th>Status</th>
                            <th style="text-align: right; width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in devices)
                        {
                            <tr>
                                <td>
                                    <div style="display: flex; flex-direction: column; gap: 0.2rem;">
                                        <span style="font-weight: 700; color: var(--text-primary); font-size: 0.9rem;">@device.User?.FullName</span>
                                        <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 500;">@device.User?.Email</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="display: flex; flex-direction: column; gap: 0.2rem;">
                                        <div style="font-size: 0.85rem; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 700; color: var(--text-primary);" title="@device.DeviceName">
                                            @device.DeviceName
                                        </div>
                                        <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 500;">IP: @device.IpAddress</span>
                                    </div>
                                </td>
                                <td style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 600;">
                                    @device.LastUsedAt.ToString("MMM dd, yyyy HH:mm")
                                </td>
                                <td>
                                    @if (device.Status == DeviceStatus.Approved)
                                    {
                                        <span class="badge badge-green">Approved</span>
                                    }
                                    else if (device.Status == DeviceStatus.Pending)
                                    {
                                        <span class="badge badge-amber">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-rose">Revoked</span>
                                    }
                                </td>
                                <td style="text-align: right;">
                                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                                        @if (device.Status != DeviceStatus.Approved)
                                        {
                                            <button class="btn-premium" @onclick="() => UpdateStatusAsync(device.Id, DeviceStatus.Approved)" style="font-size: 0.75rem; padding: 0.38rem 0.75rem; font-weight: 700; border-radius: 6px;">
                                                Approve
                                            </button>
                                        }
                                        @if (device.Status != DeviceStatus.Revoked)
                                        {
                                            <button class="btn-premium btn-secondary-custom" @onclick="() => UpdateStatusAsync(device.Id, DeviceStatus.Revoked)" style="font-size: 0.75rem; padding: 0.38rem 0.75rem; color: var(--danger); border-color: rgba(239,68,68,0.15); font-weight: 700; border-radius: 6px;">
                                                Revoke
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<UserTrustedDevice>? devices;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevicesAsync();
    }

    private async Task LoadDevicesAsync()
    {
        devices = await TrustedDeviceService.GetAllDevicesAsync();
    }

    private async Task UpdateStatusAsync(Guid deviceId, DeviceStatus newStatus)
    {
        await TrustedDeviceService.UpdateDeviceStatusAsync(deviceId, newStatus);
        await LoadDevicesAsync();
    }
}
