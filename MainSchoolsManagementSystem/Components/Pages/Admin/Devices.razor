@page "/admin/devices"
@layout MainSchoolsManagementSystem.Components.Layout.AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using MainSchoolsManagementSystem.Data
@using MainSchoolsManagementSystem.Features.TrustedDevices.Services
@inject ITrustedDeviceService TrustedDeviceService
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager

<PageTitle>Device Authorizations — Admin</PageTitle>

<div class="d-flex flex-column" style="max-width: 900px; gap: 2rem;">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">Device Authorizations</h2>
        <p style="color: var(--text-muted); font-size: 0.92rem;">Manage device access for all users in the system.</p>
    </div>

    <!-- Devices List -->
    <div class="glass-panel" style="padding: 1.5rem;">
        @if (devices == null)
        {
            <p>Loading devices...</p>
        }
        else if (!devices.Any())
        {
            <p style="color: var(--text-muted);">No devices have been registered yet.</p>
        }
        else
        {
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Device Details</th>
                        <th>Last Used</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var device in devices)
                    {
                        <tr>
                            <td>
                                <strong style="font-weight: 700; color: var(--text-primary);">@device.User?.FullName</strong><br/>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">@device.User?.Email</span>
                            </td>
                            <td>
                                <div style="font-size: 0.85rem; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600;" title="@device.DeviceName">
                                    @device.DeviceName
                                </div>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">IP: @device.IpAddress</span>
                            </td>
                            <td style="font-size: 0.85rem; color: var(--text-secondary);">
                                @device.LastUsedAt.ToString("MMM dd, yyyy HH:mm")
                            </td>
                            <td>
                                @if (device.Status == DeviceStatus.Approved)
                                {
                                    <span class="badge badge-green">Approved</span>
                                }
                                else if (device.Status == DeviceStatus.Pending)
                                {
                                    <span class="badge badge-amber">Pending</span>
                                }
                                else
                                {
                                    <span class="badge badge-rose">Revoked</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 0.5rem;">
                                    @if (device.Status != DeviceStatus.Approved)
                                    {
                                        <button class="btn-premium" @onclick="() => UpdateStatusAsync(device.Id, DeviceStatus.Approved)" style="font-size: 0.75rem; padding: 0.35rem 0.7rem;">
                                            Approve
                                        </button>
                                    }
                                    @if (device.Status != DeviceStatus.Revoked)
                                    {
                                        <button class="btn-premium btn-secondary-custom" @onclick="() => UpdateStatusAsync(device.Id, DeviceStatus.Revoked)" style="font-size: 0.75rem; padding: 0.35rem 0.7rem; color: var(--danger); border-color: rgba(239,68,68,0.15);">
                                            Revoke
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
    </div>
</div>

@code {
    private List<UserTrustedDevice>? devices;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevicesAsync();
    }

    private async Task LoadDevicesAsync()
    {
        devices = await TrustedDeviceService.GetAllDevicesAsync();
    }

    private async Task UpdateStatusAsync(Guid deviceId, DeviceStatus newStatus)
    {
        await TrustedDeviceService.UpdateDeviceStatusAsync(deviceId, newStatus);
        await LoadDevicesAsync();
    }
}
