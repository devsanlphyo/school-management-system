    private async Task RegisterAdmin()
    {
        if (string.IsNullOrWhiteSpace(registerFullName) || string.IsNullOrWhiteSpace(registerEmail) || string.IsNullOrWhiteSpace(registerPassword))
        {
            validationError = "Full Name, Email, and Password are required.";
            return;
        }

        if (registerRole != "Admin" && string.IsNullOrEmpty(registerSchoolId))
        {
            validationError = "Please select a school to assign.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName = registerEmail,
            Email = registerEmail,
            FullName = registerFullName,
            EmailConfirmed = true
        };

        if (registerRole != "Admin")
        {
            user.SchoolId = int.Parse(registerSchoolId);
        }

        var result = await UserManager.CreateAsync(user, registerPassword);
        if (!result.Succeeded)
        {
            validationError = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        // Assign Role
        await UserManager.AddToRoleAsync(user, registerRole);

        CloseModals();
        await LoadAdministrators();
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(editFullName) || string.IsNullOrWhiteSpace(editEmail))
        {
            validationError = "Full Name and Email are required.";
            return;
        }

        if (editRole != "Admin" && string.IsNullOrEmpty(editSchoolId))
        {
            validationError = "Please select a school to assign.";
            return;
        }

        var user = await UserManager.FindByIdAsync(editUserId);
        if (user == null) return;

        user.FullName = editFullName;
        user.Email = editEmail;
        user.UserName = editEmail;

        if (editRole == "Admin")
        {
            user.SchoolId = null;
            user.DepartmentId = null;
        }
        else
        {
            user.SchoolId = int.Parse(editSchoolId);
            user.DepartmentId = null;
        }

        var result = await UserManager.UpdateAsync(user);
        if (!result.Succeeded)
        {
            validationError = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        // Update Role if changed
        var currentRoles = await UserManager.GetRolesAsync(user);
        if (!currentRoles.Contains(editRole))
        {
            await UserManager.RemoveFromRolesAsync(user, currentRoles);
            await UserManager.AddToRoleAsync(user, editRole);
        }

        CloseModals();
        await LoadAdministrators();
    }

    private async Task AddAssignment()
    {
        if (selectedTeacher == null) return;

        if (string.IsNullOrEmpty(newAssignmentClassId) || string.IsNullOrEmpty(newAssignmentSubjectId))
        {
            validationError = "Please select both a class and a subject.";
            return;
        }

        int classId = int.Parse(newAssignmentClassId);
        int subjectId = int.Parse(newAssignmentSubjectId);

        using var context = await DbFactory.CreateDbContextAsync();
        
        // Check duplicate
        var exists = await context.TeacherAssignments
            .AnyAsync(ta => ta.TeacherId == selectedTeacher.Id && ta.ClassId == classId && ta.SubjectId == subjectId);

        if (exists)
        {
            validationError = "This assignment already exists.";
            return;
        }

        var assignment = new TeacherAssignment
        {
            TeacherId = selectedTeacher.Id,
            ClassId = classId,
            SubjectId = subjectId
        };

        context.TeacherAssignments.Add(assignment);
        await context.SaveChangesAsync();

        // Reload assignments list
        teacherAssignments = await context.TeacherAssignments
            .Include(ta => ta.Class)
            .Include(ta => ta.Subject)
            .ThenInclude(s => s.Department)
            .Where(ta => ta.TeacherId == selectedTeacher.Id)
            .ToListAsync();

        newAssignmentClassId = "";
        newAssignmentSubjectId = "";
        validationError = "";
    }

    private async Task DeleteAssignment(int id)
    {
        if (selectedTeacher == null) return;

        using var context = await DbFactory.CreateDbContextAsync();
        var assignment = await context.TeacherAssignments.FindAsync(id);
        if (assignment != null)
        {
            context.TeacherAssignments.Remove(assignment);
            await context.SaveChangesAsync();

            // Reload assignments list
            teacherAssignments = await context.TeacherAssignments
                .Include(ta => ta.Class)
                .Include(ta => ta.Subject)
                .ThenInclude(s => s.Department)
                .Where(ta => ta.TeacherId == selectedTeacher.Id)
                .ToListAsync();
        }
    }

    private async Task DeleteAdmin()
    {
        if (deletingAdmin == null) return;

        var user = await UserManager.FindByIdAsync(deletingAdmin.Id);
        if (user != null)
        {
            await UserManager.DeleteAsync(user);
        }

        CloseModals();
        await LoadAdministrators();
    }

    private void OpenResetPasswordModal(AdminDisplayDto admin)
    {
        resetPasswordAdmin = admin;
        newPasswordForReset = "";
        validationError = "";
        successMessage = "";
        showResetPasswordModal = true;
    }

    private async Task ResetUserPassword()
    {
        if (resetPasswordAdmin == null) return;
        if (string.IsNullOrWhiteSpace(newPasswordForReset))
        {
            validationError = "Password cannot be empty.";
            successMessage = "";
            return;
        }

        var user = await UserManager.FindByIdAsync(resetPasswordAdmin.Id);
        if (user != null)
        {
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            var result = await UserManager.ResetPasswordAsync(user, token, newPasswordForReset);
            if (result.Succeeded)
            {
                successMessage = "Password has been successfully reset.";
                validationError = "";
                newPasswordForReset = "";
            }
            else
            {
                validationError = string.Join(" ", result.Errors.Select(e => e.Description));
                successMessage = "";
            }
        }
    }

