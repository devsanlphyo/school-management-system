    private async Task OpenAssignmentsModal(AdminDisplayDto teacher)
    {
        selectedTeacher = teacher;
        newAssignmentClassId = "";
        newAssignmentSubjectId = "";
        validationError = "";

        using var context = await DbFactory.CreateDbContextAsync();
        teacherAssignments = await context.TeacherAssignments
            .Include(ta => ta.Class)
            .Include(ta => ta.Subject)
            .ThenInclude(s => s.Department)
            .Where(ta => ta.TeacherId == teacher.Id)
            .ToListAsync();

        if (teacher.SchoolId.HasValue)
        {
            teacherSchoolClasses = await context.SchoolClasses
                .Where(c => c.SchoolId == teacher.SchoolId.Value)
                .ToListAsync();

            var deptIds = await context.Departments
                .Where(d => d.SchoolId == teacher.SchoolId.Value)
                .Select(d => d.Id)
                .ToListAsync();

            teacherSchoolSubjects = await context.Subjects
                .Include(s => s.Department)
                .Where(s => deptIds.Contains(s.DepartmentId))
                .ToListAsync();
        }
        else
        {
            teacherSchoolClasses = new();
            teacherSchoolSubjects = new();
        }

        showAssignmentsModal = true;
    }

