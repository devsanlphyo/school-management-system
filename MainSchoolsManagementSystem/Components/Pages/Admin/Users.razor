@page "/admin/users"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<PageTitle>Manage Users</PageTitle>

<div class="d-flex flex-column" style="gap: 2rem;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">Users</h2>
            <p style="color: var(--text-muted); font-size: 0.92rem;">Register and manage system users and school staff.</p>
        </div>
        <button class="btn-premium" @onclick="OpenRegisterModal">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Register User
        </button>
    </div>

    <!-- Filters Bar -->
    <div class="glass-panel" style="padding: 1.25rem; display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
        <div style="flex: 1; min-width: 200px;">
            <label class="form-label" style="margin-bottom: 0.35rem;">Role Filter</label>
            <select class="form-control-custom" @bind="selectedRoleFilter">
                <option value="">All Roles</option>
                <option value="Headmaster">Headmaster</option>
                <option value="Director">Director</option>
                <option value="Officer">Officer</option>
                <option value="Teacher">Teacher</option>
                <option value="Assistant">Assistant</option>
                <option value="Admin">System Admin</option>
            </select>
        </div>
        <div style="flex: 1; min-width: 200px;">
            <label class="form-label" style="margin-bottom: 0.35rem;">School Filter</label>
            <select class="form-control-custom" @bind="selectedSchoolFilter">
                <option value="">All Schools</option>
                @foreach (var school in schools)
                {
                    <option value="@school.Id.ToString()">@school.Name</option>
                }
            </select>
        </div>
    </div>

    <!-- Table List -->
    <div class="glass-panel" style="padding: 0; overflow: hidden;">
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Assigned School & Dept</th>
                        <th style="text-align: right; width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filteredAdmins.Any())
                    {
                        foreach (var admin in filteredAdmins)
                        {
                            <tr>
                                <td style="font-weight: 700; color: var(--text-primary);">@admin.FullName</td>
                                <td style="color: var(--text-secondary);">@admin.Email</td>
                                <td>
                                    <span class="badge badge-indigo">@admin.Role</span>
                                </td>
                                <td>
                                    @if (admin.SchoolName != null)
                                    {
                                        <div style="display: flex; flex-direction: column; gap: 0.15rem;">
                                            <span style="font-weight: 600; color: var(--text-secondary);">@admin.SchoolName</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color: var(--text-muted); font-style: italic;">System-Wide (None)</span>
                                    }
                                </td>
                                <td style="text-align: right;">
                                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                                        @if (admin.Role == "Teacher")
                                        {
                                            <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem; font-size: 0.8rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem;" title="Manage Class/Subject Assignments" @onclick="() => OpenAssignmentsModal(admin)">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>
                                                Assign
                                            </button>
                                        }
                                        <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem;" title="Edit User" @onclick="() => OpenEditUserModal(admin)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                        </button>
                                        <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem; color: var(--warning);" title="Reset Password" @onclick="() => OpenResetPasswordModal(admin)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                        </button>
                                        <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem; color: var(--danger); border-color: rgba(244,63,94,0.15);" title="Remove User" @onclick="() => OpenDeleteModal(admin)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No users found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal: Register User -->
@if (showRegisterModal)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 450px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.15rem; font-weight: 800;">Register User</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control-custom" placeholder="e.g., John Doe" value="@registerFullName" @oninput="OnFullNameInput" @onblur="OnFullNameBlur" />
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control-custom" placeholder="e.g., headmaster@school.edu" @bind="registerEmail" />
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control-custom" placeholder="Minimum 6 characters" @bind="registerPassword" />
                </div>

                <div class="form-group">
                    <label class="form-label">System Role</label>
                    <select class="form-control-custom" @bind="registerRole">
                        <option value="Headmaster">Headmaster</option>
                        <option value="Director">Director</option>
                        <option value="Officer">Officer</option>
                        <option value="Teacher">Teacher</option>
                        <option value="Assistant">Assistant</option>
                        <option value="Admin">System Admin</option>
                    </select>
                </div>

                @if (registerRole != "Admin")
                {
                    <div class="form-group">
                        <label class="form-label">Assign School</label>
                        <select class="form-control-custom" @onchange="OnRegisterSchoolChanged">
                            <option value="">-- Select School --</option>
                            @foreach (var school in schools)
                            {
                                <option value="@school.Id.ToString()">@school.Name</option>
                            }
                        </select>
                    </div>


                }

                @if (!string.IsNullOrEmpty(validationError))
                {
                    <span class="validation-message">@validationError</span>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseModals">Cancel</button>
                <button class="btn-premium" @onclick="RegisterAdmin">Register</button>
            </div>
        </div>
    </div>
}

<!-- Modal: Edit User -->
@if (showEditUserModal)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 450px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.15rem; font-weight: 800;">Edit User Profile</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control-custom" @bind="editFullName" />
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control-custom" @bind="editEmail" />
                </div>

                <div class="form-group">
                    <label class="form-label">System Role</label>
                    <select class="form-control-custom" @bind="editRole">
                        <option value="Headmaster">Headmaster</option>
                        <option value="Director">Director</option>
                        <option value="Officer">Officer</option>
                        <option value="Teacher">Teacher</option>
                        <option value="Assistant">Assistant</option>
                        <option value="Admin">System Admin</option>
                    </select>
                </div>

                @if (editRole != "Admin")
                {
                    <div class="form-group">
                        <label class="form-label">Assign School</label>
                        <select class="form-control-custom" value="@editSchoolId" @onchange="OnEditSchoolChanged">
                            <option value="">-- Select School --</option>
                            @foreach (var school in schools)
                            {
                                <option value="@school.Id.ToString()">@school.Name</option>
                            }
                        </select>
                    </div>


                }

                @if (!string.IsNullOrEmpty(validationError))
                {
                    <span class="validation-message">@validationError</span>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseModals">Cancel</button>
                <button class="btn-premium" @onclick="SaveUser">Save Changes</button>
            </div>
        </div>
    </div>
}

<!-- Modal: Manage Teacher Assignments -->
@if (showAssignmentsModal && selectedTeacher != null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 600px;">
            <div class="modal-header-custom">
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800;">Manage Assignments</h3>
                    <span style="font-size: 0.75rem; color: var(--text-muted);">Teacher: @selectedTeacher.FullName</span>
                </div>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1.5rem;">
                
                <!-- Add Assignment Form -->
                <div class="glass-panel" style="padding: 1rem; background: rgba(0,0,0,0.02); box-shadow: none; display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
                    <div style="flex: 1; min-width: 160px;">
                        <label class="form-label" style="font-size: 0.75rem; margin-bottom: 0.25rem;">Class</label>
                        <select class="form-control-custom" style="font-size: 0.8rem;" @bind="newAssignmentClassId">
                            <option value="">-- Select Class --</option>
                            @foreach (var cls in teacherSchoolClasses)
                            {
                                <option value="@cls.Id.ToString()">@cls.Name</option>
                            }
                        </select>
                    </div>
                    <div style="flex: 1; min-width: 160px;">
                        <label class="form-label" style="font-size: 0.75rem; margin-bottom: 0.25rem;">Subject</label>
                        <select class="form-control-custom" style="font-size: 0.8rem;" @bind="newAssignmentSubjectId">
                            <option value="">-- Select Subject --</option>
                            @foreach (var sub in teacherSchoolSubjects)
                            {
                                <option value="@sub.Id.ToString()">@sub.Name (@(sub.Department?.Name ?? "General"))</option>
                            }
                        </select>
                    </div>
                    <button class="btn-premium" style="padding: 0.5rem 1rem; font-size: 0.8rem; font-weight: 600;" @onclick="AddAssignment">
                        Assign
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(validationError))
                {
                    <span class="validation-message">@validationError</span>
                }

                <!-- Current Assignments Table -->
                <div>
                    <h4 style="font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-primary);">Current Assignments</h4>
                    <div class="table-container" style="max-height: 250px; overflow-y: auto;">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th>Class</th>
                                    <th>Subject</th>
                                    <th style="text-align: right; width: 60px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (teacherAssignments.Any())
                                {
                                    @foreach (var ta in teacherAssignments)
                                    {
                                        <tr>
                                            <td style="font-weight: 600;">@(ta.Class?.Name ?? "Unknown Class")</td>
                                            <td>
                                                <div style="display: flex; flex-direction: column; gap: 0.1rem;">
                                                    <span style="font-weight: 600; color: var(--text-primary);">@(ta.Subject?.Name ?? "Unknown Subject")</span>
                                                    <span style="font-size: 0.7rem; color: var(--text-muted);">@(ta.Subject?.Department?.Name ?? "General") Dept</span>
                                                </div>
                                            </td>
                                            <td style="text-align: right;">
                                                <button class="btn-premium btn-secondary-custom" style="padding: 0.3rem; color: var(--danger);" title="Remove Assignment" @onclick="() => DeleteAssignment(ta.Id)">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" style="text-align: center; padding: 1.5rem; color: var(--text-muted); font-size: 0.8rem;">
                                            No active assignments.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
}

<!-- Modal: Delete Confirmation -->
@if (showDeleteModal && deletingAdmin != null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 420px;">
            <div class="modal-header-custom" style="border-bottom: none; padding-bottom: 0;">
                <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--danger);">Delete User</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="text-align: center; padding: 1.5rem 2rem;">
                <div style="color: var(--danger); margin-bottom: 1rem;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </div>
                <h4 style="margin-bottom: 0.5rem; font-weight: 700;">Are you sure?</h4>
                <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.5;">
                    This will permanently delete the user account for <strong>@deletingAdmin.Email</strong> from the system.
                </p>
            </div>
            <div class="modal-footer-custom" style="border-top: none; padding-top: 0;">
                <button class="btn-premium btn-secondary-custom" style="flex: 1;" @onclick="CloseModals">Cancel</button>
                <button class="btn-premium" style="background: var(--danger); color: white; flex: 1; box-shadow: none;" @onclick="DeleteAdmin">Delete</button>
            </div>
        </div>
    </div>
}

<!-- Modal: Reset Password -->
@if (showResetPasswordModal && resetPasswordAdmin != null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 420px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.15rem; font-weight: 800;">Reset Password</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1rem;">
                <p style="font-size: 0.85rem; color: var(--text-muted);">Resetting password for <strong>@resetPasswordAdmin.Email</strong>.</p>
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <input type="password" class="form-control-custom" placeholder="Enter new password" @bind="newPasswordForReset" />
                </div>
                @if (!string.IsNullOrEmpty(validationError))
                {
                    <span class="validation-message">@validationError</span>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div style="background: rgba(16, 185, 129, 0.05); border: 1px solid var(--success-border); color: var(--success); padding: 0.75rem; border-radius: var(--radius-sm); font-size: 0.9rem;">
                        @successMessage
                    </div>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseModals">Close</button>
                <button class="btn-premium" @onclick="ResetUserPassword">Reset Password</button>
            </div>
        </div>
    </div>
}

@code {
    private List<School> schools = new();
    private List<AdminDisplayDto> admins = new();

    private string selectedRoleFilter = "";
    private string selectedSchoolFilter = "";

    private bool showRegisterModal = false;
    private string registerFullName = "";
    private string registerEmail = "";
    private string registerPassword = "";
    private string registerRole = "Headmaster";
    private string registerSchoolId = "";
    private string registerDeptId = "";
    private List<Department> schoolDepartments = new();

    private bool showEditUserModal = false;
    private string editUserId = "";
    private string editFullName = "";
    private string editEmail = "";
    private string editRole = "";
    private string editSchoolId = "";
    private string editDeptId = "";
    private List<Department> editSchoolDepartments = new();

    private bool showAssignmentsModal = false;
    private AdminDisplayDto? selectedTeacher;
    private List<TeacherAssignment> teacherAssignments = new();
    private List<SchoolClass> teacherSchoolClasses = new();
    private List<Subject> teacherSchoolSubjects = new();
    private string newAssignmentClassId = "";
    private string newAssignmentSubjectId = "";

    private bool showDeleteModal = false;
    private AdminDisplayDto? deletingAdmin;

    private bool showResetPasswordModal = false;
    private AdminDisplayDto? resetPasswordAdmin;
    private string newPasswordForReset = "";
    private string successMessage = "";

    private string validationError = "";

    private IEnumerable<AdminDisplayDto> filteredAdmins
    {
        get
        {
            var result = admins.AsEnumerable();
            if (!string.IsNullOrEmpty(selectedRoleFilter))
            {
                result = result.Where(a => a.Role == selectedRoleFilter);
            }
            if (!string.IsNullOrEmpty(selectedSchoolFilter))
            {
                int.TryParse(selectedSchoolFilter, out int schoolId);
                result = result.Where(a => a.SchoolId == schoolId);
            }
            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSchools();
        await LoadAdministrators();
    }

    private async Task LoadSchools()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        schools = await context.Schools.ToListAsync();
    }

    private async Task LoadAdministrators()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        admins.Clear();

        var adminRoleNames = new List<string> { "Admin", "Headmaster", "Director", "Officer", "Teacher", "Assistant" };
        var roles = await context.Roles.Where(r => adminRoleNames.Contains(r.Name)).ToListAsync();
        var roleIds = roles.Select(r => r.Id).ToList();

        var userRoles = await context.UserRoles.Where(ur => roleIds.Contains(ur.RoleId)).ToListAsync();
        var userIds = userRoles.Select(ur => ur.UserId).ToList();

        var users = await context.Users
            .Include(u => u.School)
            .Include(u => u.Department)
            .Where(u => userIds.Contains(u.Id))
            .ToListAsync();

        foreach (var user in users)
        {
            var ur = userRoles.FirstOrDefault(x => x.UserId == user.Id);
            var role = roles.FirstOrDefault(r => r.Id == ur?.RoleId)?.Name ?? "Staff";

            admins.Add(new AdminDisplayDto
            {
                Id = user.Id,
                FullName = user.FullName,
                Email = user.Email ?? "Unknown",
                Role = role,
                SchoolId = user.SchoolId,
                SchoolName = user.School?.Name,
                DepartmentId = user.DepartmentId,
                DepartmentName = user.Department?.Name
            });
        }
    }

    private int randomEmailDigit = 0;

    private void OpenRegisterModal()
    {
        registerFullName = "";
        registerEmail = "";
        registerPassword = "";
        registerRole = "Headmaster";
        registerSchoolId = "";
        registerDeptId = "";
        schoolDepartments = new();
        validationError = "";
        randomEmailDigit = new Random().Next(1000, 10000);
        showRegisterModal = true;
    }

    private void OnFullNameInput(ChangeEventArgs e)
    {
        registerFullName = e.Value?.ToString() ?? "";
        
        if (string.IsNullOrWhiteSpace(registerFullName))
        {
            registerEmail = "";
        }
        else
        {
            registerEmail = registerFullName.ToLower().Replace(" ", "") + "@helloone.edu.com";
        }
    }

    private async Task OnFullNameBlur()
    {
        if (!string.IsNullOrWhiteSpace(registerFullName))
        {
            var baseEmail = registerFullName.ToLower().Replace(" ", "") + "@helloone.edu.com";
            var existingUser = await UserManager.FindByEmailAsync(baseEmail);
            
            if (existingUser != null)
            {
                registerEmail = registerFullName.ToLower().Replace(" ", "") + randomEmailDigit.ToString() + "@helloone.edu.com";
            }
            else
            {
                registerEmail = baseEmail;
            }
        }
    }

