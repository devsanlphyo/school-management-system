@page "/admin/settings"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Data

<PageTitle>Global System Settings — HelloTwo</PageTitle>

<div class="d-flex flex-column" style="max-width: 600px; gap: 2rem;">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">System Settings</h2>
        <p style="color: var(--text-muted); font-size: 0.92rem;">Global configurations and system maintenance options.</p>
    </div>

    <!-- Settings Card -->
    <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.75rem; padding: 2rem;">
        
        <!-- Lesson Plan Policies Section -->
        <div>
            <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                Lesson Plan Policies
            </h3>
            
            <div class="form-group">
                <label class="form-label">Daily Submission Deadline</label>
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <input type="time" class="form-control-custom" style="width: 150px;" value="@deadlineString" @onchange="OnDeadlineChanged" />
                    <span style="font-size: 0.85rem; color: var(--text-secondary);">
                        Any lesson plan uploaded after this time will be flagged as <strong>Late</strong>.
                      </span>
                </div>
            </div>
        </div>

        <!-- System Maintenance Section -->
        <div style="margin-top: 1rem;">
            <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1.25rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                System Maintenance
            </h3>
            
            <!-- Toggle: Maintenance Mode -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0;">
                <div style="padding-right: 1.5rem;">
                    <div style="font-weight: 700; font-size: 0.9rem; color: var(--text-primary);">Maintenance Mode</div>
                    <p style="color: var(--text-muted); font-size: 0.78rem; margin-top: 0.25rem;">
                        Temporarily restrict access to the system for all non-admin users.
                    </p>
                </div>
                <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0;">
                    <input type="checkbox" @bind="maintenanceMode" style="opacity: 0; width: 0; height: 0;" />
                    <span class="slider" style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--border-2); border-radius: 34px; transition: .3s; @(maintenanceMode ? "background-color: var(--danger);" : "")">
                        <span style="position: absolute; content: ''; height: 16px; width: 16px; left: 4px; bottom: 4px; background-color: white; border-radius: 50%; transition: .3s; @(maintenanceMode ? "transform: translateX(20px);" : "")"></span>
                    </span>
                </label>
            </div>
        </div>

        <!-- Feedback alert -->
        @if (showSuccessAlert)
        {
            <div class="badge badge-green" style="padding: 0.75rem 1rem; border-radius: var(--radius-sm); font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; width: 100%;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                Settings saved successfully!
            </div>
        }

        <!-- Actions -->
        <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
            <button class="btn-premium btn-secondary-custom" @onclick="ResetSettings">Reset</button>
            <button class="btn-premium" @onclick="SaveSettings">Save Settings</button>
        </div>
    </div>
</div>

@code {
    private SystemSetting? settings;
    private string deadlineString = "08:30";
    private bool maintenanceMode = false;
    private bool showSuccessAlert = false;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        settings = await context.SystemSettings.FirstOrDefaultAsync();
        if (settings == null)
        {
            settings = new SystemSetting { DailyDeadline = new TimeSpan(8, 30, 0), MaintenanceMode = false };
            context.SystemSettings.Add(settings);
            await context.SaveChangesAsync();
        }

        deadlineString = $"{settings.DailyDeadline.Hours:D2}:{settings.DailyDeadline.Minutes:D2}";
        maintenanceMode = settings.MaintenanceMode;
    }

    private void OnDeadlineChanged(ChangeEventArgs e)
    {
        deadlineString = e.Value?.ToString() ?? "08:30";
    }

    private async Task SaveSettings()
    {
        if (settings != null && TimeSpan.TryParse(deadlineString, out var parsedTime))
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var dbSettings = await context.SystemSettings.FirstOrDefaultAsync();
            if (dbSettings != null)
            {
                dbSettings.DailyDeadline = parsedTime;
                dbSettings.MaintenanceMode = maintenanceMode;
                context.SystemSettings.Update(dbSettings);
                await context.SaveChangesAsync();

                settings.DailyDeadline = parsedTime;
                settings.MaintenanceMode = maintenanceMode;
            }

            showSuccessAlert = true;
            StateHasChanged();

            await Task.Delay(3000);
            showSuccessAlert = false;
            StateHasChanged();
        }
    }

    private void ResetSettings()
    {
        if (settings != null)
        {
            deadlineString = $"{settings.DailyDeadline.Hours:D2}:{settings.DailyDeadline.Minutes:D2}";
            maintenanceMode = settings.MaintenanceMode;
        }
        else
        {
            deadlineString = "08:30";
            maintenanceMode = false;
        }
        showSuccessAlert = false;
    }
}
