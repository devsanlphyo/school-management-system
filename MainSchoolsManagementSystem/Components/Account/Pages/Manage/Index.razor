@page "/Account/Manage"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using MainSchoolsManagementSystem.Data
@using Microsoft.EntityFrameworkCore
@using System.IO

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Profile</PageTitle>

<div class="profile-header-container">
    <header class="profile-header-bar">
        <h3 class="profile-title">Profile Settings</h3>
        <div class="header-profile-section">
            <span class="profile-name">@userDisplayName</span>
            <img class="header-avatar" id="header-avatar" src="@ProfilePictureUrl" alt="Header Avatar" />
        </div>
    </header>
</div>

<div class="profile-content-container">
    @if (user == null)
    {
        <div class="text-center py-4">
            <p>Loading profile...</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-success mt-3" role="alert">
                @statusMessage
            </div>
        }

        <EditForm EditContext="editContext" OnSubmit="OnSubmitAsync" FormName="profile-details">
            <DataAnnotationsValidator />
            <div class="profile-layout-grid">
                <!-- Left Side: Avatar Card -->
                <div class="profile-card avatar-card">
                    <div class="avatar-wrapper">
                        <img class="profile-avatar" id="profile-avatar" src="@ProfilePictureUrl" alt="Profile Avatar" />
                    </div>
                    
                    <div class="upload-section">
                        <label class="btn-upload">
                            Choose Photo
                            <InputFile OnChange="OnInputFileChange" accept=".png,.jpg,.jpeg" class="file-input-hidden" />
                        </label>
                        <span class="upload-tip">PNG, JPG, or JPEG up to 2MB</span>
                        <div class="@(string.IsNullOrEmpty(fileValidationError) ? "mt-1" : "text-danger mt-1")" data-valmsg-for="Input.ProfilePicture">
                            @fileValidationError
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(schoolName))
                    {
                        <div class="school-info-section mt-4">
                            <div class="info-label">School</div>
                            <div class="info-value school-info" id="school-display">@schoolName</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(departmentName))
                    {
                        <div class="school-info-section mt-3">
                            <div class="info-label">Department</div>
                            <div class="info-value">@departmentName</div>
                        </div>
                    }
                </div>

                <!-- Right Side: Details Form Card -->
                <div class="profile-card form-card">
                    <div class="form-group mb-4">
                        <label class="form-label" for="username">Username / Email</label>
                        <input type="text" id="username" value="@username" class="form-input-control disabled-input" disabled />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label" for="fullname">Full Name</label>
                        <InputText id="fullname" name="Input.FullName" @bind-Value="Input.FullName" class="form-input-control" placeholder="Enter your full name" />
                        <ValidationMessage For="() => Input.FullName" class="text-danger mt-1" data-valmsg-for="Input.FullName" />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label" for="phone">Phone Number</label>
                        <InputText id="phone" name="Input.PhoneNumber" @bind-Value="Input.PhoneNumber" class="form-input-control" placeholder="Please enter your phone number." />
                        <ValidationMessage For="() => Input.PhoneNumber" class="text-danger mt-1" data-valmsg-for="Input.PhoneNumber" />
                    </div>

                    <button type="submit" class="btn-premium w-100">Save</button>
                </div>
            </div>
        </EditForm>
    }
</div>

<style>
    .profile-header-container {
        background: var(--bg-surface);
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 2rem;
        margin-bottom: 2rem;
        border-radius: var(--radius-lg);
    }
    .profile-header-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .profile-title {
        color: var(--text-primary);
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        font-size: 1.5rem;
        margin: 0;
    }
    .header-profile-section {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .profile-name {
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.9rem;
    }
    .header-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--primary);
    }

    .profile-content-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }
    .profile-layout-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 768px) {
        .profile-layout-grid {
            grid-template-columns: 350px 1fr;
        }
    }

    .profile-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        padding: 2rem;
    }
    .avatar-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .avatar-wrapper {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid var(--border-color);
        box-shadow: var(--shadow);
        margin-bottom: 1.5rem;
        background: var(--bg-base);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .profile-avatar {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .upload-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 100%;
    }
    .btn-upload {
        display: inline-block;
        background: var(--primary-glow);
        color: var(--primary);
        border: 1px dashed var(--primary);
        border-radius: var(--radius-sm);
        padding: 0.5rem 1.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition-smooth);
    }
    .btn-upload:hover {
        background: var(--primary);
        color: #fff;
        border-style: solid;
    }
    .file-input-hidden {
        display: none !important;
    }
    .upload-tip {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .school-info-section {
        text-align: left;
        width: 100%;
        border-top: 1px solid var(--border-color);
        padding-top: 1rem;
    }
    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    .info-value {
        color: var(--text-primary);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-secondary);
    }
    .form-input-control {
        width: 100%;
        background: var(--bg-surface);
        border: 1px solid var(--border-2);
        border-radius: var(--radius-sm);
        padding: 0.75rem 1rem;
        font-family: inherit;
        font-size: 0.95rem;
        color: var(--text-primary);
        outline: none;
        transition: var(--transition-smooth);
    }
    .form-input-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-glow);
    }
    .disabled-input {
        background: var(--bg-base);
        color: var(--text-muted);
        cursor: not-allowed;
    }

    .btn-premium {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 0.75rem 1.5rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
        box-shadow: 0 2px 4px rgba(99, 102, 241, 0.2);
    }
    .btn-premium:hover {
        background: var(--primary-hover);
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(99, 102, 241, 0.3);
    }
</style>

@code {
    private ApplicationUser user = default!;
    private string? username;
    private string? phoneNumber;
    private string? schoolName;
    private string? departmentName;
    private string? userDisplayName;
    private string? statusMessage;
    
    private IBrowserFile? selectedFile;
    private string? fileValidationError;
    
    private EditContext editContext = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private string ProfilePictureUrl => !string.IsNullOrEmpty(user?.ProfilePicturePath)
        ? user.ProfilePicturePath
        : "/uploads/profile-pictures/default-avatar.png";

    protected override async Task OnInitializedAsync()
    {
        user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        username = await UserManager.GetUserNameAsync(user);
        phoneNumber = await UserManager.GetPhoneNumberAsync(user);
        userDisplayName = user.FullName;
        if (string.IsNullOrEmpty(userDisplayName))
        {
            userDisplayName = username;
        }

        Input.FullName ??= user.FullName;
        Input.PhoneNumber ??= phoneNumber;
        
        editContext = new EditContext(Input);

        using (var db = DbFactory.CreateDbContext())
        {
            if (user.SchoolId.HasValue)
            {
                schoolName = db.Schools.FirstOrDefault(s => s.Id == user.SchoolId.Value)?.Name;
            }
            if (user.DepartmentId.HasValue)
            {
                departmentName = db.Departments.FirstOrDefault(d => d.Id == user.DepartmentId.Value)?.Name;
            }
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            fileValidationError = null;
            selectedFile = e.File;

            if (selectedFile == null)
            {
                return;
            }

            var extension = Path.GetExtension(selectedFile.Name)?.ToLowerInvariant() ?? "";
            if (extension != ".png" && extension != ".jpg" && extension != ".jpeg")
            {
                fileValidationError = "Only image files (.png, .jpg, .jpeg) are allowed.";
                selectedFile = null;
                return;
            }

            if (selectedFile.Size > 2 * 1024 * 1024)
            {
                fileValidationError = "Image size cannot exceed 2 MB.";
                selectedFile = null;
                return;
            }
        }
        catch (Exception ex)
        {
            fileValidationError = "Exception: " + ex.Message;
            selectedFile = null;
        }

        await Task.CompletedTask;
    }

    private async Task OnSubmitAsync()
    {
        statusMessage = null;

        // Custom validation for file type and size in case it wasn't caught or file is invalid
        if (selectedFile != null)
        {
            var extension = Path.GetExtension(selectedFile.Name).ToLowerInvariant();
            if (extension != ".png" && extension != ".jpg" && extension != ".jpeg")
            {
                fileValidationError = "Only image files (.png, .jpg, .jpeg) are allowed.";
            }
            else if (selectedFile.Size > 2 * 1024 * 1024)
            {
                fileValidationError = "Image size cannot exceed 2 MB.";
            }
        }

        var isValid = editContext.Validate();

        if (!isValid || !string.IsNullOrEmpty(fileValidationError))
        {
            return;
        }

        // Handle file saving if selected
        if (selectedFile != null)
        {
            try
            {
                var uploadsFolder = Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "profile-pictures");
                if (!Directory.Exists(uploadsFolder))
                {
                    Directory.CreateDirectory(uploadsFolder);
                }

                var uniqueFileName = Guid.NewGuid().ToString() + Path.GetExtension(selectedFile.Name);
                var filePath = Path.Combine(uploadsFolder, uniqueFileName);

                using (var fileStream = new FileStream(filePath, FileMode.Create))
                {
                    await selectedFile.OpenReadStream(2 * 1024 * 1024).CopyToAsync(fileStream);
                }

                // Delete old profile picture if it was a custom file and exists
                if (!string.IsNullOrEmpty(user.ProfilePicturePath) && !user.ProfilePicturePath.EndsWith("default-avatar.png"))
                {
                    var oldPath = Path.Combine(WebHostEnvironment.WebRootPath, user.ProfilePicturePath.TrimStart('/'));
                    if (File.Exists(oldPath))
                    {
                        File.Delete(oldPath);
                    }
                }

                user.ProfilePicturePath = $"/uploads/profile-pictures/{uniqueFileName}";
            }
            catch (Exception ex)
            {
                fileValidationError = $"Failed to upload file: {ex.Message}";
                return;
            }
        }

        // Update database user record details
        user.FullName = Input.FullName ?? "";
        
        if (Input.PhoneNumber != phoneNumber)
        {
            var setPhoneResult = await UserManager.SetPhoneNumberAsync(user, Input.PhoneNumber);
            if (!setPhoneResult.Succeeded)
            {
                statusMessage = "Error: Failed to set phone number.";
                return;
            }
            phoneNumber = Input.PhoneNumber;
        }

        var updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            statusMessage = "Error: Failed to update user details.";
            return;
        }

        userDisplayName = user.FullName;

        await SignInManager.RefreshSignInAsync(user);
        statusMessage = "Your profile has been updated";
        selectedFile = null;
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Full Name is required.")]
        [StringLength(100, ErrorMessage = "Full Name length cannot exceed 100 characters.")]
        [Display(Name = "Full name")]
        public string? FullName { get; set; }

        [Phone(ErrorMessage = "Invalid phone format.")]
        [Display(Name = "Phone number")]
        public string? PhoneNumber { get; set; }
    }
}
