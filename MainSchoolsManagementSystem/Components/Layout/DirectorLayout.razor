@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class='admin-layout'>
    <div class='sidebar-overlay @(isSidebarOpen ? "show" : "")' @onclick='ToggleSidebar'></div>
    <aside class='admin-sidebar @(isSidebarOpen ? "open" : "")'>
        <div class='sidebar-header'>
            <span class='brand-title'>HelloTwo Director</span>
        </div>
        <nav class="sidebar-nav">
            <NavLink class="nav-item" href="director/feed" @onclick="CloseSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin='round'><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
                Feed
            </NavLink>            <NavLink class='nav-item' href='director/dashboard' @onclick='CloseSidebar'>
                <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='7' height='9'></rect><rect x='14' y='3' width='7' height='5'></rect><rect x='14' y='12' width='7' height='9'></rect><rect x='3' y='16' width='7' height='5'></rect></svg>
                Dashboard
            </NavLink>            <NavLink class='nav-item' href='director/reports' @onclick='CloseSidebar'>
                <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='7' height='9'></rect><rect x='14' y='3' width='7' height='5'></rect><rect x='14' y='12' width='7' height='9'></rect><rect x='3' y='16' width='7' height='5'></rect></svg>
                Reports
            </NavLink>            <NavLink class='nav-item' href='director/staffmanagement' @onclick='CloseSidebar'>
                <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='7' height='9'></rect><rect x='14' y='3' width='7' height='5'></rect><rect x='14' y='12' width='7' height='9'></rect><rect x='3' y='16' width='7' height='5'></rect></svg>
                StaffManagement
            </NavLink>            <NavLink class='nav-item' href='director/lessonplans' @onclick='CloseSidebar'>
                <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                Lesson Plans
            </NavLink>            <NavLink class='nav-item' href='director/profile' @onclick='CloseSidebar'>
                <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='7' height='9'></rect><rect x='14' y='3' width='7' height='5'></rect><rect x='14' y='12' width='7' height='9'></rect><rect x='3' y='16' width='7' height='5'></rect></svg>
                Profile
            </NavLink>            <NavLink class='nav-item' href='director/settings' @onclick='CloseSidebar'>
                <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='7' height='9'></rect><rect x='14' y='3' width='7' height='5'></rect><rect x='14' y='12' width='7' height='9'></rect><rect x='3' y='16' width='7' height='5'></rect></svg>
                Settings
            </NavLink>        </nav>
        <div class='sidebar-footer'>
            <form action='/Account/Logout' method='post'>
                <AntiforgeryToken />
                <input type='hidden' name='ReturnUrl' value='' />
                <button type='submit' class='btn-premium btn-secondary-custom' style='width: 100%;'>
                    Logout
                </button>
            </form>
        </div>
    </aside>

    <main class='admin-main'>
        <header class='admin-header'>
            <div style='display: flex; align-items: center; gap: 1rem;'>
                <button class='mobile-nav-toggle' @onclick='ToggleSidebar'>
                    <svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><line x1='3' y1='12' x2='21' y2='12'></line><line x1='3' y1='6' x2='21' y2='6'></line><line x1='3' y1='18' x2='21' y2='18'></line></svg>
                </button>
                <div class='header-school'>
                    Director Portal
                </div>
            </div>
            <div class='header-profile'>
                <span class='profile-name'>@userDisplayName</span>
            </div>
        </header>
        <div class='admin-content'>
            @Body
        </div>
    </main>
</div>

@code {
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private string userDisplayName = "";
    private bool isSidebarOpen = false;

    private void ToggleSidebar() { isSidebarOpen = !isSidebarOpen; }
    private void CloseSidebar() { isSidebarOpen = false; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            userDisplayName = user.Identity.Name ?? "Director";
        }
        else
        {
            NavigationManager.NavigateTo("Account/Login", true);
        }
    }
}
