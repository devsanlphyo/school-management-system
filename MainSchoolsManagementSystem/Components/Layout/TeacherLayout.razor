@inherits LayoutComponentBase
@inject INotificationService NotificationService
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore

<div class='admin-layout'>
    <div class='sidebar-overlay @(isSidebarOpen ? "show" : "")' @onclick='ToggleSidebar'></div>
    <aside class='admin-sidebar @(isSidebarOpen ? "open" : "")'>
        <MainSchoolsManagementSystem.Components.Shared.BrandLogo Role="Teacher" />
        <nav class='sidebar-nav'>
            <NavLink class='nav-item' href='teacher/feed' @onclick='CloseSidebar'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
                Feed
            </NavLink>
            <NavLink class="nav-item" href="teacher/notifications" @onclick="CloseSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                Notifications
                @if (unreadNotificationsCount > 0)
                {
                    <span class="badge badge-rose" style="margin-left: auto; padding: 0.15rem 0.4rem; border-radius: 10px; font-size: 0.7rem; min-width: 18px; text-align: center; font-weight: bold; background-color: var(--danger); color: white;">
                        @unreadNotificationsCount
                    </span>
                }
            </NavLink>
            <NavLink class="nav-item" href="teacher/events" @onclick="CloseSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                Events
                @if (activeAnnouncementCount > 0)
                {
                    <span class="events-nav-dot" style="margin-left: auto;"></span>
                }
            </NavLink>
            <NavLink class='nav-item' href='teacher/attendance' @onclick='CloseSidebar'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                Attendance
            </NavLink>
            <NavLink class='nav-item' href='teacher/leave-requests' @onclick='CloseSidebar'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="15" x2="15" y2="15"></line><line x1="9" y1="19" x2="15" y2="19"></line><line x1="9" y1="11" x2="10" y2="11"></line></svg>
                Leave Requests
            </NavLink>
            <NavLink class='nav-item' href='teacher/lessonplans' @onclick='CloseSidebar'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                Lesson Plans
            </NavLink>
            
            
            <NavLink class='nav-item' href='teacher/profile' @onclick='CloseSidebar'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                Profile
            </NavLink>
            <NavLink class='nav-item' href='teacher/settings' @onclick='CloseSidebar'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                Settings
            </NavLink>
        </nav>
        <div class='sidebar-footer'>
            <button type="button" class="btn-premium btn-secondary-custom" style="width: 100%;" @onclick="ShowLogoutConfirm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.5rem;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Logout
            </button>
        </div>
    </aside>

    <main class='admin-main'>
        @{
            bool isPostDetail = NavigationManager.Uri.Contains("/feed/post/");
        }
        <MainSchoolsManagementSystem.Components.Shared.PortalHeader 
            Title="@(isPostDetail ? "Post Details" : "Teacher Portal")" 
            ShowSchoolIcon="false" 
            UserDisplayName="@userDisplayName" 
            UserProfilePicturePath="@profilePictureUrl"
            OnToggleSidebar="ToggleSidebar"
            ShowBackButton="@isPostDetail"
            OnBackClick="GoBack" />
        <div class='admin-content'>
            @Body
        </div>
    </main>

    @if (showLogoutConfirm)
    {
        <div class="confirm-modal-backdrop" @onclick="CancelLogout">
            <div class="confirm-modal-card" @onclick:stopPropagation>
                <div class="confirm-modal-header">
                    <h3>Confirm Logout</h3>
                </div>
                <div class="confirm-modal-body">
                    <p>Are you sure you want to log out?</p>
                </div>
                <div class="confirm-modal-actions">
                    <button class="confirm-btn cancel" @onclick="CancelLogout">Cancel</button>
                    <form action="/Account/Logout" method="post" style="display:inline; margin:0;">
                        <AntiforgeryToken />
                        <button type="submit" class="confirm-btn delete" style="background-color: var(--danger);">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private UserManager<ApplicationUser> UserManager { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    private string userDisplayName = "";
    private string profilePictureUrl = "/uploads/profile-pictures/default-avatar.png";
    private bool isSidebarOpen = false;
    private int unreadNotificationsCount = 0;
    private bool showLogoutConfirm = false;
    private int activeAnnouncementCount = 0;

    [Inject] private IDbContextFactory<MainSchoolsManagementSystem.Data.ApplicationDbContext> DbContextFactory { get; set; } = default!;

    private void ToggleSidebar() { isSidebarOpen = !isSidebarOpen; }
    private void CloseSidebar() { isSidebarOpen = false; }
    
    private void ShowLogoutConfirm() => showLogoutConfirm = true;
    private void CancelLogout() => showLogoutConfirm = false;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        MainSchoolsManagementSystem.Features.Notifications.Services.NotificationService.OnNotificationReceived += HandleNotificationReceived;
        await UpdateUnreadCountAsync();
        await LoadAnnouncementsAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = authState.User;
        if (userPrincipal.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(userPrincipal);
            if (user != null)
            {
                userDisplayName = user.FullName;
                if (string.IsNullOrEmpty(userDisplayName))
                {
                    userDisplayName = user.UserName ?? "Teacher";
                }
                if (!string.IsNullOrEmpty(user.ProfilePicturePath))
                {
                    profilePictureUrl = user.ProfilePicturePath;
                }
            }
            else
            {
                userDisplayName = userPrincipal.Identity.Name ?? "Teacher";
            }
        }
        else
        {
            NavigationManager.NavigateTo("Account/Login", true);
        }
    }

    private async Task UpdateUnreadCountAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                unreadNotificationsCount = await NotificationService.GetUnreadCountAsync(userId);
            }
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InvokeAsync(async () =>
        {
            await UpdateUnreadCountAsync();
            StateHasChanged();
        });
    }

    private void HandleNotificationReceived(string recipientId)
    {
        InvokeAsync(async () =>
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (userId == recipientId)
            {
                await UpdateUnreadCountAsync();
                StateHasChanged();
            }
        });
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private async Task LoadAnnouncementsAsync()
    {
        using var db = await DbContextFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;
        activeAnnouncementCount = await db.SystemAnnouncements
            .CountAsync(a => a.IsActive && a.StartDate <= now && a.EndDate >= now);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        MainSchoolsManagementSystem.Features.Notifications.Services.NotificationService.OnNotificationReceived -= HandleNotificationReceived;
    }
}


