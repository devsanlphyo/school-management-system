@page "/admin/schools/{SchoolId:int}"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject MainSchoolsManagementSystem.Features.Schools.Services.ISchoolService SchoolService
@inject NavigationManager NavigationManager

<PageTitle>School Details — HelloTwo</PageTitle>

<div class="d-flex flex-column" style="gap: 1.5rem;">
    <!-- Back Button -->
    <div>
        <a href="/admin/schools" class="btn-premium btn-secondary-custom" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; font-size: 0.85rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Schools
        </a>
    </div>

    <!-- Header -->
    <div style="margin-bottom: 0.5rem;">
        <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">@schoolName</h2>
        <p style="color: var(--text-muted); font-size: 0.92rem;">Manage academic departments, school classes, and subjects for this school.</p>
    </div>

    <!-- Main Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 2rem; align-items: start;">
        
        <!-- Card 1: Departments -->
        <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.25rem; padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; flex-wrap: wrap; gap: 0.75rem;">
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--text-primary);">Departments</h3>
                    <span style="font-size: 0.72rem; color: var(--text-muted);">Subject groupings & faculties</span>
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="btn-premium" style="padding: 0.4rem 0.80rem; font-size: 0.8rem; font-weight: 600;" @onclick="OpenAddDeptModal">
                        Add Department
                    </button>
                    <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem 0.80rem; font-size: 0.8rem; font-weight: 600;" @onclick="LoadData">
                        Refresh
                    </button>
                </div>
            </div>

            <div class="table-container" style="max-height: 400px; overflow-y: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Department Name</th>
                            <th style="text-align: right; width: 80px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (departments.Any())
                        {
                            @foreach (var dept in departments)
                            {
                                <tr>
                                    <td style="font-weight: 700; color: var(--text-primary);">@dept.Name</td>
                                    <td style="text-align: right;">
                                        <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem; color: var(--danger); border-color: rgba(244,63,94,0.12);" title="Delete Department" @onclick="() => DeleteDepartment(dept.Id)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" style="text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.85rem;">
                                    No departments registered.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Card 2: School Classes -->
        <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.25rem; padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; flex-wrap: wrap; gap: 0.75rem;">
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--text-primary);">School Classes</h3>
                    <span style="font-size: 0.72rem; color: var(--text-muted);">Grade levels & sections</span>
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="btn-premium" style="padding: 0.4rem 0.80rem; font-size: 0.8rem; font-weight: 600;" @onclick="OpenAddClassModal">
                        Add Class
                    </button>
                    <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem 0.80rem; font-size: 0.8rem; font-weight: 600;" @onclick="LoadData">
                        Refresh
                    </button>
                </div>
            </div>

            <div class="table-container" style="max-height: 400px; overflow-y: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Class Name</th>
                            <th style="text-align: right; width: 80px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (classes.Any())
                        {
                            @foreach (var cls in classes)
                            {
                                <tr>
                                    <td style="font-weight: 700; color: var(--text-primary);">@cls.Name</td>
                                    <td style="text-align: right;">
                                        <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem; color: var(--danger); border-color: rgba(244,63,94,0.12);" title="Delete Class" @onclick="() => DeleteClass(cls.Id)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" style="text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.85rem;">
                                    No classes registered.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Card 3: Subjects -->
        <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.25rem; padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; flex-wrap: wrap; gap: 0.75rem;">
                <div>
                    <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--text-primary);">Subjects</h3>
                    <span style="font-size: 0.72rem; color: var(--text-muted);">Curriculum courses</span>
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="btn-premium" style="padding: 0.4rem 0.80rem; font-size: 0.8rem; font-weight: 600;" @onclick="OpenAddSubjectModal">
                        Add Subject
                    </button>
                    <button class="btn-premium btn-secondary-custom" style="padding: 0.4rem 0.80rem; font-size: 0.8rem; font-weight: 600;" @onclick="LoadData">
                        Refresh
                    </button>
                </div>
            </div>

            <div class="table-container" style="max-height: 400px; overflow-y: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Subject Name</th>
                            <th>Department</th>
                            <th style="text-align: right; width: 80px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (subjects.Any())
                        {
                            @foreach (var sub in subjects)
                            {
                                <tr>
                                    <td style="font-weight: 700; color: var(--text-primary);">@sub.Name</td>
                                    <td>
                                        <span class="badge badge-indigo">@(sub.Department?.Name ?? "General")</span>
                                    </td>
                                    <td style="text-align: right;">
                                        <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem; color: var(--danger); border-color: rgba(244,63,94,0.12);" title="Delete Subject" @onclick="() => DeleteSubject(sub.Id)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" style="text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.85rem;">
                                    No subjects registered.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- Modal: Add Department -->
@if (showAddDeptModal)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 400px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.15rem; font-weight: 800;">Add Department</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom">
                <div class="form-group">
                    <label class="form-label">Department Name</label>
                    <input type="text" class="form-control-custom" placeholder="e.g., Mathematics, Science" @bind="newDeptName" />
                    @if (!string.IsNullOrEmpty(validationError))
                    {
                        <span class="validation-message">@validationError</span>
                    }
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseModals">Cancel</button>
                <button class="btn-premium" @onclick="AddDepartment">Add</button>
            </div>
        </div>
    </div>
}

<!-- Modal: Add Class -->
@if (showAddClassModal)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 400px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.15rem; font-weight: 800;">Add School Class</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Class Name</label>
                    <input type="text" class="form-control-custom" placeholder="e.g., Grade 10-A, KG" @bind="newClassName" />
                </div>
                @if (!string.IsNullOrEmpty(validationError))
                {
                    <span class="validation-message">@validationError</span>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseModals">Cancel</button>
                <button class="btn-premium" @onclick="AddClass">Add</button>
            </div>
        </div>
    </div>
}

<!-- Modal: Add Subject -->
@if (showAddSubjectModal)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 400px;">
            <div class="modal-header-custom">
                <h3 style="font-size: 1.15rem; font-weight: 800;">Add Subject</h3>
                <button class="btn-premium btn-secondary-custom" style="padding: 0.35rem;" @onclick="CloseModals">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-custom" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Subject Name</label>
                    <input type="text" class="form-control-custom" placeholder="e.g., Algebra I, Chemistry" @bind="newSubjectName" />
                </div>
                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select class="form-control-custom" @bind="newSubjectDeptId">
                        <option value="">-- Select Department --</option>
                        @foreach (var dept in departments)
                        {
                            <option value="@dept.Id.ToString()">@dept.Name</option>
                        }
                    </select>
                </div>
                @if (!string.IsNullOrEmpty(validationError))
                {
                    <span class="validation-message">@validationError</span>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn-premium btn-secondary-custom" @onclick="CloseModals">Cancel</button>
                <button class="btn-premium" @onclick="AddSubject">Add</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int SchoolId { get; set; }

    private string schoolName = "Loading School...";
    private List<Department> departments = new();
    private List<SchoolClass> classes = new();
    private List<Subject> subjects = new();

    private bool showAddDeptModal = false;
    private string newDeptName = "";

    private bool showAddClassModal = false;
    private string newClassName = "";

    private bool showAddSubjectModal = false;
    private string newSubjectName = "";
    private string newSubjectDeptId = "";

    private string validationError = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var school = await SchoolService.GetSchoolByIdAsync(SchoolId);

        if (school != null)
        {
            schoolName = school.Name;
            departments = await SchoolService.GetDepartmentsBySchoolIdAsync(SchoolId);
            classes = await SchoolService.GetClassesBySchoolIdAsync(SchoolId);
            
            var deptIds = departments.Select(d => d.Id).ToList();
            subjects = await SchoolService.GetSubjectsByDepartmentIdsAsync(deptIds);
        }
        else
        {
            NavigationManager.NavigateTo("/admin/schools");
        }
    }

    private void OpenAddDeptModal()
    {
        newDeptName = "";
        validationError = "";
        showAddDeptModal = true;
    }

    private void OpenAddClassModal()
    {
        newClassName = "";
        validationError = "";
        showAddClassModal = true;
    }

    private void OpenAddSubjectModal()
    {
        newSubjectName = "";
        newSubjectDeptId = "";
        validationError = "";
        showAddSubjectModal = true;
    }

    private void CloseModals()
    {
        showAddDeptModal = false;
        showAddClassModal = false;
        showAddSubjectModal = false;
        validationError = "";
    }

    private async Task AddDepartment()
    {
        if (string.IsNullOrWhiteSpace(newDeptName))
        {
            validationError = "Department name is required.";
            return;
        }

        var dept = new Department
        {
            Name = newDeptName,
            SchoolId = SchoolId
        };

        await SchoolService.CreateDepartmentAsync(dept);

        CloseModals();
        await LoadData();
    }

    private async Task AddClass()
    {
        if (string.IsNullOrWhiteSpace(newClassName))
        {
            validationError = "Class name is required.";
            return;
        }

        var cls = new SchoolClass
        {
            Name = newClassName,
            GradeLevel = newClassName,
            SchoolId = SchoolId
        };

        await SchoolService.CreateSchoolClassAsync(cls);

        CloseModals();
        await LoadData();
    }

    private async Task AddSubject()
    {
        if (string.IsNullOrWhiteSpace(newSubjectName))
        {
            validationError = "Subject name is required.";
            return;
        }
        if (string.IsNullOrEmpty(newSubjectDeptId))
        {
            validationError = "Please select a department.";
            return;
        }

        var sub = new Subject
        {
            Name = newSubjectName,
            DepartmentId = int.Parse(newSubjectDeptId)
        };

        await SchoolService.CreateSubjectAsync(sub);

        CloseModals();
        await LoadData();
    }

    private async Task DeleteDepartment(int id)
    {
        await SchoolService.DeleteDepartmentAsync(id);
        await LoadData();
    }

    private async Task DeleteClass(int id)
    {
        await SchoolService.DeleteSchoolClassAsync(id);
        await LoadData();
    }

    private async Task DeleteSubject(int id)
    {
        await SchoolService.DeleteSubjectAsync(id);
        await LoadData();
    }
}
