@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject INotificationService NotificationService
@implements IDisposable

<div class="notifications-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem; font-family: 'Outfit', sans-serif;">
                Notifications
            </h2>
            <p style="color: var(--text-muted); font-size: 0.92rem; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif;">
                Stay updated with activity on your posts.
            </p>
        </div>
        @if (notifications != null && notifications.Any(n => !n.IsRead))
        {
            <button class="btn-premium" @onclick="MarkAllAsRead">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.4rem; vertical-align: middle;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Mark all as read
            </button>
        }
    </div>

    <div class="glass-panel" style="padding: 0; overflow: hidden; border-radius: var(--radius-lg); border: 1px solid var(--border-color); background: var(--bg-surface); box-shadow: var(--shadow);">
        @if (notifications == null)
        {
            <div style="padding: 3rem; text-align: center; color: var(--text-muted); font-family: 'Plus Jakarta Sans', sans-serif;">
                <div class="spinner" style="margin: 0 auto 1rem; border: 3px solid rgba(99, 102, 241, 0.1); border-top-color: var(--primary); border-radius: 50%; width: 24px; height: 24px; animation: spin 0.8s linear infinite;"></div>
                Loading notifications...
            </div>
        }
        else if (!notifications.Any())
        {
            <div style="padding: 4rem 2rem; text-align: center; color: var(--text-secondary); font-family: 'Plus Jakarta Sans', sans-serif;">
                <svg viewBox="0 0 24 24" width="48" height="48" stroke="currentColor" stroke-width="1.5" fill="none" style="margin-bottom: 1.25rem; color: var(--text-muted);"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                <p style="font-weight: 700; font-size: 1.1rem; margin-bottom: 0.25rem; color: var(--text-primary);">All caught up!</p>
                <p style="font-size: 0.88rem; color: var(--text-muted); margin: 0;">No new notifications for you right now.</p>
            </div>
        }
        else
        {
            <div class="notification-list">
                @foreach (var notification in notifications)
                {
                    <div class="notification-item @(notification.IsRead ? "" : "unread")" @onclick="() => NavigateToPost(notification)" title="Click to view post">
                        <div class="notification-avatar">
                            @if (!string.IsNullOrEmpty(notification.TriggerUser.ProfilePicturePath))
                            {
                                <img src="@notification.TriggerUser.ProfilePicturePath" alt="Avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="avatar-circle" style="width: 40px; height: 40px; border-radius: 50%; background: #eef2ff; color: var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; border: 1px solid rgba(79, 70, 229, 0.2);">
                                    @GetInitials(notification.TriggerUser.FullName ?? notification.TriggerUser.Email ?? "U")
                                </div>
                            }
                        </div>
                        <div class="notification-content">
                            <div class="notification-text">
                                <span class="user-name">@(notification.TriggerUser.FullName ?? notification.TriggerUser.Email ?? "Someone")</span>
                                @if (notification.Type == "Reaction")
                                {
                                    <span> liked your post: </span>
                                }
                                else if (notification.Type == "Comment")
                                {
                                    <span> commented on your post: </span>
                                }
                                <span class="post-snippet">"@GetSnippet(notification.FeedPost.Content)"</span>
                            </div>
                            <div class="notification-time">
                                @GetRelativeTime(notification.CreatedAt)
                            </div>
                        </div>
                        @if (!notification.IsRead)
                        {
                            <div class="unread-dot-container">
                                <span class="unread-dot"></span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .notifications-container {
        max-width: 680px;
        margin: 0 auto;
    }

    .notification-list {
        display: flex;
        flex-direction: column;
    }

    .notification-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        cursor: pointer;
        transition: var(--transition-smooth);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .notification-item:last-child {
        border-bottom: none;
    }

    .notification-item:hover {
        background-color: rgba(99, 102, 241, 0.03);
    }

    .notification-item.unread {
        background-color: rgba(99, 102, 241, 0.05);
    }

    .notification-item.unread:hover {
        background-color: rgba(99, 102, 241, 0.08);
    }

    .notification-avatar {
        flex-shrink: 0;
    }

    .notification-content {
        flex-grow: 1;
        min-width: 0;
    }

    .notification-text {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .user-name {
        font-weight: 700;
        color: var(--text-primary);
    }

    .post-snippet {
        color: var(--text-muted);
        font-style: italic;
    }

    .notification-time {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }

    .unread-dot-container {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .unread-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: var(--primary);
        display: inline-block;
    }
</style>

@code {
    [Parameter] public string CurrentRole { get; set; } = "";

    private List<Notification>? notifications;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(currentUserId))
            {
                MainSchoolsManagementSystem.Features.Notifications.Services.NotificationService.OnNotificationReceived += HandleNotificationReceived;
                await LoadNotificationsAsync();
                
                // Automatically mark all as read on load
                await NotificationService.MarkAllAsReadAsync(currentUserId);
            }
        }
    }

    private async Task LoadNotificationsAsync()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;
        notifications = await NotificationService.GetNotificationsForUserAsync(currentUserId);
    }

    private async Task MarkAllAsRead()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;
        await NotificationService.MarkAllAsReadAsync(currentUserId);
        await LoadNotificationsAsync();
    }

    private async Task NavigateToPost(Notification notification)
    {
        await NotificationService.MarkAsReadAsync(notification.Id);
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/feed/post/{notification.FeedPostId}");
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        return name.Substring(0, 1).ToUpper();
    }

    private string GetSnippet(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return content.Length > 60 ? content.Substring(0, 57) + "..." : content;
    }

    private string GetRelativeTime(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} minutes ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hours ago";
        return $"{(int)span.TotalDays} days ago";
    }

    private void HandleNotificationReceived(string recipientId)
    {
        if (recipientId == currentUserId)
        {
            InvokeAsync(async () =>
            {
                await LoadNotificationsAsync();
                StateHasChanged();
            });
        }
    }

    public void Dispose()
    {
        MainSchoolsManagementSystem.Features.Notifications.Services.NotificationService.OnNotificationReceived -= HandleNotificationReceived;
    }
}
