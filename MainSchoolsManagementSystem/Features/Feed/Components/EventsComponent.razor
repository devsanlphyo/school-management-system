@using MainSchoolsManagementSystem.Features.Admin.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<MainSchoolsManagementSystem.Data.ApplicationDbContext> DbContextFactory

<div class="events-page">
    <div class="events-page-header">
        <div class="events-page-title-row">
            <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary); flex-shrink: 0;">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <h1 class="events-page-heading">Active Announcements</h1>
        </div>
        <p class="events-page-subtitle">All current school-wide announcements from the administration.</p>
    </div>

    @if (announcements == null)
    {
        <div class="glass-panel" style="padding: 2rem; text-align: center; color: var(--text-muted);">
            <p>Loading announcements...</p>
        </div>
    }
    else if (!announcements.Any())
    {
        <div class="glass-panel events-empty-state">
            <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none" style="color: var(--text-muted); margin-bottom: 1rem;">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <p style="font-weight: 600; font-size: 1rem; color: var(--text-secondary); margin: 0;">No active announcements</p>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0.25rem 0 0;">Check back later for updates from the administration.</p>
        </div>
    }
    else
    {
        <div class="events-list">
            @foreach (var a in announcements)
            {
                <div class="event-card event-card-@(a.Type.ToLower())">
                    <div class="event-card-icon-col">
                        <div class="event-type-icon event-icon-@(a.Type.ToLower())">
                            @if (a.Type == "Warning")
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                            }
                            else if (a.Type == "Error")
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                            }
                            else if (a.Type == "Success")
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                            }
                        </div>
                    </div>
                    <div class="event-card-body">
                        <div class="event-card-top">
                            <span class="event-type-badge event-badge-@(a.Type.ToLower())">@a.Type</span>
                            <span class="event-date">
                                @a.StartDate.ToLocalTime().ToString("MMM d") – @a.EndDate.ToLocalTime().ToString("MMM d, yyyy")
                            </span>
                        </div>
                        <p class="event-message">@a.Message</p>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<SystemAnnouncement>? announcements;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbContextFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;
        announcements = await db.SystemAnnouncements
            .Where(a => a.IsActive && a.StartDate <= now && a.EndDate >= now)
            .OrderByDescending(a => a.CreatedAt)
            .ToListAsync();
    }
}
