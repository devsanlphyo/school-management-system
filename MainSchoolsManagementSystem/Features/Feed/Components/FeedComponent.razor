@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using MainSchoolsManagementSystem.Features.Users.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IFeedService FeedService
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<MainSchoolsManagementSystem.Data.ApplicationDbContext> DbContextFactory
@inject UserManager<ApplicationUser> UserManager
@inject MainSchoolsManagementSystem.Features.Users.Services.IUserService UserService
<div class="feed-container">
  @if (activeAnnouncements != null && activeAnnouncements.Any(a => !dismissedAnnouncementIds.Contains(a.Id)))
  {
      <div class="system-announcements">
          @foreach (var announcement in activeAnnouncements.Where(a => !dismissedAnnouncementIds.Contains(a.Id)))
          {
              <div class="announcement-banner announcement-banner-@(announcement.Type.ToLower())">
                  <div class="announcement-icon">
                      @if (announcement.Type == "Warning")
                      {
                          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                      }
                      else if (announcement.Type == "Error")
                      {
                          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                      }
                      else if (announcement.Type == "Success")
                      {
                          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                      }
                      else
                      {
                          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                      }
                  </div>
                  <div class="announcement-text">@announcement.Message</div>
                  <button class="announcement-dismiss-btn"
                          @onclick="() => DismissAnnouncement(announcement.Id)"
                          title="Dismiss — you can re-read this in Events">
                      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </button>
              </div>
          }
      </div>
  }

  <div class="create-post-card">
    <div class="create-post-top-row">
      <div class="feed-avatar" @onclick="NavigateToCreate">
          @if (!string.IsNullOrEmpty(CurrentUserProfilePicturePath))
          {
              <img src="@CurrentUserProfilePicturePath" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" alt="User Avatar" />
          }
          else
          {
              @AvatarInitials
          }
      </div>
      <div class="feed-create-input" @onclick="NavigateToCreate">What's on your mind?</div>
    </div>
  </div>
  
  <Microsoft.AspNetCore.Components.Sections.SectionContent SectionName="top-navbar-center">
      <div class="feed-search-wrapper">
          <div class="feed-search-bar">
              <svg class="feed-search-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              <input type="text"
                     @bind="searchQuery"
                     @bind:event="oninput"
                     placeholder="Search users..."
                     class="feed-search-input" />
              @if (!string.IsNullOrWhiteSpace(searchQuery))
              {
                  <button class="feed-search-clear" @onclick="() => searchQuery = string.Empty" tabindex="-1" title="Clear">
                      <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2.5" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </button>
              }
          </div>

          @if (!string.IsNullOrWhiteSpace(searchQuery))
          {
              <div class="feed-search-dropdown">
                  @if (matchingUsers.Any())
                  {
                      @foreach (var user in matchingUsers)
                      {
                          <div class="search-dropdown-item" @onclick="() => NavigateToProfile(user.Id)">
                              <div class="feed-avatar" style="width: 32px; height: 32px; border-radius: 50%; font-size: 0.85rem; flex-shrink: 0; background: #eef2ff; color: var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 700; border: 1px solid rgba(79, 70, 229, 0.2);">
                                  @if (!string.IsNullOrEmpty(user.ProfilePicturePath))
                                  {
                                      <img src="@user.ProfilePicturePath" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                                  }
                                  else
                                  {
                                      @GetInitials(user.FullName ?? user.Email ?? "U")
                                  }
                              </div>
                              <div style="display: flex; flex-direction: column; flex: 1; min-width: 0;">
                                  <span style="font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">@user.FullName</span>
                                  <span style="font-size: 0.75rem; color: var(--text-muted); text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">@user.Email</span>
                              </div>
                          </div>
                      }
                  }
                  else
                  {
                      <div style="padding: 1rem; text-align: center; color: var(--text-muted); font-size: 0.88rem;">
                          No users found matching &quot;@searchQuery&quot;
                      </div>
                  }
              </div>
          }
      </div>
  </Microsoft.AspNetCore.Components.Sections.SectionContent>


  @if (posts == null)
  {
      <div class="glass-panel" style="padding: 2rem; text-align: center; color: var(--text-muted);">
          <p>Loading feed...</p>
      </div>
  }
  else if (!FilteredPosts.Any())
  {
      <div class="glass-panel" style="padding: 3rem; text-align: center; color: var(--text-secondary);">
          <svg viewBox="0 0 24 24" width="48" height="48" stroke="currentColor" stroke-width="1.5" fill="none" style="margin-bottom: 1rem; color: var(--text-muted);"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          <p style="font-weight: 600; font-size: 1.1rem; margin-bottom: 0.25rem;">No posts found</p>
          <p style="font-size: 0.88rem; color: var(--text-muted); margin: 0;">Try adjusting your search criteria or post something new!</p>
      </div>
  }
  else
  {
      <div class="posts-list">
          @foreach (var post in FilteredPosts)
          {
              <div class="post-card" id="post-@post.Id">
                  <!-- Post Header -->
                  <div class="post-header">
                      <div class="post-author-avatar" @onclick="() => NavigateToProfile(post.AuthorId)" style="cursor: pointer;" title="View Profile">
                          @if (!string.IsNullOrEmpty(post.Author?.ProfilePicturePath))
                          {
                              <img src="@post.Author.ProfilePicturePath" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" alt="Author Avatar" />
                          }
                          else
                          {
                              @GetInitials(post.Author?.FullName ?? post.Author?.Email ?? "U")
                          }
                      </div>
                      <div class="post-author-info">
                          <div class="post-author-name-row">
                              <span class="post-author-name" @onclick="() => NavigateToProfile(post.AuthorId)" style="cursor: pointer;" title="View Profile">@(post.Author?.FullName ?? post.Author?.Email ?? "User")</span>
                              @if (userRoles.TryGetValue(post.AuthorId, out var role))
                              {
                                  <span class="role-badge role-@role.ToLower()">@role</span>
                              }
                          </div>
                          <div class="post-meta-info">
                              <span class="post-time" title="View details (@post.CreatedAt.ToLocalTime().ToString("g"))" @onclick="() => NavigateToPostDetail(post.Id)" style="cursor: pointer; text-decoration: underline;">@GetRelativeTime(post.CreatedAt)</span>
                              <span class="post-meta-divider">•</span>
                              <span class="post-visibility" title="@post.Visibility.ToString()">
                                  @if (post.Visibility == PostVisibility.Public)
                                  {
                                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                  }
                                  else
                                  {
                                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                  }
                                  <span style="margin-left: 2px; vertical-align: middle;">@post.Visibility</span>
                              </span>
                          </div>
                      </div>
                      @if (post.AuthorId == currentUserId)
                      {
                          <div class="post-menu-container">
                              <button class="post-menu-btn" @onclick="() => TogglePostMenu(post.Id)" title="More options">
                                  <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><circle cx="12" cy="5" r="1.5"></circle><circle cx="12" cy="12" r="1.5"></circle><circle cx="12" cy="19" r="1.5"></circle></svg>
                              </button>
                              @if (openPostMenus.Contains(post.Id))
                              {
                                  <div class="post-dropdown-menu">
                                      <button class="dropdown-item edit" @onclick="() => NavigateToEdit(post.Id)">
                                          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" style="margin-right: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                          <span>Edit Post</span>
                                      </button>
                                      <button class="dropdown-item delete" @onclick="() => ConfirmDeletePost(post)">
                                          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" style="margin-right: 0.5rem;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                          <span>Delete Post</span>
                                      </button>
                                  </div>
                              }
                          </div>
                      }
                  </div>

                  <!-- Post Content -->
                  <div class="post-content">
                      @post.Content
                  </div>
                  
                  @if (post.MediaItems != null && post.MediaItems.Any())
                  {
                      <div class="media-preview-container" style="margin-top: 1rem; margin-bottom: 1rem;">
                          <div class="media-preview-grid count-@Math.Min(4, post.MediaItems.Count)">
                              @foreach (var media in post.MediaItems.OrderBy(m => m.SortOrder).Take(4))
                              {
                                  <div class="preview-item">
                                      @if (media.ContentType != null && media.ContentType.StartsWith("image/"))
                                      {
                                          <img src="/api/feed/media/@media.StoredFileName/view" class="preview-image" @onclick="() => OpenLightbox(media.StoredFileName)" style="cursor: pointer;" />
                                      }
                                      else if (media.ContentType != null && media.ContentType.StartsWith("video/"))
                                      {
                                          <video src="/api/feed/media/@media.StoredFileName/view" class="preview-video" muted controls></video>
                                      }
                                  </div>
                              }
                          </div>
                      </div>
                  }

                  <!-- Post Stats -->
                  <div class="post-stats-row">
                      <div class="post-stats-likes">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="#E02424" stroke="#E02424" style="display: inline-block; vertical-align: middle;"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                          <span style="margin-left: 4px; vertical-align: middle;">@post.Reactions.Count @(post.Reactions.Count == 1 ? "like" : "likes")</span>
                      </div>
                      <div class="post-stats-comments" @onclick="() => ToggleComments(post.Id)" style="cursor: pointer;">
                          <span>@post.Comments.Count @(post.Comments.Count == 1 ? "comment" : "comments")</span>
                      </div>
                  </div>

                  <!-- Post Actions Bar -->
                  <div class="post-actions-bar">
                      @{
                          bool hasReacted = post.Reactions.Any(r => r.UserId == currentUserId);
                      }
                      <button class="post-action-btn like @(hasReacted ? "active" : "")" @onclick="() => ToggleLove(post)">
                          @if (hasReacted)
                          {
                              <svg width="20" height="20" viewBox="0 0 24 24" fill="#E02424" stroke="none"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                              <span style="color: #E02424;">Liked</span>
                          }
                          else
                          {
                              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                              <span>Like</span>
                          }
                      </button>
                      <button class="post-action-btn comment" @onclick="() => ToggleComments(post.Id)">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                          <span>Comment</span>
                      </button>
                  </div>

                  <!-- Comment Section -->
                  @if (openCommentSections.Contains(post.Id))
                  {
                      <div class="comments-section-container">
                          <div class="comments-divider"></div>
                          <div class="comments-list">
                              @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                              {
                                  <div class="comment-item">
                                      <div class="comment-author-avatar" @onclick="() => NavigateToProfile(comment.AuthorId)" style="cursor: pointer;" title="View Profile">
                                          @if (!string.IsNullOrEmpty(comment.Author?.ProfilePicturePath))
                                          {
                                              <img src="@comment.Author.ProfilePicturePath" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" alt="Commenter Avatar" />
                                          }
                                          else
                                          {
                                              @GetInitials(comment.Author?.FullName ?? comment.Author?.Email ?? "C")
                                          }
                                      </div>
                                      <div class="comment-content-container">
                                          @if (editingCommentId == comment.Id)
                                          {
                                              <div class="comment-edit-box">
                                                  <input type="text" class="new-comment-input" @bind="editingCommentText" @onkeydown="@(async e => { if (e.Key == "Enter") await SubmitEditComment(comment.Id); })" style="width: 100%; margin-bottom: 0.5rem;" />
                                                  <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                                      <button class="btn-premium" style="padding: 0.2rem 0.6rem; font-size: 0.8rem;" @onclick="CancelEditComment">Cancel</button>
                                                      <button class="btn-premium btn-primary-custom" style="padding: 0.2rem 0.6rem; font-size: 0.8rem;" @onclick="() => SubmitEditComment(comment.Id)">Save</button>
                                                  </div>
                                              </div>
                                          }
                                          else
                                          {
                                              <div class="comment-bubble">
                                                  <div class="comment-author-header">
                                                      <span class="comment-author-name" @onclick="() => NavigateToProfile(comment.AuthorId)" style="cursor: pointer;" title="View Profile">@(comment.Author?.FullName ?? comment.Author?.Email ?? "User")</span>
                                                      @if (userRoles.TryGetValue(comment.AuthorId, out var cRole))
                                                      {
                                                          <span class="role-badge role-@cRole.ToLower()">@cRole</span>
                                                      }
                                                  </div>
                                                  <p class="comment-text">@comment.Content</p>
                                              </div>
                                              <div class="comment-meta">
                                                  <span class="comment-time">@GetRelativeTime(comment.CreatedAt)</span>
                                                  @if (comment.AuthorId == currentUserId || post.AuthorId == currentUserId)
                                                  {
                                                      <span class="comment-meta-divider">•</span>
                                                      <button class="comment-delete-link" @onclick="() => ConfirmDeleteComment(comment)">Delete</button>
                                                  }
                                                  @if (comment.AuthorId == currentUserId)
                                                  {
                                                      <span class="comment-meta-divider">•</span>
                                                      <button class="comment-delete-link" @onclick="() => StartEditComment(comment)">Edit</button>
                                                  }
                                              </div>
                                          }
                                      </div>
                                  </div>
                              }
                          </div>

                          <!-- New Comment Box -->
                          <div class="new-comment-box">
                              <div class="new-comment-avatar">
                                  @if (!string.IsNullOrEmpty(CurrentUserProfilePicturePath))
                                  {
                                      <img src="@CurrentUserProfilePicturePath" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" alt="Your Avatar" />
                                  }
                                  else
                                  {
                                      @AvatarInitials
                                  }
                              </div>
                              <div class="new-comment-input-row">
                                  <input type="text" class="new-comment-input" placeholder="Write a comment..." @bind="newCommentText[post.Id]" @bind:event="oninput" @onkeydown="@(async e => { if (e.Key == "Enter") await SubmitComment(post); })" />
                                  <button class="new-comment-send-btn" @onclick="() => SubmitComment(post)" disabled="@(string.IsNullOrWhiteSpace(newCommentText[post.Id]))" title="Post comment" style="display: flex; align-items: center; gap: 4px; padding: 0 12px; width: auto; border-radius: 16px;">
                                      <span>Post</span>
                                      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                                  </button>
                              </div>
                          </div>
                      </div>
                  }
              </div>
          }
      </div>
  }
</div>

@if (showDeleteConfirmation)
{
    <div class="confirm-modal-backdrop" @onclick="CancelDelete">
        <div class="confirm-modal-card" @onclick:stopPropagation>
            <div class="confirm-modal-header">
                <h3>Confirm Delete</h3>
            </div>
            <div class="confirm-modal-body">
                <p>@deleteConfirmationMessage</p>
            </div>
            <div class="confirm-modal-actions">
                <button class="confirm-btn cancel" @onclick="CancelDelete">Cancel</button>
                <button class="confirm-btn delete" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
}

@if (activeLightboxImage != null)
{
    <div class="confirm-modal-backdrop" @onclick="CloseLightbox" style="background: rgba(0,0,0,0.85); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div style="position: relative; max-width: 90%; max-height: 90%;" @onclick:stopPropagation>
            <button @onclick="CloseLightbox" style="position: absolute; right: -40px; top: -40px; background: none; border: none; color: white; font-size: 2rem; cursor: pointer;">
                <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2.5" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <img src="/api/feed/media/@activeLightboxImage/view" style="max-width: 100%; max-height: 80vh; object-fit: contain; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.5);" />
        </div>
    </div>
}



@code {
    [Parameter] public string CurrentRole { get; set; } = "";
    
    private string AvatarInitials = "U";
    private string? CurrentUserProfilePicturePath;
    private List<FeedPost>? posts;
    private string searchQuery = "";
    
    private IEnumerable<FeedPost> FilteredPosts => posts ?? Enumerable.Empty<FeedPost>();

    private List<UserDisplayDto> allUsers = new();
    private List<UserDisplayDto> matchingUsers => 
        string.IsNullOrWhiteSpace(searchQuery)
        ? new List<UserDisplayDto>()
        : allUsers.Where(u => 
            (u.FullName != null && u.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) ||
            (u.Email != null && u.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        ).Take(10).ToList();

    private List<MainSchoolsManagementSystem.Features.Admin.Models.SystemAnnouncement>? activeAnnouncements;
    private HashSet<int> dismissedAnnouncementIds = new();
    private int activeAnnouncementCount => activeAnnouncements?.Count(a => !dismissedAnnouncementIds.Contains(a.Id)) ?? 0;
    private string? currentUserId;
    private HashSet<int> openCommentSections = new HashSet<int>();
    private Dictionary<int, string> newCommentText = new Dictionary<int, string>();
    private Dictionary<string, string> userRoles = new Dictionary<string, string>();
    
    private HashSet<int> openPostMenus = new HashSet<int>();
    private bool showDeleteConfirmation = false;
    private string deleteConfirmationMessage = "";
    private Func<Task>? pendingDeleteAction = null;
    
    private int? editingCommentId = null;
    private string editingCommentText = "";

    private void StartEditComment(FeedPostComment comment)
    {
        editingCommentId = comment.Id;
        editingCommentText = comment.Content;
    }

    private void CancelEditComment()
    {
        editingCommentId = null;
        editingCommentText = "";
    }

    private async Task SubmitEditComment(int commentId)
    {
        if (string.IsNullOrWhiteSpace(editingCommentText)) return;

        await FeedService.UpdateCommentAsync(commentId, editingCommentText);
        editingCommentId = null;
        editingCommentText = "";
        await LoadPostsAsync();
    }


    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var appUser = await UserManager.GetUserAsync(user);
            var name = appUser?.FullName ?? user.Identity.Name ?? "U";
            AvatarInitials = GetInitials(name);
            CurrentUserProfilePicturePath = appUser?.ProfilePicturePath;
            await LoadAnnouncementsAsync();
            await LoadPostsAsync();
            allUsers = await UserService.GetUsersByRolesAsync(new List<string> { "Teacher", "Headmaster", "Director", "Officer", "Assistant", "Admin" });
        }
    }

    private async Task LoadAnnouncementsAsync()
    {
        using var db = await DbContextFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;
        activeAnnouncements = await db.SystemAnnouncements
            .Where(a => a.IsActive && a.StartDate <= now && a.EndDate >= now)
            .OrderByDescending(a => a.CreatedAt)
            .ToListAsync();
    }

    private string GetAnnouncementColor(string type)
    {
        return type switch
        {
            "Warning" => "linear-gradient(135deg, #f59e0b, #d97706)",
            "Error" => "linear-gradient(135deg, #ef4444, #dc2626)",
            "Success" => "linear-gradient(135deg, #10b981, #059669)",
            _ => "linear-gradient(135deg, #3b82f6, #2563eb)" // Info
        };
    }

    private void DismissAnnouncement(int id)
    {
        dismissedAnnouncementIds.Add(id);
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        return name.Substring(0, 1).ToUpper();
    }

    private string GetRelativeTime(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} minutes ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hours ago";
        return $"{(int)span.TotalDays} days ago";
    }

    private async Task LoadPostsAsync()
    {
        posts = await FeedService.GetAllPostsAsync();
            
        foreach(var p in posts)
        {
            if (!newCommentText.ContainsKey(p.Id)) newCommentText[p.Id] = "";
        }

        var userIds = posts.Select(p => p.AuthorId).Concat(posts.SelectMany(p => p.Comments.Select(c => c.AuthorId))).Distinct().ToList();
        if (userIds.Any())
        {
            userRoles = await FeedService.GetUserRolesForFeedAsync(userIds);
        }


    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/feed/create");
    }

    private void ToggleComments(int postId)
    {
        if (openCommentSections.Contains(postId)) openCommentSections.Remove(postId);
        else openCommentSections.Add(postId);
    }

    private async Task ToggleLove(FeedPost post)
    {
        if (currentUserId == null) return;
        
        await FeedService.ToggleReactionAsync(post.Id, currentUserId);
        await LoadPostsAsync();
    }

    private async Task SubmitComment(FeedPost post)
    {
        if (currentUserId == null) return;
        var text = newCommentText[post.Id];
        if (string.IsNullOrWhiteSpace(text)) return;

        await FeedService.AddCommentAsync(post.Id, currentUserId, text);

        newCommentText[post.Id] = "";
        await LoadPostsAsync();
    }

    private void TogglePostMenu(int postId)
    {
        if (openPostMenus.Contains(postId)) openPostMenus.Remove(postId);
        else openPostMenus.Add(postId);
    }

    private void NavigateToEdit(int postId)
    {
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/feed/edit/{postId}");
    }

    private void ConfirmDeletePost(FeedPost post)
    {
        deleteConfirmationMessage = "Are you sure you want to delete this post? This action cannot be undone.";
        pendingDeleteAction = async () => 
        {
            await FeedService.DeletePostAsync(post.Id);
            await LoadPostsAsync();
        };
        showDeleteConfirmation = true;
        openPostMenus.Remove(post.Id);
    }

    private void ConfirmDeleteComment(FeedPostComment comment)
    {
        deleteConfirmationMessage = "Are you sure you want to delete this comment? This action cannot be undone.";
        pendingDeleteAction = async () => 
        {
            await FeedService.DeleteCommentAsync(comment.Id);
            await LoadPostsAsync();
        };
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        pendingDeleteAction = null;
    }

    private async Task ConfirmDelete()
    {
        if (pendingDeleteAction != null)
        {
            await pendingDeleteAction();
        }
        showDeleteConfirmation = false;
        pendingDeleteAction = null;
    }



    private void NavigateToProfile(string userId)
    {
        if (string.IsNullOrEmpty(userId)) return;
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/profile/{userId}");
    }

    private void NavigateToPostDetail(int postId)
    {
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/feed/post/{postId}");
    }

