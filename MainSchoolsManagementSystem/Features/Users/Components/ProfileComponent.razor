@using Microsoft.AspNetCore.Identity
@using MainSchoolsManagementSystem.Data
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.EntityFrameworkCore
@using MainSchoolsManagementSystem.Features.Feed.Models
@using MainSchoolsManagementSystem.Features.Feed.Services
@using System.Security.Claims
@inject IServiceProvider ServiceProvider
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IFeedService FeedService
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@inject IJSRuntime JSRuntime
<div style="width: 100%; max-width: 1200px; margin: 0 auto; padding-bottom: 3rem;">
    
    @if (!isLoaded)
    {
        <div class="glass-panel" style="padding: 5rem 3rem; text-align: center; color: var(--text-muted); max-width: 600px; margin: 3rem auto; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.5rem;">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p style="font-size: 1rem; font-weight: 600;">Loading profile...</p>
        </div>
    }
    else if (currentUser == null)
    {
        <div class="glass-panel" style="padding: 4rem 3rem; text-align: center; color: var(--text-muted); max-width: 600px; margin: 3rem auto; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.25rem; border-top: 4px solid var(--danger); border-radius: 20px;">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <h3 style="font-size: 1.5rem; font-weight: 900; color: var(--text-primary); margin-top: 0.5rem; font-family: 'Outfit', sans-serif;">User Profile Not Found</h3>
            <p style="font-size: 0.95rem; line-height: 1.6; max-width: 450px; margin: 0 auto;">
                The requested user profile could not be found, or your login session is stale.
            </p>
            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button class="btn-premium btn-secondary-custom" @onclick='() => NavigationManager.NavigateTo("/")'>Go Home</button>
                <button class="btn-premium" style="text-decoration: none;" @onclick="ShowLogoutConfirm">Log Out & Re-login</button>
            </div>
        </div>
    }
    else
    {
        <!-- Modern Hero Cover Banner & Profile Header -->
        <div class="profile-hero-container" style="position: relative; margin-bottom: 3.5rem;">
            <div class="profile-cover-banner">
                <div style="position: absolute; inset: 0; background: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2280%22 height=%2280%22 viewBox=%220 0 80 80%22%3E%3Cg fill=%22%23fff%22 fill-opacity=%220.08%22%3E%3Cpath d=%22M0 0h40v40H0V0zm40 40h40v40H40V40z%22/%3E%3C/g%3E%3C/svg%3E'); opacity: 0.25;"></div>
            </div>
            
            <div class="profile-hero-avatar-wrap" style="display: flex; flex-direction: column; align-items: center; margin-top: -65px; position: relative; z-index: 2;">
                <div style="position: relative;">
                    <div class="profile-avatar-large" style="width: 130px; height: 130px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--accent-2)); color: white; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; font-weight: 800; border: 6px solid var(--bg-surface); box-shadow: var(--shadow-lg); user-select: none; transition: transform 0.3s ease; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePicturePath))
                        {
                            <img src="@currentUser.ProfilePicturePath" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />
                        }
                        else
                        {
                            @GetInitials(currentUser?.FullName ?? currentUser?.Email ?? "U")
                        }
                    </div>
                    @if (!isReadOnly)
                    {
                        <label class="avatar-upload-btn" style="position: absolute; bottom: 5px; right: 5px; background: var(--primary); color: white; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.2); transition: all 0.2s ease; z-index: 3;" title="Change Profile Picture">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                            <InputFile OnChange="UploadAvatar" accept=".png,.jpg,.jpeg" style="display: none;" />
                        </label>
                    }
                </div>
                @if (!string.IsNullOrEmpty(avatarUploadError))
                {
                    <div class="text-danger mt-2" style="font-size: 0.85rem; font-weight: 600;">@avatarUploadError</div>
                }
                <h2 style="font-size: 2.25rem; font-weight: 900; color: var(--text-primary); margin-top: 1rem; margin-bottom: 0.25rem; font-family: 'Outfit', sans-serif; letter-spacing: -0.5px;">
                    @(currentUser?.FullName ?? "User Name")
                </h2>
                <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 0.75rem; font-weight: 500;">
                    @currentUser?.Email
                </p>
                @if (!string.IsNullOrEmpty(userRole))
                {
                    <span class="role-badge role-@userRole.ToLower()" style="font-size: 0.8rem; padding: 0.4rem 1.25rem; border-radius: 30px; font-weight: 700; letter-spacing: 0.5px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">@userRole</span>
                }
            </div>
        </div>

        <!-- Two-Column Grid Layout -->
        <div class="profile-layout-grid">
            
            <!-- Left Column: Details & Settings -->
            <div class="profile-details-column" style="display: flex; flex-direction: column; gap: 1.75rem;">
                
                <div class="glass-panel" style="display: flex; flex-direction: column; gap: 2rem; padding: 2rem; border-radius: 20px;">
                    
                    <!-- School Information -->
                    <div>
                        <h3 style="font-size: 1.15rem; font-weight: 800; margin-bottom: 1.25rem; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem; font-family: 'Outfit', sans-serif;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
                            School Information
                        </h3>
                        
                        <div class="profile-info-item">
                            <span class="profile-info-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
                            </span>
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-size: 0.72rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">School Association</span>
                                <span style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">@schoolName</span>
                            </div>
                        </div>
                    </div>

                    <!-- Personal Information -->
                    <div>
                        <h3 style="font-size: 1.15rem; font-weight: 800; margin-bottom: 1.25rem; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem; font-family: 'Outfit', sans-serif;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            Personal Details
                        </h3>
                        
                        <EditForm Model="profileModel" OnValidSubmit="UpdateProfileAsync">
                            <DataAnnotationsValidator />
                            
                            <div class="form-group" style="margin-bottom: 1.25rem;">
                                <label class="form-label" style="font-size: 0.8rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">Full Name</label>
                                <InputText class="form-control-modern" @bind-Value="profileModel.FullName" placeholder="Enter your full name" disabled="@isReadOnly" />
                                @if (!isReadOnly)
                                {
                                    <ValidationMessage For="@(() => profileModel.FullName)" class="text-danger" style="font-size: 0.8rem; margin-top: 0.25rem; display: block;" />
                                }
                            </div>

                            <div class="form-group" style="margin-bottom: 1.5rem;">
                                <label class="form-label" style="font-size: 0.8rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">Email Address</label>
                                <InputText class="form-control-modern" @bind-Value="profileModel.Email" disabled style="background: rgba(0,0,0,0.02); opacity: 0.75;" />
                            </div>

                            @if (showSuccessAlert)
                            {
                                <div class="badge badge-green" style="padding: 0.75rem 1rem; border-radius: 12px; font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; width: 100%; margin-bottom: 1rem; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.15);">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                    Profile updated successfully!
                                </div>
                            }

                            @if (!isReadOnly)
                            {
                                <div style="display: flex; justify-content: flex-end;">
                                    <button type="submit" class="btn-premium" style="border-radius: 12px; padding: 0.7rem 1.5rem;">Save Details</button>
                                </div>
                            }
                        </EditForm>
                    </div>
                </div>
            </div>

            <!-- Right Column: User Posts -->
            <div class="profile-posts-column" style="display: flex; flex-direction: column; gap: 1.25rem;">
                @if (CurrentRole == "Admin")
                {
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.5rem; font-family: 'Outfit', sans-serif;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                        Administrative Overview
                    </h3>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1rem;">
                        <div class="glass-panel" style="padding: 2rem; border-radius: 20px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(59, 130, 246, 0.1); color: #3B82F6; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>
                            </div>
                            <h4 style="font-size: 2.5rem; font-weight: 900; color: var(--text-primary); margin: 0; line-height: 1;">@adminTotalSchools</h4>
                            <p style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 0.5rem;">Registered Schools</p>
                        </div>
                        
                        <div class="glass-panel" style="padding: 2rem; border-radius: 20px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(16, 185, 129, 0.1); color: #10B981; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                            </div>
                            <h4 style="font-size: 2.5rem; font-weight: 900; color: var(--text-primary); margin: 0; line-height: 1;">@adminTotalUsers</h4>
                            <p style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 0.5rem;">Total Users</p>
                        </div>
                    </div>

                    <div class="glass-panel" style="padding: 1.5rem; border-radius: 20px; margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                        <h4 style="font-size: 1rem; font-weight: 800; color: var(--text-primary); margin: 0;">Quick Actions</h4>
                        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                            <a href="/admin/users" class="btn-premium btn-secondary-custom" style="text-decoration: none; font-size: 0.85rem; padding: 0.6rem 1.2rem;">Manage Users</a>
                            <a href="/admin/schools" class="btn-premium btn-secondary-custom" style="text-decoration: none; font-size: 0.85rem; padding: 0.6rem 1.2rem;">Manage Schools</a>
                            <a href="/admin/settings" class="btn-premium btn-secondary-custom" style="text-decoration: none; font-size: 0.85rem; padding: 0.6rem 1.2rem;">System Settings</a>
                            <button @onclick="ExportSchoolsCsv" class="btn-premium btn-secondary-custom" style="font-size: 0.85rem; padding: 0.6rem 1.2rem;">Export Schools (CSV)</button>
                            <button @onclick="ExportUsersCsv" class="btn-premium btn-secondary-custom" style="font-size: 0.85rem; padding: 0.6rem 1.2rem;">Export Users (CSV)</button>
                        </div>
                    </div>

                    <!-- System Health & Storage -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1rem;">
                        <div class="glass-panel" style="padding: 1.5rem; border-radius: 20px; display: flex; flex-direction: column; gap: 0.75rem;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <h4 style="font-size: 1rem; font-weight: 800; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" color="#8B5CF6"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                                    System Status
                                </h4>
                                <span class="badge badge-green" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 10px;">Operational</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-top: 0.5rem;">
                                <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">Server Uptime</span>
                                <span style="font-size: 0.85rem; color: var(--text-primary); font-weight: 700;">@serverUptime</span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">Database Health</span>
                                <span style="font-size: 0.85rem; color: var(--text-primary); font-weight: 700;">@databaseHealth</span>
                            </div>
                        </div>

                        <div class="glass-panel" style="padding: 1.5rem; border-radius: 20px; display: flex; flex-direction: column; gap: 0.75rem;">
                            <h4 style="font-size: 1rem; font-weight: 800; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" color="#F59E0B"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
                                Storage Usage
                            </h4>
                            <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-top: 0.5rem;">
                                <span style="font-size: 1.5rem; font-weight: 900; color: var(--text-primary); line-height: 1;">@storageUsagePercent</span>
                                <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">@storageUsageText</span>
                            </div>
                            <div style="width: 100%; height: 8px; background: rgba(0,0,0,0.05); border-radius: 4px; overflow: hidden; margin-top: 0.25rem;">
                                <div style="height: 100%; width: @(storagePercentage.ToString(System.Globalization.CultureInfo.InvariantCulture))%; background: linear-gradient(90deg, #F59E0B, #FCD34D); border-radius: 4px;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Recently Onboarded Schools -->
                    <div class="glass-panel" style="padding: 1.5rem; border-radius: 20px; margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <h4 style="font-size: 1rem; font-weight: 800; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                Recently Onboarded Schools
                            </h4>
                            <a href="/admin/schools" style="font-size: 0.8rem; font-weight: 700; color: var(--primary); text-decoration: none;">View All</a>
                        </div>
                        
                        @if (recentSchools != null && recentSchools.Any())
                        {
                            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                @foreach (var school in recentSchools)
                                {
                                    <div style="display: flex; align-items: center; padding: 0.75rem; background: rgba(0,0,0,0.02); border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                                        <div style="width: 36px; height: 36px; border-radius: 10px; background: rgba(59, 130, 246, 0.1); color: #3B82F6; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1rem; margin-right: 1rem;">
                                            @GetInitials(school.Name)
                                        </div>
                                        <div style="display: flex; flex-direction: column;">
                                            <span style="font-size: 0.95rem; font-weight: 700; color: var(--text-primary);">@school.Name</span>
                                            <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 500;">School ID: #@school.Id</span>
                                        </div>
                                        <button class="btn-premium btn-secondary-custom" style="margin-left: auto; padding: 0.4rem 0.8rem; font-size: 0.75rem;" @onclick='() => NavigationManager.NavigateTo($"/admin/schools/{school.Id}")'>Manage</button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0; text-align: center; padding: 1rem 0;">No schools registered yet.</p>
                        }
                    </div>

                    <!-- System Announcements -->
                    <div class="glass-panel" style="padding: 1.5rem; border-radius: 20px; margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                        <h4 style="font-size: 1rem; font-weight: 800; color: var(--text-primary); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            Create System Announcement
                        </h4>
                        
                        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                            <input type="text" class="form-control" placeholder="Announcement Message" @bind="newAnnouncementMessage" style="background: var(--bg-body); color: var(--text-primary); border-color: rgba(0,0,0,0.1); border-radius: 8px; padding: 0.6rem;" />
                            <div style="display: flex; gap: 1rem;">
                                <select class="form-select" @bind="newAnnouncementType" style="flex: 1; background: var(--bg-body); color: var(--text-primary); border-color: rgba(0,0,0,0.1); border-radius: 8px;">
                                    <option value="Info">Info (Blue)</option>
                                    <option value="Success">Success (Green)</option>
                                    <option value="Warning">Warning (Orange)</option>
                                    <option value="Error">Error (Red)</option>
                                </select>
                                <select class="form-select" @bind="newAnnouncementDurationDays" style="flex: 1; background: var(--bg-body); color: var(--text-primary); border-color: rgba(0,0,0,0.1); border-radius: 8px;">
                                    <option value="1">1 Day</option>
                                    <option value="3">3 Days</option>
                                    <option value="7">1 Week</option>
                                </select>
                            </div>
                            <button class="btn-premium" @onclick="CreateAnnouncement" style="align-self: flex-start; margin-top: 0.5rem; font-size: 0.85rem; padding: 0.5rem 1rem;">Publish Announcement</button>
                            @if (!string.IsNullOrEmpty(announcementStatus))
                            {
                                <span style="font-size: 0.85rem; color: #10B981; font-weight: 600; margin-top: 0.25rem;">@announcementStatus</span>
                            }
                        </div>
                    </div>

                    <!-- Recent Error Logs -->
                    <div class="glass-panel" style="padding: 1.5rem; border-radius: 20px; margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                        <h4 style="font-size: 1rem; font-weight: 800; color: #EF4444; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            Recent Error Logs
                        </h4>
                        
                        @if (recentErrors != null && recentErrors.Any())
                        {
                            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                @foreach (var error in recentErrors)
                                {
                                    <div style="padding: 1rem; background: rgba(239, 68, 68, 0.05); border-left: 4px solid #EF4444; border-radius: 8px;">
                                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem; font-weight: 600;">@error.CreatedAt.ToLocalTime().ToString("g") - @error.RequestPath</div>
                                        <div style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary); word-break: break-all;">@error.ExceptionMessage</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="padding: 1.5rem; text-align: center; color: var(--text-muted); font-size: 0.9rem; font-weight: 500;">
                                No recent errors found. System is healthy.
                            </div>
                        }
                    </div>
                }
                else
                {
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.5rem; font-family: 'Outfit', sans-serif;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Posts Published
                    </h3>

                    @if (userPosts == null)
                {
                    <div class="glass-panel" style="padding: 4rem; text-align: center; color: var(--text-muted); border-radius: 20px;">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p style="margin-top: 1rem; font-size: 0.95rem;">Loading user's feed...</p>
                    </div>
                }
                else if (!userPosts.Any())
                {
                    <div class="glass-panel" style="padding: 5rem 2rem; text-align: center; color: var(--text-muted); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; border-radius: 20px;">
                        <svg width="54" height="54" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="9"></line><line x1="9" y1="13" x2="15" y2="13"></line><line x1="9" y1="17" x2="13" y2="17"></line></svg>
                        <p style="font-size: 1rem; font-weight: 600; color: var(--text-secondary);">No posts published yet</p>
                        <p style="font-size: 0.88rem; max-width: 320px; margin: 0 auto; color: var(--text-muted);">When this user writes updates, stories, or announcements, they will appear here.</p>
                    </div>
                }
                else
                {
                    <div class="posts-list" style="display: flex; flex-direction: column; gap: 1.5rem; width: 100%;">
                        @foreach (var post in userPosts)
                        {
                            <div class="post-card">
                                <!-- Post Header -->
                                <div class="post-header">
                                    <div class="post-author-avatar" @onclick="() => NavigateToProfile(post.AuthorId)" style="cursor: pointer;" title="View Profile">
                                        @GetInitials(post.Author?.FullName ?? post.Author?.Email ?? "U")
                                    </div>
                                    <div class="post-author-info">
                                        <div class="post-author-name-row">
                                            <span class="post-author-name" @onclick="() => NavigateToProfile(post.AuthorId)" style="cursor: pointer;" title="View Profile">@(post.Author?.FullName ?? post.Author?.Email ?? "User")</span>
                                            @if (userRoles.TryGetValue(post.AuthorId, out var role))
                                            {
                                                <span class="role-badge role-@role.ToLower()">@role</span>
                                            }
                                        </div>
                                        <div class="post-meta-info">
                                            <span class="post-time" title="@post.CreatedAt.ToLocalTime().ToString("g")">@GetRelativeTime(post.CreatedAt)</span>
                                            <span class="post-meta-divider">•</span>
                                            <span class="post-visibility" title="@post.Visibility.ToString()">
                                                @if (post.Visibility == PostVisibility.Public)
                                                {
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                                }
                                                else
                                                {
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                                }
                                                <span style="margin-left: 2px; vertical-align: middle;">@post.Visibility</span>
                                            </span>
                                        </div>
                                    </div>
                                    @if (post.AuthorId == currentUserId)
                                    {
                                        <div class="post-menu-container">
                                            <button class="post-menu-btn" @onclick="() => TogglePostMenu(post.Id)" title="More options">
                                                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><circle cx="12" cy="5" r="1.5"></circle><circle cx="12" cy="12" r="1.5"></circle><circle cx="12" cy="19" r="1.5"></circle></svg>
                                            </button>
                                            @if (openPostMenus.Contains(post.Id))
                                            {
                                                <div class="post-dropdown-menu">
                                                    <button class="dropdown-item edit" @onclick="() => NavigateToEdit(post.Id)">
                                                        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" style="margin-right: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                                        <span>Edit Post</span>
                                                    </button>
                                                    <button class="dropdown-item delete" @onclick="() => ConfirmDeletePost(post)">
                                                        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" style="margin-right: 0.5rem;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                                        <span>Delete Post</span>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <!-- Post Content -->
                                <div class="post-content">
                                    @post.Content
                                </div>

                                <!-- Post Stats -->
                                <div class="post-stats-row">
                                    <div class="post-stats-likes">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="#E02424" stroke="#E02424" style="display: inline-block; vertical-align: middle;"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                        <span style="margin-left: 4px; vertical-align: middle;">@post.Reactions.Count @(post.Reactions.Count == 1 ? "like" : "likes")</span>
                                    </div>
                                    <div class="post-stats-comments" @onclick="() => ToggleComments(post.Id)" style="cursor: pointer;">
                                        <span>@post.Comments.Count @(post.Comments.Count == 1 ? "comment" : "comments")</span>
                                    </div>
                                </div>

                                <!-- Post Actions Bar -->
                                <div class="post-actions-bar">
                                    @{
                                        bool hasReacted = post.Reactions.Any(r => r.UserId == currentUserId);
                                    }
                                    <button class="post-action-btn like @(hasReacted ? "active" : "")" @onclick="() => ToggleLove(post)">
                                        @if (hasReacted)
                                        {
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="#E02424" stroke="none"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                            <span style="color: #E02424;">Liked</span>
                                        }
                                        else
                                        {
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                            <span>Like</span>
                                        }
                                    </button>
                                    <button class="post-action-btn comment" @onclick="() => ToggleComments(post.Id)">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                                        <span>Comment</span>
                                    </button>
                                </div>

                                <!-- Comment Section -->
                                @if (openCommentSections.Contains(post.Id))
                                {
                                    <div class="comments-section-container">
                                        <div class="comments-divider"></div>
                                        <div class="comments-list">
                                            @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                                            {
                                                <div class="comment-item">
                                                    <div class="comment-author-avatar" @onclick="() => NavigateToProfile(comment.AuthorId)" style="cursor: pointer;" title="View Profile">
                                                        @GetInitials(comment.Author?.FullName ?? comment.Author?.Email ?? "C")
                                                    </div>
                                                    <div class="comment-content-container">
                                                        <div class="comment-bubble">
                                                            <div class="comment-author-header">
                                                                <span class="comment-author-name" @onclick="() => NavigateToProfile(comment.AuthorId)" style="cursor: pointer;" title="View Profile">@(comment.Author?.FullName ?? comment.Author?.Email ?? "User")</span>
                                                                @if (userRoles.TryGetValue(comment.AuthorId, out var cRole))
                                                                {
                                                                    <span class="role-badge role-@cRole.ToLower()">@cRole</span>
                                                                }
                                                            </div>
                                                            <p class="comment-text">@comment.Content</p>
                                                        </div>
                                                        <div class="comment-meta">
                                                            <span class="comment-time">@GetRelativeTime(comment.CreatedAt)</span>
                                                            @if (comment.AuthorId == currentUserId || post.AuthorId == currentUserId)
                                                            {
                                                                <span class="comment-meta-divider">•</span>
                                                                <button class="comment-delete-link" @onclick="() => ConfirmDeleteComment(comment)">Delete</button>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        <!-- New Comment Box -->
                                        <div class="new-comment-box">
                                            <div class="new-comment-avatar">@AvatarInitials</div>
                                            <div class="new-comment-input-row">
                                                <input type="text" class="new-comment-input" placeholder="Write a comment..." @bind="newCommentText[post.Id]" @onkeydown="@(async e => { if (e.Key == "Enter") await SubmitComment(post); })" />
                                                <button class="new-comment-send-btn" @onclick="() => SubmitComment(post)" disabled="@(string.IsNullOrWhiteSpace(newCommentText[post.Id]))" title="Post comment">
                                                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                }
            </div>
        </div>
    }
</div>

@if (showLogoutConfirm)
{
    <div class="confirm-modal-backdrop" @onclick="CancelLogout">
        <div class="confirm-modal-card" @onclick:stopPropagation>
            <div class="confirm-modal-header">
                <h3>Confirm Logout</h3>
            </div>
            <div class="confirm-modal-body">
                <p>Are you sure you want to log out?</p>
            </div>
            <div class="confirm-modal-actions">
                <button class="confirm-btn cancel" @onclick="CancelLogout">Cancel</button>
                <form action="/Account/Logout" method="post" style="display:inline; margin:0;">
                    <button type="submit" class="confirm-btn delete" style="background-color: var(--danger);">Logout</button>
                </form>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirmation)
{
    <div class="confirm-modal-backdrop" @onclick="CancelDelete">
        <div class="confirm-modal-card" @onclick:stopPropagation>
            <div class="confirm-modal-header">
                <h3>Confirm Delete</h3>
            </div>
            <div class="confirm-modal-body">
                <p>@deleteConfirmationMessage</p>
            </div>
            <div class="confirm-modal-actions">
                <button class="confirm-btn cancel" @onclick="CancelDelete">Cancel</button>
                <button class="confirm-btn delete" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? UserId { get; set; }
    [Parameter] public string CurrentRole { get; set; } = "";

    private ApplicationUser? currentUser;
    private string schoolName = "Loading...";
    private bool isReadOnly = false;
    private string userRole = "";
    private bool isLoaded = false;
    
    // Profile Model
    private ProfileModel profileModel = new();
    private bool showSuccessAlert = false;

    // Posts Feed
    private string AvatarInitials = "U";
    private string? currentUserId;
    private List<FeedPost>? userPosts;
    private HashSet<int> openCommentSections = new HashSet<int>();
    private Dictionary<int, string> newCommentText = new Dictionary<int, string>();
    private Dictionary<string, string> userRoles = new Dictionary<string, string>();
    private HashSet<int> openPostMenus = new HashSet<int>();
    
    private bool showDeleteConfirmation = false;
    private string deleteConfirmationMessage = "";
    private Func<Task>? pendingDeleteAction = null;
    
    private bool showLogoutConfirm = false;
    private void ShowLogoutConfirm() => showLogoutConfirm = true;
    private void CancelLogout() => showLogoutConfirm = false;
    
    // Admin Dashboard
    private int adminTotalSchools = 0;
    private int adminTotalUsers = 0;
    private List<MainSchoolsManagementSystem.Features.Schools.Models.School> recentSchools = new();
    private List<MainSchoolsManagementSystem.Features.Admin.Models.SystemErrorLog> recentErrors = new();
    
    // Announcement fields
    private string newAnnouncementMessage = "";
    private string newAnnouncementType = "Info";
    private int newAnnouncementDurationDays = 1;
    private string announcementStatus = "";
    
    // Real System Stats
    private string serverUptime = "Loading...";
    private string databaseHealth = "Checking...";
    private string storageUsagePercent = "0%";
    private string storageUsageText = "0 GB / 0 GB";
    private double storagePercentage = 0;
    
    private string? avatarUploadError;

    private async Task UploadAvatar(InputFileChangeEventArgs e)
    {
        if (currentUser == null) return;
        
        avatarUploadError = null;
        var file = e.File;
        if (file == null) return;

        var extension = System.IO.Path.GetExtension(file.Name)?.ToLowerInvariant() ?? "";
        if (extension != ".png" && extension != ".jpg" && extension != ".jpeg")
        {
            avatarUploadError = "Only image files (.png, .jpg, .jpeg) are allowed.";
            return;
        }

        if (file.Size > 2 * 1024 * 1024)
        {
            avatarUploadError = "Image size cannot exceed 2 MB.";
            return;
        }

        try
        {
            var uploadsFolder = System.IO.Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "profile-pictures");
            if (!System.IO.Directory.Exists(uploadsFolder)) System.IO.Directory.CreateDirectory(uploadsFolder);

            var uniqueFileName = Guid.NewGuid().ToString() + extension;
            var filePath = System.IO.Path.Combine(uploadsFolder, uniqueFileName);

            using (var stream = new System.IO.FileStream(filePath, System.IO.FileMode.Create))
            {
                await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(stream);
            }

            using var scope = ServiceProvider.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            var dbUser = await userManager.FindByIdAsync(currentUser.Id);
            if (dbUser != null)
            {
                if (!string.IsNullOrEmpty(dbUser.ProfilePicturePath) && !dbUser.ProfilePicturePath.EndsWith("default-avatar.png"))
                {
                    var oldPath = System.IO.Path.Combine(WebHostEnvironment.WebRootPath, dbUser.ProfilePicturePath.TrimStart('/'));
                    if (System.IO.File.Exists(oldPath)) System.IO.File.Delete(oldPath);
                }

                dbUser.ProfilePicturePath = $"/uploads/profile-pictures/{uniqueFileName}";
                await userManager.UpdateAsync(dbUser);
                currentUser.ProfilePicturePath = dbUser.ProfilePicturePath;
                
                await LoadPostsAsync(); // reload feed avatars
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            avatarUploadError = $"Failed to upload: {ex.Message}";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoaded = false;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                using var scope = ServiceProvider.CreateScope();
                var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
                var dbContextFactory = scope.ServiceProvider.GetRequiredService<IDbContextFactory<ApplicationDbContext>>();
                
                var loggedInUser = await userManager.GetUserAsync(user);
                if (loggedInUser != null)
                {
                    currentUserId = loggedInUser.Id;

                    var loggedInUserRoles = await userManager.GetRolesAsync(loggedInUser);
                    if (string.IsNullOrEmpty(CurrentRole))
                    {
                        CurrentRole = loggedInUserRoles.FirstOrDefault() ?? "teacher";
                    }

                    var name = loggedInUser.FullName ?? loggedInUser.Email ?? "U";
                    AvatarInitials = GetInitials(name);

                    if (!string.IsNullOrEmpty(UserId) && UserId != loggedInUser.Id)
                    {
                        isReadOnly = true;
                        currentUser = await userManager.FindByIdAsync(UserId);
                    }
                    else
                    {
                        isReadOnly = false;
                        currentUser = loggedInUser;
                    }

                    if (currentUser != null)
                    {
                        profileModel.FullName = currentUser.FullName ?? "";
                        profileModel.Email = currentUser.Email ?? "";
                        
                        var roles = await userManager.GetRolesAsync(currentUser);
                        userRole = roles.FirstOrDefault() ?? "";

                        using var db = await dbContextFactory.CreateDbContextAsync();
                        if (CurrentRole == "Admin")
                        {
                            schoolName = "Global System Administrator";
                            adminTotalSchools = await db.Schools.CountAsync();
                            adminTotalUsers = await db.Users.CountAsync();
                            recentSchools = await db.Schools.OrderByDescending(s => s.Id).Take(3).ToListAsync();
                            recentErrors = await db.SystemErrorLogs.OrderByDescending(e => e.CreatedAt).Take(3).ToListAsync();
                            
                            // Load real system stats
                            bool dbConnected = await db.Database.CanConnectAsync();
                            databaseHealth = dbConnected ? "Excellent" : "Failing";
                            
                            TimeSpan uptime = DateTime.Now - System.Diagnostics.Process.GetCurrentProcess().StartTime;
                            serverUptime = $"{(int)uptime.TotalDays}d {uptime.Hours}h {uptime.Minutes}m";
                            
                            try
                            {
                                var driveInfo = new System.IO.DriveInfo(System.IO.Directory.GetCurrentDirectory());
                                if (driveInfo.IsReady)
                                {
                                    long totalSpace = driveInfo.TotalSize;
                                    long freeSpace = driveInfo.TotalFreeSpace;
                                    long usedSpace = totalSpace - freeSpace;
                        
                                    storagePercentage = Math.Round((double)usedSpace / totalSpace * 100, 1);
                                    storageUsagePercent = $"{storagePercentage}%";
                                    storageUsageText = $"{usedSpace / (1024 * 1024 * 1024)} GB / {totalSpace / (1024 * 1024 * 1024)} GB";
                                }
                            }
                            catch
                            {
                                storageUsagePercent = "N/A";
                                storageUsageText = "Info unavailable";
                            }
                        }
                        else if (currentUser.SchoolId.HasValue)
                        {
                            var school = await db.Schools.FindAsync(currentUser.SchoolId.Value);
                            schoolName = school?.Name ?? "No School Associated";
                        }
                        else
                        {
                            schoolName = "No School Associated";
                        }

                        await LoadPostsAsync();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PROFILE ERROR] Exception in OnParametersSetAsync: {ex}");
        }
        finally
        {
            isLoaded = true;
        }
    }

    private async Task LoadPostsAsync()
    {
        if (currentUser == null) return;

        var allPosts = await FeedService.GetAllPostsAsync();
        
        if (isReadOnly)
        {
            userPosts = allPosts
                .Where(p => p.AuthorId == currentUser.Id && p.Visibility == PostVisibility.Public)
                .OrderByDescending(p => p.CreatedAt)
                .ToList();
        }
        else
        {
            userPosts = allPosts
                .Where(p => p.AuthorId == currentUser.Id)
                .OrderByDescending(p => p.CreatedAt)
                .ToList();
        }

        foreach(var p in userPosts)
        {
            if (!newCommentText.ContainsKey(p.Id)) newCommentText[p.Id] = "";
        }

        var userIds = userPosts.Select(p => p.AuthorId)
            .Concat(userPosts.SelectMany(p => p.Comments.Select(c => c.AuthorId)))
            .Distinct()
            .ToList();
            
        if (userIds.Any())
        {
            userRoles = await FeedService.GetUserRolesForFeedAsync(userIds);
        }
    }

    private void ToggleComments(int postId)
    {
        if (openCommentSections.Contains(postId)) openCommentSections.Remove(postId);
        else openCommentSections.Add(postId);
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        return name.Substring(0, 1).ToUpper();
    }

    private string GetRelativeTime(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} minutes ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hours ago";
        return $"{(int)span.TotalDays} days ago";
    }

    private async Task ToggleLove(FeedPost post)
    {
        if (currentUserId == null) return;
        
        await FeedService.ToggleReactionAsync(post.Id, currentUserId);
        await LoadPostsAsync();
    }

    private async Task SubmitComment(FeedPost post)
    {
        if (currentUserId == null) return;
        var text = newCommentText[post.Id];
        if (string.IsNullOrWhiteSpace(text)) return;

        await FeedService.AddCommentAsync(post.Id, currentUserId, text);

        newCommentText[post.Id] = "";
        await LoadPostsAsync();
    }

    private void TogglePostMenu(int postId)
    {
        if (openPostMenus.Contains(postId)) openPostMenus.Remove(postId);
        else openPostMenus.Add(postId);
    }

    private void NavigateToEdit(int postId)
    {
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/feed/edit/{postId}");
    }

    private void ConfirmDeletePost(FeedPost post)
    {
        deleteConfirmationMessage = "Are you sure you want to delete this post? This action cannot be undone.";
        pendingDeleteAction = async () => 
        {
            await FeedService.DeletePostAsync(post.Id);
            await LoadPostsAsync();
        };
        showDeleteConfirmation = true;
        openPostMenus.Remove(post.Id);
    }

    private void ConfirmDeleteComment(FeedPostComment comment)
    {
        deleteConfirmationMessage = "Are you sure you want to delete this comment? This action cannot be undone.";
        pendingDeleteAction = async () => 
        {
            await FeedService.DeleteCommentAsync(comment.Id);
            await LoadPostsAsync();
        };
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        pendingDeleteAction = null;
    }

    private async Task ConfirmDelete()
    {
        if (pendingDeleteAction != null)
        {
            await pendingDeleteAction();
        }
        showDeleteConfirmation = false;
        pendingDeleteAction = null;
    }

    private void NavigateToProfile(string userId)
    {
        if (string.IsNullOrEmpty(userId)) return;
        NavigationManager.NavigateTo($"/{CurrentRole.ToLower()}/profile/{userId}");
    }

    private async Task UpdateProfileAsync()
    {
        if (currentUser != null)
        {
            using var scope = ServiceProvider.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            
            var dbUser = await userManager.FindByIdAsync(currentUser.Id);
            if (dbUser != null)
            {
                dbUser.FullName = profileModel.FullName;
                var result = await userManager.UpdateAsync(dbUser);
                if (result.Succeeded)
                {
                    showSuccessAlert = true;
                    StateHasChanged();
                    await Task.Delay(1500);
                    showSuccessAlert = false;
                    StateHasChanged();
                    
                    NavigationManager.Refresh(true);
                }
            }
        }
    }

    public class ProfileModel
    {
        [Required(ErrorMessage = "Full Name is required.")]
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
    }

    private async Task ExportSchoolsCsv()
    {
        using var scope = ServiceProvider.CreateScope();
        var dbContextFactory = scope.ServiceProvider.GetRequiredService<IDbContextFactory<ApplicationDbContext>>();
        using var db = await dbContextFactory.CreateDbContextAsync();
        
        var schools = await db.Schools.ToListAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Id,Name");
        foreach(var s in schools)
        {
            sb.AppendLine($"{s.Id},\"{s.Name}\"");
        }
        
        await JSRuntime.InvokeVoidAsync("downloadFileFromText", "schools_export.csv", sb.ToString());
    }

    private async Task ExportUsersCsv()
    {
        using var scope = ServiceProvider.CreateScope();
        var dbContextFactory = scope.ServiceProvider.GetRequiredService<IDbContextFactory<ApplicationDbContext>>();
        using var db = await dbContextFactory.CreateDbContextAsync();
        
        var users = await db.Users.ToListAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Id,FullName,Email,SchoolId");
        foreach(var u in users)
        {
            sb.AppendLine($"{u.Id},\"{u.FullName}\",\"{u.Email}\",{u.SchoolId}");
        }
        
        await JSRuntime.InvokeVoidAsync("downloadFileFromText", "users_export.csv", sb.ToString());
    }

    private async Task CreateAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(newAnnouncementMessage)) return;
        
        using var scope = ServiceProvider.CreateScope();
        var dbContextFactory = scope.ServiceProvider.GetRequiredService<IDbContextFactory<ApplicationDbContext>>();
        using var db = await dbContextFactory.CreateDbContextAsync();
        
        var announcement = new MainSchoolsManagementSystem.Features.Admin.Models.SystemAnnouncement
        {
            Message = newAnnouncementMessage,
            Type = newAnnouncementType,
            StartDate = DateTime.UtcNow,
            EndDate = DateTime.UtcNow.AddDays(newAnnouncementDurationDays),
            IsActive = true
        };
        
        db.SystemAnnouncements.Add(announcement);
        await db.SaveChangesAsync();
        
        newAnnouncementMessage = "";
        announcementStatus = "Announcement published successfully!";
        StateHasChanged();
        
        await Task.Delay(3000);
        announcementStatus = "";
        StateHasChanged();
    }
}
