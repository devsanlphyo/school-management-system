@page "/admin/settings"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject MainSchoolsManagementSystem.Features.SystemSettings.Services.ISystemSettingService SystemSettingService
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@using System.IO

<PageTitle>Global System Settings — HelloTwo</PageTitle>

<div class="d-flex flex-column" style="max-width: 600px; gap: 2rem;">
    <!-- Header -->
    <div>
        <h2 style="font-size: 1.85rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.4rem;">System Settings</h2>
        <p style="color: var(--text-muted); font-size: 0.92rem;">Global configurations and system maintenance options.</p>
    </div>

    <!-- Settings Card -->
    <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.75rem; padding: 2rem;">
        
        <!-- Lesson Plan Policies Section -->
        <div>
            <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                Lesson Plan Policies
            </h3>
            
            <div class="form-group">
                <label class="form-label">Daily Submission Deadline</label>
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <input type="time" class="form-control-custom" style="width: 150px;" value="@deadlineString" @onchange="OnDeadlineChanged" />
                    <span style="font-size: 0.85rem; color: var(--text-secondary);">
                        Any lesson plan uploaded after this time will be flagged as <strong>Late</strong>.
                      </span>
                </div>
            </div>
        </div>

        <!-- System Maintenance Section -->
        <div style="margin-top: 1rem;">
            <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1.25rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                System Maintenance
            </h3>
            
            <!-- Toggle: Maintenance Mode -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0;">
                <div style="padding-right: 1.5rem;">
                    <div style="font-weight: 700; font-size: 0.9rem; color: var(--text-primary);">Maintenance Mode</div>
                    <p style="color: var(--text-muted); font-size: 0.78rem; margin-top: 0.25rem;">
                        Temporarily restrict access to the system for all non-admin users.
                    </p>
                </div>
                <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0;">
                    <input type="checkbox" @bind="maintenanceMode" style="opacity: 0; width: 0; height: 0;" />
                    <span class="slider" style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--border-2); border-radius: 34px; transition: .3s; @(maintenanceMode ? "background-color: var(--danger);" : "")">
                        <span style="position: absolute; content: ''; height: 16px; width: 16px; left: 4px; bottom: 4px; background-color: white; border-radius: 50%; transition: .3s; @(maintenanceMode ? "transform: translateX(20px);" : "")"></span>
                    </span>
                </label>
            </div>
        </div>

        <!-- Brand Settings Section -->
        <div style="margin-top: 1rem;">
            <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1.25rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                Brand Identity
            </h3>
            
            <div class="form-group" style="display: flex; flex-direction: column; gap: 0.75rem;">
                <label class="form-label">System Brand Logo</label>
                <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
                    <div style="width: 100px; height: 60px; border: 1px dashed var(--border-color); border-radius: 8px; display: flex; align-items: center; justify-content: center; background: var(--bg-base); overflow: hidden; padding: 4px;">
                        @if (!string.IsNullOrEmpty(brandLogoPath))
                        {
                            <img src="@brandLogoPath" alt="Brand Logo" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                        }
                        else
                        {
                            <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 500;">Default (Text)</span>
                        }
                    </div>
                    
                    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                        <div style="display: flex; gap: 0.5rem;">
                            <label class="btn-premium" style="font-size: 0.8rem; padding: 0.4rem 0.8rem; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; border-radius: 6px; margin: 0;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                Upload Logo
                                <InputFile OnChange="HandleLogoUpload" accept=".png,.jpg,.jpeg,.svg" style="display: none;" />
                            </label>
                            
                            @if (!string.IsNullOrEmpty(brandLogoPath))
                            {
                                <button class="btn-premium btn-secondary-custom" style="font-size: 0.8rem; padding: 0.4rem 0.8rem; color: var(--danger); border-color: rgba(239, 68, 68, 0.2);" @onclick="ResetBrandLogo" type="button">
                                    Remove
                                </button>
                            }
                        </div>
                        <span style="font-size: 0.72rem; color: var(--text-muted);">
                            Supports PNG, JPG, or SVG. Suggested height: 40px. Max size: 1MB.
                        </span>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(logoUploadError))
                {
                    <div class="text-danger" style="font-size: 0.78rem; font-weight: 600; margin-top: 0.25rem;">@logoUploadError</div>
                }
            </div>
        </div>

        <!-- Feedback alert -->
        @if (showSuccessAlert)
        {
            <div class="badge badge-green" style="padding: 0.75rem 1rem; border-radius: var(--radius-sm); font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; width: 100%;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                Settings saved successfully!
            </div>
        }

        <!-- Actions -->
        <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
            <button class="btn-premium btn-secondary-custom" @onclick="ResetSettings">Reset</button>
            <button class="btn-premium" @onclick="SaveSettings">Save Settings</button>
        </div>
    </div>

    <!-- Appearance Card -->
    <div class="glass-panel" style="display: flex; flex-direction: column; gap: 1.75rem; padding: 2rem;">
        <MainSchoolsManagementSystem.Components.Shared.ThemeSettings />
    </div>
</div>

@code {
    private SystemSetting? settings;
    private string deadlineString = "08:30";
    private bool maintenanceMode = false;
    private bool showSuccessAlert = false;

    protected override async Task OnInitializedAsync()
    {
        settings = await SystemSettingService.GetSettingsAsync();
        deadlineString = $"{settings.DailyDeadline.Hours:D2}:{settings.DailyDeadline.Minutes:D2}";
        maintenanceMode = settings.MaintenanceMode;
        UpdateLogoPath();
    }

    private void OnDeadlineChanged(ChangeEventArgs e)
    {
        deadlineString = e.Value?.ToString() ?? "08:30";
    }

    private async Task SaveSettings()
    {
        if (settings != null && TimeSpan.TryParse(deadlineString, out var parsedTime))
        {
            settings.DailyDeadline = parsedTime;
            settings.MaintenanceMode = maintenanceMode;
            await SystemSettingService.UpdateSettingsAsync(settings);

            showSuccessAlert = true;
            StateHasChanged();

            await Task.Delay(3000);
            showSuccessAlert = false;
            StateHasChanged();
        }
    }

    private void ResetSettings()
    {
        if (settings != null)
        {
            deadlineString = $"{settings.DailyDeadline.Hours:D2}:{settings.DailyDeadline.Minutes:D2}";
            maintenanceMode = settings.MaintenanceMode;
        }
        else
        {
            deadlineString = "08:30";
            maintenanceMode = false;
        }
        showSuccessAlert = false;
    }

    private string? brandLogoPath;
    private string? logoUploadError;

    private void UpdateLogoPath()
    {
        var logoFolder = Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "brand");
        var logoFile = Path.Combine(logoFolder, "logo.png");
        if (File.Exists(logoFile))
        {
            var lastWrite = File.GetLastWriteTimeUtc(logoFile).Ticks;
            brandLogoPath = $"/uploads/brand/logo.png?v={lastWrite}";
        }
        else
        {
            brandLogoPath = null;
        }
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        logoUploadError = null;
        var file = e.File;
        if (file == null) return;

        var extension = Path.GetExtension(file.Name)?.ToLowerInvariant();
        if (extension != ".png" && extension != ".jpg" && extension != ".jpeg" && extension != ".svg")
        {
            logoUploadError = "Only PNG, JPG, JPEG, and SVG images are allowed.";
            return;
        }

        if (file.Size > 1 * 1024 * 1024)
        {
            logoUploadError = "Logo image size cannot exceed 1 MB.";
            return;
        }

        try
        {
            var logoFolder = Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "brand");
            if (!Directory.Exists(logoFolder)) Directory.CreateDirectory(logoFolder);

            var logoFile = Path.Combine(logoFolder, "logo.png");

            using (var stream = new FileStream(logoFile, FileMode.Create))
            {
                await file.OpenReadStream(1 * 1024 * 1024).CopyToAsync(stream);
            }

            UpdateLogoPath();
            showSuccessAlert = true;
            StateHasChanged();

            await Task.Delay(3000);
            showSuccessAlert = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logoUploadError = $"Failed to save logo: {ex.Message}";
        }
    }

    private void ResetBrandLogo()
    {
        logoUploadError = null;
        try
        {
            var logoFile = Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "brand", "logo.png");
            if (File.Exists(logoFile))
            {
                File.Delete(logoFile);
            }
            UpdateLogoPath();
            showSuccessAlert = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logoUploadError = $"Failed to delete logo: {ex.Message}";
        }
    }
}
